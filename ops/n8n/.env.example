TZ=Europe/Bratislava

# Generate once and keep stable:
# openssl rand -hex 32
N8N_ENCRYPTION_KEY=replace-with-long-random-string

POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace-with-db-password
POSTGRES_DB=n8n

NOCODB_PUBLIC_PORT=8080
NOCODB_JWT_SECRET=replace-with-another-long-random-string
NOCODB_PUBLIC_URL=http://127.0.0.1:8080

# Local-only setup.
N8N_PUBLIC_PORT=5678
N8N_HOST=127.0.0.1
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://127.0.0.1:5678/
WEBHOOK_URL=http://127.0.0.1:5678/
N8N_SECURE_COOKIE=false

# Public tunnel/domain setup.
# N8N_HOST=n8n.your-domain.sk
# N8N_PROTOCOL=https
# N8N_EDITOR_BASE_URL=https://n8n.your-domain.sk/
# WEBHOOK_URL=https://n8n.your-domain.sk/
# N8N_SECURE_COOKIE=true
# CLOUDFLARED_TUNNEL_TOKEN=

# Telegram notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional WhatsApp Cloud API.
WHATSAPP_API_VERSION=v20.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
JAKUB_WHATSAPP_TO=421944844489
