---
const analyticsMode = import.meta.env.PUBLIC_ANALYTICS_MODE ?? "disabled";
const ga4MeasurementId = import.meta.env.PUBLIC_GA4_MEASUREMENT_ID ?? "";
const googleAdsId = import.meta.env.PUBLIC_GOOGLE_ADS_ID ?? "";
const googleAdsConversionLabel = import.meta.env.PUBLIC_GOOGLE_ADS_CONVERSION_LABEL ?? "";
const consentConfig = {
  analyticsMode,
  ga4MeasurementId,
  googleAdsId,
  googleAdsConversionLabel,
};
---

<div
  class="cookie-consent"
  data-cookie-consent
  data-config={JSON.stringify(consentConfig)}
  hidden
>
  <div class="cookie-consent__scrim" data-cookie-consent-close aria-hidden="true"></div>
  <section
    class="cookie-consent__panel"
    role="dialog"
    aria-modal="false"
    aria-labelledby="cookie-consent-title"
    aria-describedby="cookie-consent-copy"
  >
    <div class="cookie-consent__content">
      <p class="cookie-consent__eyebrow">Cookies a meranie</p>
      <h2 id="cookie-consent-title">Nastavenie súkromia</h2>
      <p id="cookie-consent-copy">
        Nevyhnutné služby používam na fungovanie webu a rezervačného formulára. Analytiku a
        marketingové meranie spustím iba po vašom súhlase.
      </p>
      <a class="cookie-consent__link" href="/ochrana-osobnych-udajov/">Ochrana osobných údajov a cookies</a>
    </div>

    <div class="cookie-consent__preferences" data-cookie-preferences hidden>
      <label class="cookie-consent__toggle">
        <span>
          <strong>Nevyhnutné</strong>
          <small>Web, bezpečnosť, rezervačný formulár a uloženie tejto voľby.</small>
        </span>
        <input type="checkbox" checked disabled />
      </label>
      <label class="cookie-consent__toggle">
        <span>
          <strong>Analytika</strong>
          <small>GA4 návštevnosť a anonymizované funnel eventy bez osobných údajov.</small>
        </span>
        <input type="checkbox" data-cookie-category="analytics" />
      </label>
      <label class="cookie-consent__toggle">
        <span>
          <strong>Marketing</strong>
          <small>Google Ads konverzie po úspešnej rezervácii. Remarketing a enhanced conversions sú vypnuté.</small>
        </span>
        <input type="checkbox" data-cookie-category="marketing" />
      </label>
    </div>

    <div class="cookie-consent__actions">
      <button class="cookie-consent__button secondary" type="button" data-cookie-reject>
        Odmietnuť voliteľné
      </button>
      <button class="cookie-consent__button secondary" type="button" data-cookie-customize>
        Nastaviť
      </button>
      <button class="cookie-consent__button primary" type="button" data-cookie-accept>
        Prijať všetko
      </button>
      <button class="cookie-consent__button primary" type="button" data-cookie-save hidden>
        Uložiť nastavenia
      </button>
    </div>
  </section>
</div>

<script>
  (() => {
    const root = document.querySelector("[data-cookie-consent]");
    if (!(root instanceof HTMLElement)) return;

    const storageKey = "jakub_cookie_consent_v1";
    const version = 1;
    const ttlMs = 182 * 24 * 60 * 60 * 1000;
    const config = (() => {
      try {
        return JSON.parse(root.dataset.config || "{}");
      } catch {
        return {};
      }
    })();
    const analyticsMode = String(config.analyticsMode || "disabled").toLowerCase();
    const ga4MeasurementId = String(config.ga4MeasurementId || "").trim();
    const googleAdsId = String(config.googleAdsId || "").trim();
    const googleAdsConversionLabel = String(config.googleAdsConversionLabel || "").trim();
    const analyticsEnabled = analyticsMode !== "disabled";
    const debugMode = analyticsMode === "test";
    let googleTagLoaded = false;
    let pageViewSent = false;

    const preferences = root.querySelector("[data-cookie-preferences]");
    const analyticsInput = root.querySelector('[data-cookie-category="analytics"]');
    const marketingInput = root.querySelector('[data-cookie-category="marketing"]');
    const acceptButton = root.querySelector("[data-cookie-accept]");
    const rejectButton = root.querySelector("[data-cookie-reject]");
    const customizeButton = root.querySelector("[data-cookie-customize]");
    const saveButton = root.querySelector("[data-cookie-save]");

    window.dataLayer = window.dataLayer || [];
    window.gtag =
      window.gtag ||
      function gtag() {
        window.dataLayer.push(arguments);
      };
    window.gtag("consent", "default", {
      analytics_storage: "denied",
      ad_storage: "denied",
      ad_user_data: "denied",
      ad_personalization: "denied",
      security_storage: "granted",
    });

    const normalizeConsent = (value = {}) => {
      const now = new Date().toISOString();
      const expiresAt = new Date(Date.now() + ttlMs).toISOString();
      return {
        necessary: true,
        analytics: Boolean(value.analytics),
        marketing: Boolean(value.marketing),
        version,
        updated_at: value.updated_at || now,
        expires_at: value.expires_at || expiresAt,
      };
    };

    const readConsent = () => {
      try {
        const stored = window.localStorage.getItem(storageKey);
        if (!stored) return null;
        const parsed = JSON.parse(stored);
        if (parsed.version !== version) return null;
        if (!parsed.expires_at || Date.parse(parsed.expires_at) <= Date.now()) return null;
        return normalizeConsent(parsed);
      } catch {
        return null;
      }
    };

    const writeConsent = (value) => {
      const consent = normalizeConsent({
        ...value,
        updated_at: new Date().toISOString(),
        expires_at: new Date(Date.now() + ttlMs).toISOString(),
      });

      try {
        window.localStorage.setItem(storageKey, JSON.stringify(consent));
      } catch {
        // Consent storage must never break the site.
      }

      applyConsent(consent);
      hideBanner();
      window.dispatchEvent(new CustomEvent("cookie-consent:update", { detail: consent }));
      return consent;
    };

    const updateGoogleConsent = (consent) => {
      window.gtag("consent", "update", {
        analytics_storage: consent.analytics ? "granted" : "denied",
        ad_storage: consent.marketing ? "granted" : "denied",
        ad_user_data: consent.marketing ? "granted" : "denied",
        ad_personalization: consent.marketing ? "granted" : "denied",
        security_storage: "granted",
      });
    };

    const loadGoogleTag = (tagId) => {
      if (!analyticsEnabled || googleTagLoaded || !tagId) return;
      googleTagLoaded = true;
      const script = document.createElement("script");
      script.async = true;
      script.src = `https://www.googletagmanager.com/gtag/js?id=${encodeURIComponent(tagId)}`;
      document.head.append(script);
      window.gtag("js", new Date());
    };

    const applyConsent = (consent) => {
      updateGoogleConsent(consent);

      if (!analyticsEnabled) return;

      if (consent.analytics && ga4MeasurementId) {
        loadGoogleTag(ga4MeasurementId);
        window.gtag("config", ga4MeasurementId, { send_page_view: false, debug_mode: debugMode });
        if (!pageViewSent) {
          pageViewSent = true;
          window.gtag("event", "page_view", {
            page_location: window.location.href,
            page_path: window.location.pathname,
            page_title: document.title,
            debug_mode: debugMode,
          });
        }
      }

      if (consent.marketing && googleAdsId) {
        loadGoogleTag(ga4MeasurementId || googleAdsId);
        window.gtag("config", googleAdsId, { send_page_view: false });
      }
    };

    const setPreferenceInputs = (consent) => {
      if (analyticsInput instanceof HTMLInputElement) analyticsInput.checked = Boolean(consent?.analytics);
      if (marketingInput instanceof HTMLInputElement) marketingInput.checked = Boolean(consent?.marketing);
    };

    const showBanner = (expanded = false) => {
      setPreferenceInputs(readConsent() || { analytics: false, marketing: false });
      root.hidden = false;
      root.classList.toggle("is-expanded", expanded);
      if (preferences instanceof HTMLElement) preferences.hidden = !expanded;
      if (customizeButton instanceof HTMLElement) customizeButton.hidden = expanded;
      if (acceptButton instanceof HTMLElement) acceptButton.hidden = expanded;
      if (saveButton instanceof HTMLElement) saveButton.hidden = !expanded;
    };

    const hideBanner = () => {
      root.hidden = true;
      root.classList.remove("is-expanded");
    };

    const currentPreferenceValue = () => ({
      analytics: analyticsInput instanceof HTMLInputElement && analyticsInput.checked,
      marketing: marketingInput instanceof HTMLInputElement && marketingInput.checked,
    });

    const sanitizeEventParams = (params = {}) => {
      const allowed = [
        "intent",
        "property_type",
        "booking_status",
        "mode",
        "utm_source",
        "utm_medium",
        "utm_campaign",
        "utm_content",
        "utm_term",
        "landing_path",
        "lead_source",
      ];
      return allowed.reduce((safe, key) => {
        const value = params[key];
        if (value === undefined || value === null || value === "") return safe;
        safe[key] = String(value).slice(0, 120);
        return safe;
      }, {});
    };

    window.jakubConsent = {
      get: readConsent,
      open: () => showBanner(true),
      has: (category) => Boolean(readConsent()?.[category]),
      trackEvent: (eventName, params = {}) => {
        const consent = readConsent();
        if (!analyticsEnabled || !consent?.analytics || !ga4MeasurementId) return false;
        applyConsent(consent);
        window.gtag("event", eventName, {
          ...sanitizeEventParams(params),
          debug_mode: debugMode,
        });
        return true;
      },
      trackLeadConversion: (params = {}) => {
        const consent = readConsent();
        if (!analyticsEnabled || !consent?.marketing || !googleAdsId || !googleAdsConversionLabel) return false;
        applyConsent(consent);
        window.gtag("event", "conversion", {
          send_to: `${googleAdsId}/${googleAdsConversionLabel}`,
          ...sanitizeEventParams(params),
        });
        return true;
      },
    };

    acceptButton?.addEventListener("click", () => writeConsent({ analytics: true, marketing: true }));
    rejectButton?.addEventListener("click", () => writeConsent({ analytics: false, marketing: false }));
    customizeButton?.addEventListener("click", () => showBanner(true));
    saveButton?.addEventListener("click", () => writeConsent(currentPreferenceValue()));

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      const trigger = target.closest("[data-cookie-consent-manage]");
      if (!trigger) return;
      event.preventDefault();
      showBanner(true);
    });

    const existingConsent = readConsent();
    if (existingConsent) {
      applyConsent(existingConsent);
    } else {
      showBanner(false);
    }
  })();
</script>

<style>
  .cookie-consent[hidden] {
    display: none;
  }

  .cookie-consent {
    position: fixed;
    z-index: 200;
    inset: 0;
    display: grid;
    align-items: end;
    padding: 18px;
    pointer-events: none;
  }

  .cookie-consent__scrim {
    position: absolute;
    inset: 0;
    background: rgba(11, 11, 10, 0.08);
    opacity: 0;
  }

  .cookie-consent.is-expanded .cookie-consent__scrim {
    opacity: 1;
  }

  .cookie-consent__panel {
    position: relative;
    width: min(720px, 100%);
    margin: 0 auto;
    border: 1px solid rgba(11, 11, 10, 0.18);
    border-radius: 8px;
    background: #fffaf2;
    box-shadow: 0 24px 70px rgba(11, 11, 10, 0.24);
    color: #0b0b0a;
    pointer-events: auto;
  }

  .cookie-consent__content {
    padding: 24px 24px 16px;
  }

  .cookie-consent__eyebrow {
    margin: 0 0 8px;
    color: #9a5c32;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .cookie-consent h2 {
    margin: 0 0 10px;
    font-family: "Newsreader", Georgia, serif;
    font-size: 30px;
    line-height: 1;
  }

  .cookie-consent p {
    margin: 0;
    color: #5f5a52;
    font-family: "Instrument Sans", system-ui, sans-serif;
    font-size: 15px;
    line-height: 1.55;
  }

  .cookie-consent__link {
    display: inline-flex;
    margin-top: 12px;
    color: #9a5c32;
    font-size: 14px;
    font-weight: 800;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .cookie-consent__preferences {
    display: grid;
    gap: 10px;
    padding: 0 24px 8px;
  }

  .cookie-consent__toggle {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 18px;
    align-items: center;
    border: 1px solid rgba(11, 11, 10, 0.14);
    border-radius: 8px;
    padding: 14px;
    background: rgba(246, 241, 232, 0.62);
  }

  .cookie-consent__toggle strong,
  .cookie-consent__toggle small {
    display: block;
  }

  .cookie-consent__toggle strong {
    margin-bottom: 4px;
    font-size: 14px;
  }

  .cookie-consent__toggle small {
    color: #6f6a62;
    font-size: 13px;
    line-height: 1.45;
  }

  .cookie-consent__toggle input {
    width: 44px;
    height: 24px;
    accent-color: #9a5c32;
  }

  .cookie-consent__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: flex-end;
    border-top: 1px solid rgba(11, 11, 10, 0.12);
    padding: 16px 24px 24px;
  }

  .cookie-consent__button {
    min-height: 42px;
    border-radius: 6px;
    padding: 0 16px;
    font: 800 14px/1 "Instrument Sans", system-ui, sans-serif;
    cursor: pointer;
  }

  .cookie-consent__button.primary {
    border: 1px solid #0b0b0a;
    background: #0b0b0a;
    color: #fffaf2;
  }

  .cookie-consent__button.secondary {
    border: 1px solid rgba(11, 11, 10, 0.18);
    background: transparent;
    color: #0b0b0a;
  }

  @media (max-width: 620px) {
    .cookie-consent {
      padding: 12px;
    }

    .cookie-consent__content {
      padding: 20px 18px 14px;
    }

    .cookie-consent__preferences {
      padding: 0 18px 8px;
    }

    .cookie-consent__actions {
      display: grid;
      padding: 14px 18px 18px;
    }

    .cookie-consent__button {
      width: 100%;
    }
  }
</style>
