---
import "../styles/global.css";
import { site } from "../data/site";

const cleanPhone = site.contact.phone.replace(/[^\d+]/g, "");
const contactHref = cleanPhone.length >= 10 ? `tel:${cleanPhone}` : "/";
---

<!doctype html>
<html lang="sk">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="icon" type="image/png" href="/favicon.png?v=2" />
    <link rel="icon" href="/favicon.ico?v=2" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <meta name="description" content={`Stránka sa nenašla | ${site.brand}`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Newsreader:opsz,wght@6..72,500;6..72,650;6..72,700&display=swap"
      rel="stylesheet"
    />
    <title>Stránka sa nenašla | {site.brand}</title>
    <style>
      :root {
        --paper: #f6f1e8;
        --ink: #0b0b0a;
        --charcoal: #1b1b19;
        --brass: #d8b878;
        --white: #fffaf2;
        --muted: rgba(255, 250, 242, 0.72);
        --font-body: "Instrument Sans", system-ui, sans-serif;
        --font-display: "Newsreader", Georgia, serif;
      }

      * {
        box-sizing: border-box;
      }

      body {
        display: grid;
        min-height: 100svh;
        margin: 0;
        place-items: center;
        background:
          linear-gradient(110deg, rgba(11, 11, 10, 0.98), rgba(27, 27, 25, 0.92)),
          var(--ink);
        color: var(--white);
        font-family: var(--font-body);
      }

      main {
        width: min(760px, calc(100% - 36px));
        padding: 72px 0;
      }

      img {
        width: 148px;
        height: auto;
        margin-bottom: 42px;
      }

      p,
      h1 {
        margin-top: 0;
      }

      .eyebrow {
        margin-bottom: 16px;
        color: var(--brass);
        font-size: 14px;
        font-weight: 800;
      }

      h1 {
        max-width: 680px;
        margin-bottom: 22px;
        font-family: var(--font-display);
        font-size: clamp(48px, 8vw, 92px);
        font-weight: 650;
        line-height: 0.96;
      }

      .text {
        max-width: 560px;
        margin-bottom: 34px;
        color: var(--muted);
        font-size: 18px;
        line-height: 1.55;
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
      }

      a {
        color: inherit;
      }

      .button {
        display: inline-flex;
        min-height: 50px;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(255, 250, 242, 0.28);
        border-radius: 6px;
        padding: 0 20px;
        font-weight: 800;
        text-decoration: none;
      }

      .primary {
        border-color: var(--brass);
        background: var(--brass);
        color: var(--ink);
      }

      @media (max-width: 620px) {
        .actions {
          display: grid;
        }

        .button {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <img src={site.logoImage} alt="" />
      <p class="eyebrow">Stránka sa nenašla</p>
      <h1>Vráťte sa k nehnuteľnostiam, ktoré dávajú zmysel.</h1>
      <p class="text">
        Táto adresa neexistuje alebo bola presunutá. Pokračujte späť na úvod, k referenciám
        alebo sa mi ozvite priamo.
      </p>
      <div class="actions">
        <a class="button primary" href="/">Späť na úvod</a>
        <a class="button" href="/#ponuky">Pozrieť predaje</a>
        <a class="button" href={contactHref}>{site.contact.phone}</a>
      </div>
    </main>
  </body>
</html>
