---
import { site } from "../data/site";

const siteEnv = import.meta.env.PUBLIC_SITE_ENV ?? "production";
const isStaging = siteEnv !== "production";
const cleanPhone = site.contact.phone.replace(/[^\d+]/g, "");
const googleMapsApiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY?.trim() ?? "";
const googleMapsScriptUrl = googleMapsApiKey
  ? `https://maps.googleapis.com/maps/api/js?key=${encodeURIComponent(
      googleMapsApiKey,
    )}&libraries=places&v=weekly&language=sk&region=SK&loading=async`
  : "";
---

<!doctype html>
<html lang="sk">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="icon" type="image/png" href="/favicon.png?v=2" />
    <link rel="icon" href="/favicon.ico?v=2" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content={`Rezervácia konzultácie s realitným maklérom Jakubom Olšom. ${site.shortPromise}`}
    />
    {isStaging ? <meta name="robots" content="noindex,nofollow,noarchive" /> : null}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700;800&family=Newsreader:opsz,wght@6..72,500;6..72,650;6..72,700&display=swap"
      rel="stylesheet"
    />
    {googleMapsScriptUrl ? <script is:inline async defer src={googleMapsScriptUrl}></script> : null}
    <title>Rezervácia konzultácie | {site.brand}</title>
  </head>
  <body>
    {isStaging ? <div class="staging-ribbon" aria-hidden="true">STAGING</div> : null}

    <header class="wizard-header">
      <a class="brand" href="/" aria-label={`${site.brand}, späť na úvod`}>
        <img src={site.logoImage} alt="" />
        <span>
          <strong>{site.brand}</strong>
          <small>{site.role}</small>
        </span>
      </a>
      <a class="back-link" href="/">Späť na web</a>
    </header>

    <main class="wizard-shell">
      <section class="wizard-copy" aria-labelledby="wizard-title">
        <p class="eyebrow">{site.bookingFunnel.eyebrow}</p>
        <h1 id="wizard-title">{site.bookingFunnel.title}</h1>
        <p>{site.bookingFunnel.text}</p>
      </section>

      <form class="wizard-card" data-funnel-form data-email={site.contact.email} data-google-places-key={googleMapsApiKey ? "true" : "false"}>
        <p class="wizard-error" data-funnel-error aria-live="polite"></p>

        <section class="wizard-step" data-funnel-step>
          <p class="step-kicker">Krok 1</p>
          <h2>Čo chcete riešiť?</h2>
          <p>Vyberte najbližšiu akciu alebo typ nehnuteľnosti. Každá vetva otvorí iné parametre.</p>
          <input type="hidden" name="zamer" data-required data-label="zámer" />
          <div class="choice-grid">
            {
              site.bookingFunnel.intents.map((intent) => (
                <button type="button" class="choice-button" data-choice="zamer" data-value={intent} aria-pressed="false">
                  {intent}
                </button>
              ))
            }
          </div>
        </section>

        <section class="wizard-step" data-funnel-step hidden>
          <p class="step-kicker">Krok 2</p>
          <h2 data-route-title="property">Základné parametre</h2>
          <p data-route-text="property">Vyplňte len to, čo viete. Detaily sa doriešia v hovore.</p>
          <input type="hidden" name="typ" data-route-type />
          <div class="wizard-fields two">
            <label class="location-field" data-location-field>
              <span>Lokalita</span>
              <input
                name="lokalita"
                placeholder="Mesto, časť alebo ulica"
                autocomplete="off"
                data-required
                data-label="lokalita"
                data-location-input
              />
              <input type="hidden" name="lokalita_place_id" data-location-place-id />
              <input type="hidden" name="lokalita_lat" data-location-lat />
              <input type="hidden" name="lokalita_lng" data-location-lng />
              <input type="hidden" name="lokalita_overena" data-location-verified />
              <small class="field-note" data-location-hint>
                {googleMapsApiKey ? "Začnite písať a vyberte overenú adresu z Google." : "Google overenie adresy sa zapne po doplnení API kľúča."}
              </small>
            </label>
            <label data-param-field="property_kind">
              <span>Typ nehnuteľnosti</span>
              <select name="typ_detail">
                <option value="">Vyberte typ</option>
                <option value="Byt">Byt</option>
                <option value="Dom">Dom</option>
                <option value="Pozemok">Pozemok</option>
                <option value="Komerčný priestor">Komerčný priestor</option>
                <option value="Investičná nehnuteľnosť">Investičná nehnuteľnosť</option>
              </select>
            </label>
            <label data-param-field="rooms">
              <span>Izby</span>
              <input name="izby" placeholder="napr. 4 izby" />
            </label>
            <label data-param-field="area">
              <span>Výmera</span>
              <input name="vymera" placeholder="napr. 156 m²" />
            </label>
            <label data-param-field="floor">
              <span>Poschodie</span>
              <input name="poschodie" placeholder="napr. 3/6" />
            </label>
            <label data-param-field="condition">
              <span>Stav</span>
              <select name="stav">
                <option value="">Vyberte stav</option>
                <option value="Pôvodný stav">Pôvodný stav</option>
                <option value="Čiastočná rekonštrukcia">Čiastočná rekonštrukcia</option>
                <option value="Kompletná rekonštrukcia">Kompletná rekonštrukcia</option>
                <option value="Novostavba">Novostavba</option>
                <option value="Na dokončenie">Na dokončenie</option>
              </select>
            </label>
            <label data-param-field="extras">
              <span>Doplnky</span>
              <input name="doplnky" placeholder="balkón, terasa, pivnica, parkovanie" />
            </label>
            <label data-param-field="house_area">
              <span>Úžitková plocha</span>
              <input name="uzitkova_plocha" placeholder="napr. 180 m²" />
            </label>
            <label data-param-field="land_area">
              <span>Výmera pozemku</span>
              <input name="vymera_pozemku" placeholder="napr. 620 m²" />
            </label>
            <label data-param-field="land_type">
              <span>Typ pozemku</span>
              <select name="typ_pozemku">
                <option value="">Vyberte typ</option>
                <option value="Stavebný pozemok">Stavebný pozemok</option>
                <option value="Záhrada">Záhrada</option>
                <option value="Rekreačný pozemok">Rekreačný pozemok</option>
                <option value="Orná pôda">Orná pôda</option>
                <option value="Iné">Iné</option>
              </select>
            </label>
            <label data-param-field="utilities">
              <span>Siete</span>
              <input name="siete" placeholder="voda, elektrina, plyn, kanalizácia" />
            </label>
            <label data-param-field="access">
              <span>Prístup</span>
              <input name="pristup" placeholder="asfaltová cesta, podiel, vecné bremeno..." />
            </label>
            <label data-param-field="commercial_type">
              <span>Typ priestoru</span>
              <select name="typ_komercneho_priestoru">
                <option value="">Vyberte typ</option>
                <option value="Kancelárie">Kancelárie</option>
                <option value="Obchod">Obchod</option>
                <option value="Sklad / hala">Sklad / hala</option>
                <option value="Gastro">Gastro</option>
                <option value="Polyfunkčný objekt">Polyfunkčný objekt</option>
                <option value="Iné">Iné</option>
              </select>
            </label>
            <label data-param-field="occupancy">
              <span>Obsadenosť</span>
              <input name="obsadenost" placeholder="voľné, nájomca, vlastné užívanie" />
            </label>
            <label data-param-field="rent_target">
              <span>Očakávaný nájom</span>
              <input name="ocakavany_najom" placeholder="napr. 950 € / mesiac" />
            </label>
            <label data-param-field="available_from">
              <span>Dostupné od</span>
              <input name="dostupne_od" placeholder="napr. ihneď, od septembra" />
            </label>
            <label data-param-field="management_scope">
              <span>Rozsah správy</span>
              <input name="rozsah_spravy" placeholder="iba nájomca, správa, servis, vyúčtovania" />
            </label>
          </div>
        </section>

        <section class="wizard-step" data-funnel-step hidden>
          <p class="step-kicker">Krok 3</p>
          <h2 data-route-title="date">Kedy sa vám hodí hovor?</h2>
          <p data-route-text="date">Kým nie je napojený kalendár, ide o preferovaný termín. Jakub ho potvrdí späť.</p>
          <div class="wizard-fields">
            <label>
              <span>Preferovaný dátum</span>
              <input name="datum" type="date" data-funnel-date data-required data-label="dátum hovoru" />
            </label>
          </div>
          <input type="hidden" name="cas" data-required data-label="čas hovoru" />
          <div class="slot-grid" aria-label="Preferovaný čas hovoru">
            {
              site.bookingFunnel.timeSlots.map((slot) => (
                <button type="button" class="slot-button" data-choice="cas" data-value={slot} aria-pressed="false">
                  {slot}
                </button>
              ))
            }
          </div>
        </section>

        <section class="wizard-step" data-funnel-step hidden>
          <p class="step-kicker">Krok 4</p>
          <h2 data-route-title="contact">Kam má Jakub poslať potvrdenie?</h2>
          <p data-route-text="contact">Po odoslaní sa otvorí email s vyplneným kontextom. Neskôr tento krok nahradí backend a kalendár.</p>
          <div class="wizard-fields two">
            <label>
              <span>Meno</span>
              <input name="meno" autocomplete="name" data-required data-label="meno" />
            </label>
            <label>
              <span>Telefón</span>
              <input name="telefon" type="tel" autocomplete="tel" data-required data-label="telefón" />
            </label>
            <label>
              <span>Email</span>
              <input name="email" type="email" autocomplete="email" />
            </label>
            <label>
              <span>Časový horizont</span>
              <select name="horizont">
                <option value="">Vyberte horizont</option>
                <option value="Ihneď">Ihneď</option>
                <option value="1-3 mesiace">1-3 mesiace</option>
                <option value="3-6 mesiacov">3-6 mesiacov</option>
                <option value="Zatiaľ len zisťujem možnosti">Zatiaľ len zisťujem možnosti</option>
              </select>
            </label>
            <label class="full">
              <span>Čo je pre vás dôležité?</span>
              <textarea
                name="sprava"
                rows="4"
                placeholder="Cena, rýchlosť, diskrétnosť, kúpa nového bývania, investícia..."
                data-route-placeholder="message"
              ></textarea>
            </label>
          </div>
        </section>

        <div class="wizard-summary" data-funnel-summary aria-live="polite"></div>

        <div class="wizard-actions">
          <button type="button" class="button secondary" data-funnel-prev>Späť</button>
          <button type="button" class="button primary" data-funnel-next>Pokračovať</button>
          <button type="submit" class="button primary" data-funnel-submit hidden>Odoslať a rezervovať</button>
        </div>

        <div class="wizard-progress" aria-label="Postup rezervácie">
          <span data-funnel-progress>1 / 4</span>
          <div aria-hidden="true">
            <i data-funnel-bar></i>
          </div>
        </div>
      </form>
    </main>

    <footer class="wizard-footer">
      <div class="footer-brand">
        <img src={site.logoImage} alt="" />
        <p>{site.brand}</p>
      </div>
      <nav aria-label="Kontaktné odkazy">
        <a href={`tel:${cleanPhone}`}>{site.contact.phone}</a>
        <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>
        <a href="/">Späť na web</a>
      </nav>
    </footer>

    <script>
      const funnelForm = document.querySelector("[data-funnel-form]");

      if (funnelForm instanceof HTMLFormElement) {
        const funnelSteps = Array.from(funnelForm.querySelectorAll("[data-funnel-step]"));
        const progressText = funnelForm.querySelector("[data-funnel-progress]");
        const progressBar = funnelForm.querySelector("[data-funnel-bar]");
        const funnelError = funnelForm.querySelector("[data-funnel-error]");
        const funnelPrev = funnelForm.querySelector("[data-funnel-prev]");
        const funnelNext = funnelForm.querySelector("[data-funnel-next]");
        const funnelSubmit = funnelForm.querySelector("[data-funnel-submit]");
        const funnelSummary = funnelForm.querySelector("[data-funnel-summary]");
        const dateInput = funnelForm.querySelector("[data-funnel-date]");
        const locationField = funnelForm.querySelector("[data-location-field]");
        const locationInput = funnelForm.querySelector("[data-location-input]");
        const locationPlaceId = funnelForm.querySelector("[data-location-place-id]");
        const locationLat = funnelForm.querySelector("[data-location-lat]");
        const locationLng = funnelForm.querySelector("[data-location-lng]");
        const locationVerified = funnelForm.querySelector("[data-location-verified]");
        const locationHint = funnelForm.querySelector("[data-location-hint]");
        const routeTypeField = funnelForm.querySelector("[data-route-type]");
        const paramFields = Array.from(funnelForm.querySelectorAll("[data-param-field]"));
        const routeTitles = {
          property: funnelForm.querySelector('[data-route-title="property"]'),
          date: funnelForm.querySelector('[data-route-title="date"]'),
          contact: funnelForm.querySelector('[data-route-title="contact"]'),
        };
        const routeTexts = {
          property: funnelForm.querySelector('[data-route-text="property"]'),
          date: funnelForm.querySelector('[data-route-text="date"]'),
          contact: funnelForm.querySelector('[data-route-text="contact"]'),
        };
        const routePlaceholders = {
          message: funnelForm.querySelector('[data-route-placeholder="message"]'),
        };
        let activeStep = 0;

        const parameterLabels = {
          typ_detail: "Typ nehnuteľnosti",
          izby: "Izby",
          vymera: "Výmera",
          poschodie: "Poschodie",
          stav: "Stav",
          doplnky: "Doplnky",
          uzitkova_plocha: "Úžitková plocha",
          vymera_pozemku: "Výmera pozemku",
          typ_pozemku: "Typ pozemku",
          siete: "Siete",
          pristup: "Prístup",
          typ_komercneho_priestoru: "Typ priestoru",
          obsadenost: "Obsadenosť",
          ocakavany_najom: "Očakávaný nájom",
          dostupne_od: "Dostupné od",
          rozsah_spravy: "Rozsah správy",
        };

        const defaultRoute = {
          propertyType: "",
          paramFields: ["property_kind", "rooms", "area", "condition"],
          propertyTitle: "K akej nehnuteľnosti chcete zistiť možnosti?",
          propertyText: "Vyberte typ a doplňte základné údaje. Jakub z toho pripraví najrozumnejší prvý postup.",
          dateTitle: "Kedy sa vám hodí hovor?",
          dateText: "Vyberte čas na krátky orientačný hovor bez tlaku na okamžité rozhodnutie.",
          contactTitle: "Kam má Jakub poslať potvrdenie konzultácie?",
          contactText: "Po odoslaní dostane Jakub základný kontext a pripraví otázky k možnostiam.",
          messagePlaceholder: "Čo zvažujete, čo vás brzdí, čo by bol dobrý výsledok...",
          leadTitle: "Konzultácia možností z webu Jakuba Olšu",
          subjectPrefix: "Konzultácia možností",
          submitLabel: "Požiadať o konzultáciu",
        };

        const intentRoutes = {
          "Zistiť možnosti": defaultRoute,
          "Predať byt": {
            propertyType: "Byt",
            paramFields: ["rooms", "area", "floor", "condition", "extras"],
            propertyTitle: "Aký byt chcete predať?",
            propertyText: "Pri byte sú dôležité lokalita, dispozícia, výmera, poschodie, stav a doplnky ako balkón, pivnica alebo parkovanie.",
            dateTitle: "Kedy chcete prejsť predaj bytu?",
            dateText: "Vyberte termín hovoru k cene, príprave, prezentácii a predajnému postupu.",
            contactTitle: "Kam má Jakub poslať potvrdenie predajnej konzultácie?",
            contactText: "Po odoslaní bude mať Jakub základné parametre bytu a pripraví sa na konkrétny rozhovor.",
            messagePlaceholder: "Očakávaná cena, dôvod predaja, časový tlak, parkovanie, pivnica, právny stav...",
            leadTitle: "Predaj bytu z webu Jakuba Olšu",
            subjectPrefix: "Predaj bytu",
            submitLabel: "Odoslať predaj bytu",
          },
          "Predať dom": {
            propertyType: "Dom",
            paramFields: ["rooms", "house_area", "land_area", "condition", "extras"],
            propertyTitle: "Aký dom chcete predať?",
            propertyText: "Pri dome potrebujeme oddeliť úžitkovú plochu, pozemok, stav a veci ako garáž, terasa, bazén alebo technické zázemie.",
            dateTitle: "Kedy chcete prejsť predaj domu?",
            dateText: "Vyberte termín hovoru k cene, prezentácii, marketingu a servisnému postupu.",
            contactTitle: "Kam má Jakub poslať potvrdenie konzultácie k domu?",
            contactText: "Po odoslaní bude mať Jakub základ pre prvý odhad situácie a prípravu otázok.",
            messagePlaceholder: "Rok výstavby, rekonštrukcia, technický stav, garáž, záhrada, dôvod predaja...",
            leadTitle: "Predaj domu z webu Jakuba Olšu",
            subjectPrefix: "Predaj domu",
            submitLabel: "Odoslať predaj domu",
          },
          "Predať pozemok": {
            propertyType: "Pozemok",
            paramFields: ["land_area", "land_type", "utilities", "access"],
            propertyTitle: "Aký pozemok chcete predať?",
            propertyText: "Pri pozemku rozhoduje výmera, typ pozemku, siete, prístup a regulácia. Detaily sa preveria následne.",
            dateTitle: "Kedy chcete prejsť predaj pozemku?",
            dateText: "Vyberte termín hovoru k potenciálu pozemku, prevereniu rizík a predajnému postupu.",
            contactTitle: "Kam má Jakub poslať potvrdenie konzultácie k pozemku?",
            contactText: "Po odoslaní bude mať Jakub kontext k pozemku a pripraví si ďalšie otázky.",
            messagePlaceholder: "Územný plán, list vlastníctva, prístup, siete, či už máte cenovú predstavu...",
            leadTitle: "Predaj pozemku z webu Jakuba Olšu",
            subjectPrefix: "Predaj pozemku",
            submitLabel: "Odoslať predaj pozemku",
          },
          "Predať komerčný priestor": {
            propertyType: "Komerčný priestor",
            paramFields: ["commercial_type", "area", "condition", "occupancy", "extras"],
            propertyTitle: "Aký komerčný priestor chcete predať?",
            propertyText: "Pri komerčnej nehnuteľnosti sú podstatné typ priestoru, výmera, stav, obsadenosť a investičný potenciál.",
            dateTitle: "Kedy chcete prejsť predaj komerčného priestoru?",
            dateText: "Vyberte termín hovoru k stratégii predaja, číslam, nájomcom a prezentácii.",
            contactTitle: "Kam má Jakub poslať potvrdenie komerčnej konzultácie?",
            contactText: "Po odoslaní bude mať Jakub základ pre obchodný a investičný pohľad na nehnuteľnosť.",
            messagePlaceholder: "Nájomca, výnos, prevádzka, stav zmlúv, parkovanie, technické špecifiká...",
            leadTitle: "Predaj komerčného priestoru z webu Jakuba Olšu",
            subjectPrefix: "Predaj komerčného priestoru",
            submitLabel: "Odoslať komerčný predaj",
          },
          "Prenájom alebo správa": {
            propertyType: "Prenájom / správa",
            paramFields: ["property_kind", "rooms", "area", "condition", "rent_target", "available_from", "management_scope"],
            propertyTitle: "Čo chcete prenajať alebo spravovať?",
            propertyText: "Pri prenájme rozhoduje lokalita, dispozícia, stav, zariadenie a očakávaný typ nájomcu.",
            dateTitle: "Kedy chcete prejsť prenájom alebo správu?",
            dateText: "Vyberte čas hovoru k nájomnému, prezentácii, výberu nájomcu a správe.",
            contactTitle: "Kam má Jakub poslať potvrdenie prenájmovej konzultácie?",
            contactText: "Po odoslaní bude mať Jakub základ pre návrh prenájmu alebo správy.",
            messagePlaceholder: "Zariadenie, očakávaný nájom, či chcete iba nájomcu alebo aj správu...",
            leadTitle: "Prenájom alebo správa z webu Jakuba Olšu",
            subjectPrefix: "Prenájom alebo správa",
            submitLabel: "Odoslať prenájom/správu",
          },
        };

        if (dateInput instanceof HTMLInputElement) {
          const now = new Date();
          now.setDate(now.getDate() + 1);
          const localDate = new Date(now.getTime() - now.getTimezoneOffset() * 60000).toISOString().slice(0, 10);
          dateInput.min = localDate;
          if (!dateInput.value) dateInput.value = localDate;
        }

        const funnelValue = (name) => {
          const field = funnelForm.elements.namedItem(name);

          if (field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement || field instanceof HTMLSelectElement) {
            return field.value.trim();
          }

          return "";
        };

        const setFunnelError = (message = "") => {
          if (funnelError) funnelError.textContent = message;
        };

        const currentRoute = () => intentRoutes[funnelValue("zamer")] || defaultRoute;

        const setParamFieldState = (field, isActive) => {
          if (!(field instanceof HTMLElement)) return;

          field.hidden = !isActive;
          field.querySelectorAll("input, select, textarea").forEach((control) => {
            if (
              control instanceof HTMLInputElement ||
              control instanceof HTMLTextAreaElement ||
              control instanceof HTMLSelectElement
            ) {
              control.disabled = !isActive;
              if (!isActive) control.value = "";
            }
          });
        };

        const routeParameterLines = () => {
          const route = currentRoute();

          return (route.paramFields || [])
            .map((fieldKey) => {
              const field = paramFields.find((item) => item instanceof HTMLElement && item.dataset.paramField === fieldKey);
              if (!(field instanceof HTMLElement)) return "";

              const control = field.querySelector("input, select, textarea");
              if (
                !(control instanceof HTMLInputElement) &&
                !(control instanceof HTMLTextAreaElement) &&
                !(control instanceof HTMLSelectElement)
              ) {
                return "";
              }

              const value = control.value.trim();
              if (!value) return "";

              const label = parameterLabels[control.name] || field.querySelector("span")?.textContent?.trim() || control.name;
              return `${label}: ${value}`;
            })
            .filter(Boolean);
        };

        const applyIntentRoute = () => {
          const route = currentRoute();
          const activeParamFields = new Set(route.paramFields || []);

          if (routeTypeField instanceof HTMLInputElement) {
            routeTypeField.value = funnelValue("zamer") ? route.propertyType || "" : "";
          }
          if (routeTitles.property) routeTitles.property.textContent = route.propertyTitle;
          if (routeTitles.date) routeTitles.date.textContent = route.dateTitle;
          if (routeTitles.contact) routeTitles.contact.textContent = route.contactTitle;
          if (routeTexts.property) routeTexts.property.textContent = route.propertyText;
          if (routeTexts.date) routeTexts.date.textContent = route.dateText;
          if (routeTexts.contact) routeTexts.contact.textContent = route.contactText;
          if (routePlaceholders.message instanceof HTMLTextAreaElement) {
            routePlaceholders.message.placeholder = route.messagePlaceholder;
          }
          if (funnelSubmit instanceof HTMLButtonElement) {
            funnelSubmit.textContent = route.submitLabel;
          }

          paramFields.forEach((field) => {
            const key = field instanceof HTMLElement ? field.dataset.paramField || "" : "";
            setParamFieldState(field, activeParamFields.has(key));
          });
        };

        const setLocationHint = (message = "") => {
          if (locationHint) locationHint.textContent = message;
        };

        const clearLocationVerification = () => {
          if (locationPlaceId instanceof HTMLInputElement) locationPlaceId.value = "";
          if (locationLat instanceof HTMLInputElement) locationLat.value = "";
          if (locationLng instanceof HTMLInputElement) locationLng.value = "";
          if (locationVerified instanceof HTMLInputElement) locationVerified.value = "";
          if (locationField instanceof HTMLElement) locationField.classList.remove("is-verified");
        };

        const waitForGooglePlaces = () =>
          new Promise((resolve, reject) => {
            const startedAt = Date.now();
            const timer = window.setInterval(async () => {
              if (window.google?.maps?.importLibrary) {
                window.clearInterval(timer);
                await window.google.maps.importLibrary("places");
                resolve(window.google.maps.places);
                return;
              }

              if (Date.now() - startedAt > 8000) {
                window.clearInterval(timer);
                reject(new Error("Google Places sa nenačítal."));
              }
            }, 120);
          });

        const setupLocationAutocomplete = async () => {
          if (
            funnelForm.dataset.googlePlacesKey !== "true" ||
            !(locationInput instanceof HTMLInputElement)
          ) {
            return;
          }

          try {
            await waitForGooglePlaces();
            const autocomplete = new window.google.maps.places.Autocomplete(locationInput, {
              componentRestrictions: { country: "sk" },
              fields: ["formatted_address", "geometry", "name", "place_id"],
              types: ["geocode"],
            });

            locationInput.dataset.googleEnforced = "true";
            locationInput.classList.add("has-google-autocomplete");
            setLocationHint("Vyberte adresu z Google návrhov, aby bola lokalita overená.");

            autocomplete.addListener("place_changed", () => {
              const place = autocomplete.getPlace();

              if (!place?.place_id || !place.formatted_address) {
                clearLocationVerification();
                setLocationHint("Vyberte prosím konkrétnu adresu z Google návrhov.");
                return;
              }

              const location = place.geometry?.location;
              const latitude = typeof location?.lat === "function" ? location.lat() : "";
              const longitude = typeof location?.lng === "function" ? location.lng() : "";

              locationInput.value = place.formatted_address;
              locationInput.dataset.selectedLocation = place.formatted_address;

              if (locationPlaceId instanceof HTMLInputElement) locationPlaceId.value = place.place_id;
              if (locationLat instanceof HTMLInputElement) locationLat.value = latitude ? String(latitude) : "";
              if (locationLng instanceof HTMLInputElement) locationLng.value = longitude ? String(longitude) : "";
              if (locationVerified instanceof HTMLInputElement) locationVerified.value = "true";
              if (locationField instanceof HTMLElement) locationField.classList.add("is-verified");

              setLocationHint("Overená adresa z Google.");
              updateFunnelSummary();
              setFunnelError();
            });
          } catch {
            if (locationInput instanceof HTMLInputElement) locationInput.dataset.googleEnforced = "false";
            setLocationHint("Google overenie adresy sa nenačítalo. Lokalitu môžete dopísať ručne.");
          }
        };

        const updateFunnelSummary = () => {
          if (!funnelSummary) return;

          const items = [
            funnelValue("zamer"),
            funnelValue("typ_detail") || funnelValue("typ"),
            funnelValue("lokalita"),
            funnelValue("datum") && funnelValue("cas") ? `${funnelValue("datum")} o ${funnelValue("cas")}` : "",
          ].filter(Boolean);

          funnelSummary.textContent = items.length > 0 ? `Zatiaľ vybrané: ${items.join(" | ")}` : "";
        };

        const setFunnelStep = (step) => {
          activeStep = Math.max(0, Math.min(step, funnelSteps.length - 1));

          funnelSteps.forEach((panel, index) => {
            panel.toggleAttribute("hidden", index !== activeStep);
          });

          if (progressText) progressText.textContent = `${activeStep + 1} / ${funnelSteps.length}`;
          if (progressBar instanceof HTMLElement) progressBar.style.width = `${((activeStep + 1) / funnelSteps.length) * 100}%`;
          if (funnelPrev instanceof HTMLButtonElement) funnelPrev.disabled = activeStep === 0;
          if (funnelNext instanceof HTMLButtonElement) funnelNext.hidden = activeStep === funnelSteps.length - 1;
          if (funnelSubmit instanceof HTMLButtonElement) funnelSubmit.hidden = activeStep !== funnelSteps.length - 1;
          setFunnelError();
          updateFunnelSummary();
        };

        const validateFunnelStep = (step) => {
          const panel = funnelSteps[step];
          const requiredFields = Array.from(panel.querySelectorAll("[data-required]"));

          for (const field of requiredFields) {
            if (
              (field instanceof HTMLInputElement ||
                field instanceof HTMLTextAreaElement ||
                field instanceof HTMLSelectElement) &&
              !field.value.trim()
            ) {
              setFunnelError(`Doplňte prosím ${field.dataset.label || "povinné pole"}.`);

              if (field.type !== "hidden") {
                field.focus();
              }

              return false;
            }

            if (
              field instanceof HTMLInputElement &&
              field.dataset.locationInput !== undefined &&
              field.dataset.googleEnforced === "true" &&
              locationVerified instanceof HTMLInputElement &&
              locationVerified.value !== "true"
            ) {
              setFunnelError("Vyberte prosím lokalitu z Google návrhov.");
              field.focus();
              return false;
            }
          }

          setFunnelError();
          return true;
        };

        funnelForm.querySelectorAll("[data-choice]").forEach((button) => {
          button.addEventListener("click", () => {
            if (!(button instanceof HTMLButtonElement)) return;

            const name = button.dataset.choice;
            const value = button.dataset.value || button.textContent?.trim() || "";
            if (!name) return;

            const field = funnelForm.elements.namedItem(name);
            if (field instanceof HTMLInputElement) field.value = value;

            funnelForm.querySelectorAll(`[data-choice="${name}"]`).forEach((item) => {
              item.classList.toggle("is-selected", item === button);
              item.setAttribute("aria-pressed", item === button ? "true" : "false");
            });

            applyIntentRoute();
            updateFunnelSummary();
            setFunnelError();
          });
        });

        locationInput?.addEventListener("input", () => {
          if (!(locationInput instanceof HTMLInputElement)) return;

          if (locationInput.value !== locationInput.dataset.selectedLocation) {
            clearLocationVerification();
            if (locationInput.dataset.googleEnforced === "true") {
              setLocationHint("Vyberte adresu z Google návrhov, aby bola lokalita overená.");
            }
          }
        });

        funnelForm.addEventListener("input", updateFunnelSummary);

        funnelPrev?.addEventListener("click", () => setFunnelStep(activeStep - 1));
        funnelNext?.addEventListener("click", () => {
          if (validateFunnelStep(activeStep)) setFunnelStep(activeStep + 1);
        });

        funnelForm.addEventListener("submit", (event) => {
          event.preventDefault();

          for (let index = 0; index < funnelSteps.length; index += 1) {
            if (!validateFunnelStep(index)) {
              setFunnelStep(index);
              return;
            }
          }

          const targetEmail = funnelForm.getAttribute("data-email");
          if (!targetEmail) return;

          const subjectName = funnelValue("meno") || "nový kontakt";
          const intentName = funnelValue("zamer") || "rezervácia konzultácie";
          const route = currentRoute();
          const parameterLines = routeParameterLines();
          const body = [
            route.leadTitle,
            "",
            `Meno: ${funnelValue("meno")}`,
            `Telefón: ${funnelValue("telefon")}`,
            `Email: ${funnelValue("email") || "-"}`,
            `Zámer: ${intentName}`,
            `Typ nehnuteľnosti / vetva: ${funnelValue("typ") || "-"}`,
            `Lokalita: ${funnelValue("lokalita")}`,
            `Lokalita overená Google: ${funnelValue("lokalita_overena") === "true" ? "áno" : "nie"}`,
            `Google Place ID: ${funnelValue("lokalita_place_id") || "-"}`,
            `GPS: ${
              funnelValue("lokalita_lat") && funnelValue("lokalita_lng")
                ? `${funnelValue("lokalita_lat")}, ${funnelValue("lokalita_lng")}`
                : "-"
            }`,
            "",
            "Parametre:",
            ...(parameterLines.length > 0 ? parameterLines : ["-"]),
            "",
            `Preferovaný dátum: ${funnelValue("datum")}`,
            `Preferovaný čas: ${funnelValue("cas")}`,
            `Časový horizont: ${funnelValue("horizont") || "-"}`,
            "",
            "Čo je dôležité:",
            funnelValue("sprava") || "-",
            "",
            "Poznámka: termín je predbežný, kým nebude web napojený na kalendár.",
          ].join("\n");

          window.location.href = `mailto:${encodeURIComponent(targetEmail)}?subject=${encodeURIComponent(
            `${route.subjectPrefix} - ${subjectName} - ${intentName}`,
          )}&body=${encodeURIComponent(body)}`;
        });

        setupLocationAutocomplete();
        applyIntentRoute();
        setFunnelStep(0);
      }
    </script>

    <style>
      :root {
        --paper: #f6f1e8;
        --ink: #0b0b0a;
        --muted: #726b61;
        --wine: #9a5c32;
        --brass: #d8b878;
        --white: #fffaf2;
        --line: rgba(255, 250, 242, 0.16);
        --font-body: "Instrument Sans", system-ui, sans-serif;
        --font-display: "Newsreader", Georgia, serif;
      }

      * {
        box-sizing: border-box;
      }

      html {
        min-height: 100%;
        background: var(--ink);
      }

      body {
        display: flex;
        min-height: 100%;
        flex-direction: column;
        margin: 0;
        background:
          linear-gradient(120deg, rgba(11, 11, 10, 0.97), rgba(27, 27, 25, 0.93)),
          var(--ink);
        color: var(--white);
        font-family: var(--font-body);
        line-height: 1.5;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        display: block;
        max-width: 100%;
      }

      .staging-ribbon {
        position: fixed;
        right: 18px;
        bottom: 18px;
        z-index: 20;
        border: 1px solid rgba(11, 11, 10, 0.16);
        border-radius: 999px;
        padding: 8px 12px;
        background: #f3cf74;
        color: var(--ink);
        box-shadow: 0 12px 30px rgba(11, 11, 10, 0.22);
        font-size: 12px;
        font-weight: 900;
      }

      .wizard-header {
        display: flex;
        width: min(1180px, calc(100% - 36px));
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        margin: 0 auto;
        padding: 22px 0;
      }

      .brand {
        display: flex;
        min-width: 0;
        align-items: center;
        gap: 12px;
      }

      .brand img {
        width: 112px;
        height: 42px;
        object-fit: contain;
      }

      .brand span {
        display: grid;
      }

      .brand strong {
        font-family: var(--font-display);
        font-size: 24px;
        line-height: 1;
      }

      .brand small {
        color: rgba(255, 250, 242, 0.68);
      }

      .back-link {
        border: 1px solid rgba(255, 250, 242, 0.22);
        border-radius: 6px;
        padding: 10px 13px;
        color: rgba(255, 250, 242, 0.82);
        font-size: 14px;
        font-weight: 800;
      }

      .wizard-shell {
        display: grid;
        width: min(1380px, calc(100% - 36px));
        flex: 1;
        gap: 34px;
        margin: 0 auto;
        padding: 42px 0 70px;
      }

      .wizard-copy {
        display: grid;
        width: min(980px, 100%);
        justify-self: center;
        gap: 16px;
        text-align: center;
      }

      .eyebrow {
        margin: 0;
        color: var(--brass);
        font-size: 14px;
        font-weight: 800;
      }

      h1,
      h2,
      p {
        margin-top: 0;
      }

      h1,
      h2 {
        font-family: var(--font-display);
        font-weight: 650;
        line-height: 0.98;
      }

      h1 {
        max-width: 980px;
        margin-bottom: 0;
        font-size: clamp(52px, 6vw, 82px);
      }

      h2 {
        margin-bottom: 0;
        font-size: clamp(34px, 4vw, 54px);
      }

      .wizard-copy > p,
      .wizard-step > p:not(.step-kicker) {
        margin: 0;
        color: rgba(255, 250, 242, 0.72);
        font-size: 18px;
      }

      .wizard-copy > p {
        max-width: 760px;
        justify-self: center;
      }

      .wizard-card {
        display: grid;
        gap: 18px;
        width: 100%;
        border: 1px solid rgba(255, 250, 242, 0.18);
        border-radius: 8px;
        padding: clamp(22px, 4vw, 38px);
        background: rgba(255, 250, 242, 0.08);
        box-shadow: 0 24px 70px rgba(0, 0, 0, 0.24);
      }

      .wizard-progress {
        display: grid;
        gap: 10px;
      }

      .wizard-progress span,
      .step-kicker {
        color: var(--brass);
        font-size: 13px;
        font-weight: 900;
      }

      .wizard-progress div {
        height: 8px;
        overflow: hidden;
        border-radius: 999px;
        background: rgba(255, 250, 242, 0.12);
      }

      .wizard-progress i {
        display: block;
        width: 25%;
        height: 100%;
        border-radius: inherit;
        background: var(--brass);
        transition: width 180ms ease;
      }

      .wizard-error {
        min-height: 22px;
        margin: 0;
        color: #ffd38c;
        font-size: 14px;
        font-weight: 800;
      }

      .wizard-step {
        display: grid;
        width: 100%;
        gap: 16px;
      }

      .wizard-step[hidden] {
        display: none;
      }

      .step-kicker {
        margin: 0;
      }

      .choice-grid,
      .slot-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
      }

      .choice-grid.compact {
        grid-template-columns: repeat(5, minmax(0, 1fr));
      }

      .choice-button,
      .slot-button {
        min-height: 54px;
        border: 1px solid rgba(255, 250, 242, 0.18);
        border-radius: 8px;
        padding: 12px 14px;
        background: rgba(11, 11, 10, 0.24);
        color: rgba(255, 250, 242, 0.86);
        cursor: pointer;
        font: inherit;
        font-weight: 800;
        line-height: 1.18;
        text-align: left;
        transition: background 160ms ease, border-color 160ms ease, color 160ms ease, transform 160ms ease;
      }

      .slot-button {
        display: grid;
        min-height: 58px;
        place-items: center;
        text-align: center;
        font-size: 19px;
      }

      .choice-button:hover,
      .slot-button:hover,
      .choice-button.is-selected,
      .slot-button.is-selected {
        border-color: rgba(216, 184, 120, 0.78);
        background: rgba(216, 184, 120, 0.16);
        color: var(--white);
        transform: translateY(-1px);
      }

      .wizard-fields {
        display: grid;
        gap: 12px;
      }

      .wizard-fields.two {
        grid-template-columns: repeat(4, minmax(0, 1fr));
      }

      .wizard-fields label {
        display: grid;
        gap: 7px;
      }

      .wizard-fields [data-param-field][hidden] {
        display: none;
      }

      .wizard-fields .location-field {
        grid-column: span 2;
      }

      .wizard-fields label.full {
        grid-column: 1 / -1;
      }

      .wizard-fields span {
        color: rgba(255, 250, 242, 0.64);
        font-size: 12px;
        font-weight: 850;
      }

      .wizard-fields input,
      .wizard-fields select,
      .wizard-fields textarea {
        width: 100%;
        border: 1px solid rgba(255, 250, 242, 0.16);
        border-radius: 6px;
        background: rgba(11, 11, 10, 0.28);
        color: var(--white);
        color-scheme: dark;
        font: inherit;
      }

      .wizard-fields input,
      .wizard-fields select {
        min-height: 48px;
        padding: 0 13px;
      }

      .wizard-fields textarea {
        min-height: 118px;
        padding: 12px 13px;
        resize: vertical;
      }

      .wizard-fields input::placeholder,
      .wizard-fields textarea::placeholder {
        color: rgba(255, 250, 242, 0.36);
      }

      .field-note {
        color: rgba(255, 250, 242, 0.48);
        font-size: 12px;
        font-weight: 750;
        line-height: 1.35;
      }

      .location-field.is-verified input[data-location-input] {
        border-color: rgba(216, 184, 120, 0.72);
      }

      :global(.pac-container) {
        z-index: 10000;
        border: 1px solid rgba(11, 11, 10, 0.14);
        border-radius: 8px;
        margin-top: 6px;
        background: var(--white);
        box-shadow: 0 18px 44px rgba(0, 0, 0, 0.24);
        font-family: var(--font-body);
      }

      :global(.pac-item) {
        padding: 9px 12px;
        cursor: pointer;
      }

      :global(.pac-item-query) {
        color: var(--ink);
        font-size: 14px;
      }

      .wizard-fields input:focus,
      .wizard-fields select:focus,
      .wizard-fields textarea:focus,
      .choice-button:focus-visible,
      .slot-button:focus-visible,
      .button:focus-visible,
      .back-link:focus-visible {
        border-color: rgba(216, 184, 120, 0.72);
        outline: 2px solid var(--brass);
        outline-offset: 3px;
      }

      .wizard-summary {
        min-height: 24px;
        color: rgba(255, 250, 242, 0.66);
        font-size: 13px;
        font-weight: 750;
      }

      .wizard-actions {
        display: flex;
        gap: 10px;
        justify-content: space-between;
      }

      .button {
        appearance: none;
        -webkit-appearance: none;
        display: inline-flex;
        min-height: 50px;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(255, 250, 242, 0.26);
        border-radius: 6px;
        padding: 0 20px;
        color: var(--white);
        cursor: pointer;
        font: inherit;
        font-weight: 800;
        transition: transform 160ms ease, background 160ms ease, color 160ms ease;
      }

      .button[hidden] {
        display: none;
      }

      .button:hover {
        transform: translateY(-2px);
      }

      .button.primary {
        border-color: var(--brass);
        background: var(--brass);
        color: var(--ink);
      }

      .button.secondary {
        border-color: rgba(255, 250, 242, 0.18);
        background: rgba(255, 250, 242, 0.1);
        color: rgba(255, 250, 242, 0.78);
        -webkit-text-fill-color: rgba(255, 250, 242, 0.78);
      }

      .button.secondary:hover {
        border-color: rgba(255, 250, 242, 0.26);
        background: rgba(255, 250, 242, 0.14);
        color: rgba(255, 250, 242, 0.9);
        -webkit-text-fill-color: rgba(255, 250, 242, 0.9);
      }

      .button:disabled {
        border-color: rgba(255, 250, 242, 0.12);
        background: rgba(255, 250, 242, 0.08);
        color: rgba(255, 250, 242, 0.42);
        -webkit-text-fill-color: rgba(255, 250, 242, 0.42);
        cursor: not-allowed;
        transform: none;
      }

      .button.secondary:disabled {
        border-color: rgba(255, 250, 242, 0.12);
        background-color: rgba(255, 250, 242, 0.08);
        color: rgba(255, 250, 242, 0.42);
        -webkit-text-fill-color: rgba(255, 250, 242, 0.42);
      }

      .wizard-actions .button:disabled {
        border-color: rgba(255, 250, 242, 0.12) !important;
        background: rgba(255, 250, 242, 0.08) !important;
        background-color: rgba(255, 250, 242, 0.08) !important;
        color: rgba(255, 250, 242, 0.42) !important;
        -webkit-text-fill-color: rgba(255, 250, 242, 0.42) !important;
      }

      .button:disabled:hover {
        transform: none;
      }

      .wizard-footer {
        display: flex;
        width: min(1380px, calc(100% - 36px));
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        margin: 0 auto;
        border-top: 1px solid rgba(255, 250, 242, 0.14);
        padding: 24px 0 28px;
        color: rgba(255, 250, 242, 0.72);
      }

      .footer-brand {
        display: flex;
        min-width: 0;
        align-items: center;
        gap: 12px;
      }

      .footer-brand img {
        width: 96px;
        height: 38px;
        object-fit: contain;
      }

      .footer-brand p {
        margin: 0;
        color: var(--white);
        font-family: var(--font-display);
        font-size: 22px;
        font-weight: 650;
      }

      .wizard-footer nav {
        display: flex;
        flex-wrap: wrap;
        gap: 12px 18px;
        justify-content: flex-end;
        font-size: 14px;
        font-weight: 750;
      }

      .wizard-footer a {
        text-decoration-line: underline;
        text-decoration-color: transparent;
        text-decoration-thickness: 1px;
        text-underline-offset: 5px;
        transition: color 160ms ease, text-decoration-color 160ms ease;
      }

      .wizard-footer a:hover {
        color: var(--brass);
        text-decoration-color: currentColor;
      }

      @media (max-width: 980px) {
        .wizard-shell {
          width: min(760px, calc(100% - 36px));
        }

        .wizard-copy > p {
          max-width: none;
        }

        .choice-grid,
        .choice-grid.compact,
        .wizard-fields.two {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .wizard-fields .location-field {
          grid-column: 1 / -1;
        }

        .wizard-footer {
          width: min(760px, calc(100% - 36px));
          align-items: flex-start;
          flex-direction: column;
        }

        .wizard-footer nav {
          justify-content: flex-start;
        }
      }

      @media (max-width: 620px) {
        .wizard-header,
        .wizard-shell,
        .wizard-footer {
          width: calc(100% - 36px);
        }

        .brand span {
          display: none;
        }

        .brand img {
          width: 86px;
        }

        h1 {
          font-size: 42px;
        }

        h2 {
          font-size: 32px;
        }

        .wizard-shell {
          padding-top: 28px;
          padding-bottom: 52px;
        }

        .choice-grid,
        .choice-grid.compact,
        .slot-grid,
        .wizard-fields.two {
          grid-template-columns: 1fr;
        }

        .wizard-fields .location-field {
          grid-column: auto;
        }

        .wizard-actions {
          display: grid;
        }

        .button {
          width: 100%;
        }

        .wizard-footer nav {
          display: grid;
          gap: 8px;
        }
      }
