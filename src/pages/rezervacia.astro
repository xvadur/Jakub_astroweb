---
import AnalyticsConsent from "../components/AnalyticsConsent.astro";
import { site } from "../data/site";

const siteEnv = import.meta.env.PUBLIC_SITE_ENV ?? "production";
const isStaging = siteEnv !== "production";
const canonicalUrl = new URL("/rezervacia/", site.siteUrl).toString();
const hasInstagram = site.contact.instagram.startsWith("http");
const googleMapsApiKey = import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY?.trim() ?? "";
const googleMapsScriptUrl = googleMapsApiKey
  ? `https://maps.googleapis.com/maps/api/js?key=${encodeURIComponent(
      googleMapsApiKey,
    )}&libraries=places&v=weekly&language=sk&region=SK&loading=async`
  : "";
---

<!doctype html>
<html lang="sk">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="icon" type="image/png" href="/favicon.png?v=2" />
    <link rel="icon" href="/favicon.ico?v=2" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content={`Rezervácia konzultácie s realitným maklérom Jakubom Olšom. ${site.shortPromise}`}
    />
    <meta property="og:title" content={`Rezervácia konzultácie | ${site.brand}`} />
    <meta
      property="og:description"
      content={`Rezervácia konzultácie s realitným maklérom Jakubom Olšom. ${site.shortPromise}`}
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={site.heroImage} />
    <link rel="canonical" href={canonicalUrl} />
    {isStaging ? <meta name="robots" content="noindex,nofollow,noarchive" /> : null}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700;800&family=Newsreader:opsz,wght@6..72,500;6..72,650;6..72,700&display=swap"
      rel="stylesheet"
    />
    {googleMapsScriptUrl ? <script is:inline async defer src={googleMapsScriptUrl}></script> : null}
    <title>Rezervácia konzultácie | {site.brand}</title>
  </head>
  <body>
    {isStaging ? <div class="staging-ribbon" aria-hidden="true">STAGING</div> : null}

    <header class="wizard-header">
      <div class="brand-cluster">
        <a class="brand" href="/" aria-label={`${site.brand}, späť na úvod`}>
          <img src={site.logoImage} alt="" />
          <span>
            <strong>{site.brand}</strong>
            <small>{site.role}</small>
          </span>
        </a>
        <span class="brand-divider" aria-hidden="true"></span>
        <img class="bosen-logo header-bosen-logo" src={site.bosenGroupLogo} alt="BOSEN Group" />
      </div>
      <a class="back-link" href="/">Späť na úvod</a>
    </header>

    <main class="wizard-shell">
      <section class="wizard-copy" aria-labelledby="wizard-title">
        <p class="eyebrow">{site.bookingFunnel.eyebrow}</p>
        <h1 id="wizard-title">{site.bookingFunnel.title}</h1>
        <p>{site.bookingFunnel.text}</p>
      </section>

      <form
        class="wizard-card"
        data-funnel-form
        data-email={site.contact.email}
        data-booking-endpoint="/api/book"
        data-availability-endpoint="/api/availability"
        data-google-places-key={googleMapsApiKey ? "true" : "false"}
      >
        <p class="wizard-error" data-funnel-error aria-live="polite"></p>
        <label class="hp-field" aria-hidden="true" tabindex="-1">
          <span>Website</span>
          <input name="website" autocomplete="off" tabindex="-1" />
        </label>

        <section class="wizard-step" data-funnel-step>
          <p class="step-kicker">Krok 1</p>
          <h2>Typ požiadavky</h2>
          <input type="hidden" name="zamer" data-required data-label="zámer" />
          <div class="choice-grid">
            {
              site.bookingFunnel.intents.map((intent) => (
                <button type="button" class="choice-button" data-choice="zamer" data-value={intent} aria-pressed="false">
                  {intent}
                </button>
              ))
            }
          </div>
        </section>

        <section class="wizard-step" data-funnel-step hidden>
          <p class="step-kicker">Krok 2</p>
          <h2 data-route-title="property">Základné informácie o nehnuteľnosti</h2>
          <input type="hidden" name="typ" data-route-type />
          <div class="wizard-fields two">
            <label class="location-field" data-location-field>
              <span>Lokalita</span>
              <input
                name="lokalita"
                placeholder="Mesto, časť alebo ulica"
                autocomplete="off"
                data-required
                data-label="lokalita"
                data-location-input
              />
              <input type="hidden" name="lokalita_place_id" data-location-place-id />
              <input type="hidden" name="lokalita_lat" data-location-lat />
              <input type="hidden" name="lokalita_lng" data-location-lng />
              <input type="hidden" name="lokalita_overena" data-location-verified />
            </label>
            <label data-param-field="property_kind">
              <span>Typ nehnuteľnosti</span>
              <select name="typ_detail">
                <option value="">Vyberte typ</option>
                <option value="Byt">Byt</option>
                <option value="Dom">Dom</option>
                <option value="Pozemok">Pozemok</option>
                <option value="Komerčný priestor">Komerčný priestor</option>
                <option value="Investičná nehnuteľnosť">Investičná nehnuteľnosť</option>
              </select>
            </label>
            <label data-param-field="commercial_type">
              <span>Typ priestoru</span>
              <select name="typ_komercneho_priestoru">
                <option value="">Vyberte typ</option>
                <option value="Kancelárie">Kancelárie</option>
                <option value="Obchod">Obchod</option>
                <option value="Sklad / hala">Sklad / hala</option>
                <option value="Gastro">Gastro</option>
                <option value="Polyfunkčný objekt">Polyfunkčný objekt</option>
                <option value="Iné">Iné</option>
              </select>
            </label>
            <label data-param-field="rooms">
              <span>Izby</span>
              <input name="izby" placeholder="napr. 4 izby" />
            </label>
            <label data-param-field="area">
              <span>Výmera</span>
              <input name="vymera" placeholder="napr. 156 m²" />
            </label>
            <label data-param-field="floor">
              <span>Poschodie</span>
              <input name="poschodie" placeholder="napr. 3/6" />
            </label>
            <label data-param-field="house_area">
              <span>Úžitková plocha</span>
              <input name="uzitkova_plocha" placeholder="napr. 180 m²" />
            </label>
            <label data-param-field="land_area">
              <span>Výmera pozemku</span>
              <input name="vymera_pozemku" placeholder="napr. 620 m²" />
            </label>
            <label data-param-field="year">
              <span>Rok výstavby / rekonštrukcie</span>
              <input name="rok_vystavby_rekonstrukcie" placeholder="napr. 2008 / rekonštrukcia 2021" />
            </label>
            <label data-param-field="condition">
              <span>Stav</span>
              <select name="stav">
                <option value="">Vyberte stav</option>
                <option value="Pôvodný stav">Pôvodný stav</option>
                <option value="Udržiavaný stav">Udržiavaný stav</option>
                <option value="Čiastočná rekonštrukcia">Čiastočná rekonštrukcia</option>
                <option value="Kompletná rekonštrukcia">Kompletná rekonštrukcia</option>
                <option value="Novostavba">Novostavba</option>
                <option value="Vo výstavbe / na dokončenie">Vo výstavbe / na dokončenie</option>
              </select>
            </label>
            <label data-param-field="extras">
              <span data-route-field-label="extras">Výhody nehnuteľnosti</span>
              <input name="doplnky" placeholder="loggia/balkón, terasa, pivnica, parkovanie..." />
            </label>
            <label data-param-field="land_type">
              <span>Typ pozemku</span>
              <select name="typ_pozemku">
                <option value="">Vyberte typ</option>
                <option value="Stavebný pozemok">Stavebný pozemok</option>
                <option value="Záhrada">Záhrada</option>
                <option value="Rekreačný pozemok">Rekreačný pozemok</option>
                <option value="Orná pôda">Orná pôda</option>
                <option value="Iné">Iné</option>
              </select>
            </label>
            <label data-param-field="land_use">
              <span>Územný plán / využitie</span>
              <input name="uzemny_plan_vyuzitie" placeholder="napr. bývanie, rekreácia, komercia, neviem" />
            </label>
            <label data-param-field="utilities">
              <span>Siete</span>
              <input name="siete" placeholder="voda, elektrina, plyn, kanalizácia" />
            </label>
            <label data-param-field="access">
              <span>Prístup</span>
              <input name="pristup" placeholder="asfaltová cesta, podiel, vecné bremeno..." />
            </label>
            <label data-param-field="occupancy">
              <span>Obsadenosť</span>
              <input name="obsadenost" placeholder="voľné, nájomca, vlastné užívanie" />
            </label>
            <label data-param-field="rent_target">
              <span>Očakávaný nájom</span>
              <input name="ocakavany_najom" placeholder="napr. 950 € / mesiac" />
            </label>
            <label data-param-field="available_from">
              <span>Dostupné od</span>
              <input name="dostupne_od" placeholder="napr. ihneď, od septembra" />
            </label>
            <label data-param-field="management_scope">
              <span>Rozsah správy</span>
              <input name="rozsah_spravy" placeholder="iba nájomca, správa, servis, vyúčtovania" />
            </label>
          </div>
        </section>

        <section class="wizard-step" data-funnel-step hidden>
          <p class="step-kicker">Krok 3</p>
          <h2 data-route-title="date">Termín hovoru</h2>
          <div class="wizard-fields">
            <label>
              <span>Preferovaný dátum</span>
              <input name="datum" type="date" data-funnel-date data-required data-label="dátum hovoru" />
            </label>
          </div>
          <input type="hidden" name="cas" data-required data-label="čas hovoru" />
          <div class="slot-grid" aria-label="Preferovaný čas hovoru">
            {
              site.bookingFunnel.timeSlots.map((slot) => (
                <button type="button" class="slot-button" data-choice="cas" data-value={slot} aria-pressed="false">
                  {slot}
                </button>
              ))
            }
          </div>
          <p class="slot-status" data-slot-status aria-live="polite"></p>
        </section>

        <section class="wizard-step" data-funnel-step hidden>
          <p class="step-kicker">Krok 4</p>
          <h2 data-route-title="contact">Kontaktné údaje</h2>
          <div class="wizard-fields two">
            <label>
              <span>Meno</span>
              <input name="meno" autocomplete="name" data-required data-label="meno" />
            </label>
            <label>
              <span>Telefón</span>
              <input name="telefon" type="tel" autocomplete="tel" data-required data-label="telefón" />
            </label>
            <label>
              <span>Email</span>
              <input name="email" type="email" autocomplete="email" />
            </label>
            <label>
              <span>Časový horizont</span>
              <select name="horizont">
                <option value="">Vyberte horizont</option>
                <option value="Ihneď">Ihneď</option>
                <option value="1-3 mesiace">1-3 mesiace</option>
                <option value="3-6 mesiacov">3-6 mesiacov</option>
                <option value="Zatiaľ len zisťujem možnosti">Zatiaľ len zisťujem možnosti</option>
              </select>
            </label>
            <label class="full">
              <span>Čo je pre vás dôležité?</span>
              <textarea
                name="sprava"
                rows="4"
                placeholder="Cena, rýchlosť, diskrétnosť, kúpa nového bývania, investícia..."
                data-route-placeholder="message"
              ></textarea>
            </label>
            <label class="consent-field full">
              <input
                name="gdpr_suhlas"
                type="checkbox"
                value="ano"
                data-required
                data-label="súhlas so spracovaním údajov"
              />
              <span>
                Súhlasím so spracovaním údajov za účelom kontaktovania a rezervácie konzultácie.
                <a href="/ochrana-osobnych-udajov/" target="_blank" rel="noreferrer">Ochrana údajov</a>
              </span>
            </label>
          </div>
        </section>

        <section class="booking-confirmation" data-booking-confirmation hidden>
          <p class="step-kicker">Odoslané</p>
          <h2>Rezervácia je odoslaná.</h2>
          <p data-booking-confirmation-text>
            Ďakujem, mám podklady k hovoru a ozvem sa v zvolenom termíne.
          </p>
          <a class="button secondary" href="/">Späť na úvod</a>
        </section>

        <div class="wizard-summary" data-funnel-summary aria-live="polite"></div>

        <div class="wizard-actions">
          <button type="button" class="button secondary" data-funnel-prev>Späť</button>
          <button type="button" class="button primary" data-funnel-next>Pokračovať</button>
          <button type="submit" class="button primary" data-funnel-submit hidden>Odoslať a rezervovať</button>
        </div>

        <div class="wizard-progress" aria-label="Postup rezervácie">
          <span data-funnel-progress>1 / 4</span>
          <div aria-hidden="true">
            <i data-funnel-bar></i>
          </div>
        </div>
      </form>
    </main>

    <footer class="wizard-footer">
      <div class="footer-brand">
        <img src={site.logoImage} alt="" />
        <img class="bosen-logo footer-bosen-logo" src={site.bosenGroupLogo} alt="BOSEN Group" />
        {
          hasInstagram ? (
            <a
              class="social-icon"
              href={site.contact.instagram}
              target="_blank"
              rel="noreferrer"
              aria-label={site.contact.instagramLabel}
              title={site.contact.instagramLabel}
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="5" />
                <circle cx="12" cy="12" r="4" />
                <circle cx="17.5" cy="6.5" r="1.2" />
              </svg>
            </a>
          ) : (
            <span
              class="social-icon is-disabled"
              aria-label="Instagram doplniť pred spustením"
              title="Instagram doplniť pred spustením"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="5" />
                <circle cx="12" cy="12" r="4" />
                <circle cx="17.5" cy="6.5" r="1.2" />
              </svg>
            </span>
          )
        }
        <p>{site.brand}</p>
      </div>
      <p>{site.shortPromise}</p>
      <div class="footer-links">
        <a href="/#ponuky">Pozrieť ponuky</a>
        <a href="/ochrana-osobnych-udajov/">Ochrana údajov a cookies</a>
      </div>
    </footer>

    <script>
      const funnelForm = document.querySelector("[data-funnel-form]");

      if (funnelForm instanceof HTMLFormElement) {
        const funnelSteps = Array.from(funnelForm.querySelectorAll("[data-funnel-step]"));
        const progressText = funnelForm.querySelector("[data-funnel-progress]");
        const progressBar = funnelForm.querySelector("[data-funnel-bar]");
        const funnelError = funnelForm.querySelector("[data-funnel-error]");
        const funnelPrev = funnelForm.querySelector("[data-funnel-prev]");
        const funnelNext = funnelForm.querySelector("[data-funnel-next]");
        const funnelSubmit = funnelForm.querySelector("[data-funnel-submit]");
        const funnelSummary = funnelForm.querySelector("[data-funnel-summary]");
        const wizardActions = funnelForm.querySelector(".wizard-actions");
        const wizardProgress = funnelForm.querySelector(".wizard-progress");
        const dateInput = funnelForm.querySelector("[data-funnel-date]");
        const slotStatus = funnelForm.querySelector("[data-slot-status]");
        const slotButtons = Array.from(funnelForm.querySelectorAll(".slot-button"));
        const bookingConfirmation = funnelForm.querySelector("[data-booking-confirmation]");
        const bookingConfirmationText = funnelForm.querySelector("[data-booking-confirmation-text]");
        const locationField = funnelForm.querySelector("[data-location-field]");
        const locationInput = funnelForm.querySelector("[data-location-input]");
        const locationPlaceId = funnelForm.querySelector("[data-location-place-id]");
        const locationLat = funnelForm.querySelector("[data-location-lat]");
        const locationLng = funnelForm.querySelector("[data-location-lng]");
        const locationVerified = funnelForm.querySelector("[data-location-verified]");
        const routeTypeField = funnelForm.querySelector("[data-route-type]");
        const paramFields = Array.from(funnelForm.querySelectorAll("[data-param-field]"));
        const routeTitles = {
          property: funnelForm.querySelector('[data-route-title="property"]'),
          date: funnelForm.querySelector('[data-route-title="date"]'),
          contact: funnelForm.querySelector('[data-route-title="contact"]'),
        };
        const routeTexts = {
          property: funnelForm.querySelector('[data-route-text="property"]'),
          date: funnelForm.querySelector('[data-route-text="date"]'),
          contact: funnelForm.querySelector('[data-route-text="contact"]'),
        };
        const routePlaceholders = {
          message: funnelForm.querySelector('[data-route-placeholder="message"]'),
        };
        let activeStep = 0;
        let availabilityController;
        let isSubmitting = false;
        const funnelStepNames = ["intent", "property", "date", "contact"];

        const trackFunnelEvent = (name, detail = {}) => {
          const payload = {
            event: `booking_${name}`,
            page_path: window.location.pathname,
            ...detail,
          };

          try {
            if (typeof window.jakubTrackEvent === "function") {
              window.jakubTrackEvent(payload.event, payload);
            }
          } catch {
            // Analytics hooks must stay best-effort only.
          }

          try {
            window.dispatchEvent(new CustomEvent("booking:funnel", { detail: payload }));
          } catch {
            // Tracking must never block the reservation flow.
          }
        };

        const parameterLabels = {
          typ_detail: "Typ nehnuteľnosti",
          izby: "Izby",
          vymera: "Výmera",
          poschodie: "Poschodie",
          stav: "Stav",
          uzitkova_plocha: "Úžitková plocha",
          vymera_pozemku: "Výmera pozemku",
          rok_vystavby_rekonstrukcie: "Rok výstavby / rekonštrukcie",
          typ_pozemku: "Typ pozemku",
          uzemny_plan_vyuzitie: "Územný plán / využitie",
          siete: "Siete",
          pristup: "Prístup",
          typ_komercneho_priestoru: "Typ priestoru",
          obsadenost: "Obsadenosť",
          ocakavany_najom: "Očakávaný nájom",
          dostupne_od: "Dostupné od",
          rozsah_spravy: "Rozsah správy",
        };

        const defaultRoute = {
          propertyType: "",
          paramFields: ["property_kind", "rooms", "area", "condition"],
          propertyTitle: "Základné informácie o nehnuteľnosti",
          propertyText: "",
          dateTitle: "Termín hovoru",
          dateText: "",
          contactTitle: "Kontaktné údaje",
          contactText: "",
          messagePlaceholder: "Doplňujúce informácie",
          leadTitle: "Konzultácia možností",
          subjectPrefix: "Konzultácia možností",
          submitLabel: "Odoslať rezerváciu",
        };

        const intentRoutes = {
          "Zistiť možnosti": defaultRoute,
          "Predať byt": {
            propertyType: "Byt",
            paramFields: ["rooms", "area", "floor", "condition", "extras"],
            fieldMeta: {
              extras: {
                label: "Výhody bytu",
                placeholder: "loggia/balkón, terasa, pivnica, parkovanie, výťah...",
              },
            },
            propertyTitle: "Základné informácie o byte",
            propertyText: "",
            dateTitle: "Termín hovoru",
            dateText: "",
            contactTitle: "Kontaktné údaje",
            contactText: "",
            messagePlaceholder: "Doplňujúce informácie",
            leadTitle: "Predaj bytu",
            subjectPrefix: "Predaj bytu",
            submitLabel: "Odoslať rezerváciu",
          },
          "Predať dom": {
            propertyType: "Dom",
            paramFields: ["rooms", "house_area", "land_area", "year", "condition", "extras"],
            fieldMeta: {
              extras: {
                label: "Výhody domu",
                placeholder: "garáž, terasa, záhrada, bazén, krb, pivnica...",
              },
            },
            propertyTitle: "Základné informácie o dome",
            propertyText: "",
            dateTitle: "Termín hovoru",
            dateText: "",
            contactTitle: "Kontaktné údaje",
            contactText: "",
            messagePlaceholder: "Doplňujúce informácie",
            leadTitle: "Predaj domu",
            subjectPrefix: "Predaj domu",
            submitLabel: "Odoslať rezerváciu",
          },
          "Predať pozemok": {
            propertyType: "Pozemok",
            paramFields: ["land_area", "land_type", "land_use", "utilities", "access"],
            propertyTitle: "Základné informácie o pozemku",
            propertyText: "",
            dateTitle: "Termín hovoru",
            dateText: "",
            contactTitle: "Kontaktné údaje",
            contactText: "",
            messagePlaceholder: "Doplňujúce informácie",
            leadTitle: "Predaj pozemku",
            subjectPrefix: "Predaj pozemku",
            submitLabel: "Odoslať rezerváciu",
          },
          "Predať komerčný priestor": {
            propertyType: "Komerčný priestor",
            paramFields: ["commercial_type", "area", "condition", "occupancy", "extras"],
            fieldMeta: {
              extras: {
                label: "Výhody priestoru",
                placeholder: "parkovanie, výklad, zásobovanie, terasa, technické zázemie...",
              },
            },
            propertyTitle: "Základné informácie o priestore",
            propertyText: "",
            dateTitle: "Termín hovoru",
            dateText: "",
            contactTitle: "Kontaktné údaje",
            contactText: "",
            messagePlaceholder: "Doplňujúce informácie",
            leadTitle: "Predaj komerčného priestoru",
            subjectPrefix: "Predaj komerčného priestoru",
            submitLabel: "Odoslať rezerváciu",
          },
          "Prenájom alebo správa": {
            propertyType: "Prenájom / správa",
            paramFields: ["property_kind", "rooms", "area", "condition", "rent_target", "available_from", "management_scope"],
            propertyTitle: "Základné informácie k prenájmu",
            propertyText: "",
            dateTitle: "Termín hovoru",
            dateText: "",
            contactTitle: "Kontaktné údaje",
            contactText: "",
            messagePlaceholder: "Doplňujúce informácie",
            leadTitle: "Prenájom alebo správa",
            subjectPrefix: "Prenájom alebo správa",
            submitLabel: "Odoslať rezerváciu",
          },
        };

        if (dateInput instanceof HTMLInputElement) {
          const now = new Date();
          const localDate = new Date(now.getTime() - now.getTimezoneOffset() * 60000).toISOString().slice(0, 10);
          dateInput.min = localDate;
          if (!dateInput.value) dateInput.value = localDate;
        }

        const funnelValue = (name) => {
          const field = funnelForm.elements.namedItem(name);

          if (field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement || field instanceof HTMLSelectElement) {
            return field.value.trim();
          }

          return "";
        };

        const setFunnelError = (message = "") => {
          if (funnelError) funnelError.textContent = message;
        };

        const currentRoute = () => intentRoutes[funnelValue("zamer")] || defaultRoute;

        const createLeadCorrelationId = () => {
          if (typeof window.jakubCreateCorrelationId === "function") return window.jakubCreateCorrelationId();
          if (window.crypto?.randomUUID) return window.crypto.randomUUID();
          return `lead_${Date.now().toString(36)}_${Math.random().toString(36).slice(2, 10)}`;
        };

        const defaultFieldMeta = {
          extras: {
            label: "Výhody nehnuteľnosti",
            placeholder: "loggia/balkón, terasa, pivnica, parkovanie...",
          },
        };

        const setParamFieldState = (field, isActive) => {
          if (!(field instanceof HTMLElement)) return;

          field.hidden = !isActive;
          field.querySelectorAll("input, select, textarea").forEach((control) => {
            if (
              control instanceof HTMLInputElement ||
              control instanceof HTMLTextAreaElement ||
              control instanceof HTMLSelectElement
            ) {
              control.disabled = !isActive;
              if (!isActive) control.value = "";
            }
          });
        };

        const routeParameterLines = () => {
          const route = currentRoute();

          return (route.paramFields || [])
            .map((fieldKey) => {
              const field = paramFields.find((item) => item instanceof HTMLElement && item.dataset.paramField === fieldKey);
              if (!(field instanceof HTMLElement)) return "";

              const control = field.querySelector("input, select, textarea");
              if (
                !(control instanceof HTMLInputElement) &&
                !(control instanceof HTMLTextAreaElement) &&
                !(control instanceof HTMLSelectElement)
              ) {
                return "";
              }

              const value = control.value.trim();
              if (!value) return "";

              const label = field.querySelector("span")?.textContent?.trim() || parameterLabels[control.name] || control.name;
              return `${label}: ${value}`;
            })
            .filter(Boolean);
        };

        const applyIntentRoute = () => {
          const route = currentRoute();
          const activeParamFields = new Set(route.paramFields || []);

          if (routeTypeField instanceof HTMLInputElement) {
            routeTypeField.value = funnelValue("zamer") ? route.propertyType || "" : "";
          }
          if (routeTitles.property) routeTitles.property.textContent = route.propertyTitle;
          if (routeTitles.date) routeTitles.date.textContent = route.dateTitle;
          if (routeTitles.contact) routeTitles.contact.textContent = route.contactTitle;
          if (routeTexts.property) routeTexts.property.textContent = route.propertyText;
          if (routeTexts.date) routeTexts.date.textContent = route.dateText;
          if (routeTexts.contact) routeTexts.contact.textContent = route.contactText;
          if (routePlaceholders.message instanceof HTMLTextAreaElement) {
            routePlaceholders.message.placeholder = route.messagePlaceholder;
          }
          if (funnelSubmit instanceof HTMLButtonElement) {
            funnelSubmit.textContent = route.submitLabel;
          }

          paramFields.forEach((field) => {
            const key = field instanceof HTMLElement ? field.dataset.paramField || "" : "";
            const fieldMeta = route.fieldMeta?.[key] || defaultFieldMeta[key];
            const fieldLabel = field instanceof HTMLElement ? field.querySelector("[data-route-field-label]") : null;
            const fieldControl = field instanceof HTMLElement ? field.querySelector("input, textarea") : null;

            if (fieldMeta?.label && fieldLabel) fieldLabel.textContent = fieldMeta.label;
            if (
              fieldMeta?.placeholder &&
              (fieldControl instanceof HTMLInputElement || fieldControl instanceof HTMLTextAreaElement)
            ) {
              fieldControl.placeholder = fieldMeta.placeholder;
            }

            setParamFieldState(field, activeParamFields.has(key));
          });
        };

        const clearLocationVerification = () => {
          if (locationPlaceId instanceof HTMLInputElement) locationPlaceId.value = "";
          if (locationLat instanceof HTMLInputElement) locationLat.value = "";
          if (locationLng instanceof HTMLInputElement) locationLng.value = "";
          if (locationVerified instanceof HTMLInputElement) locationVerified.value = "";
          if (locationField instanceof HTMLElement) locationField.classList.remove("is-verified");
        };

        const waitForGooglePlaces = () =>
          new Promise((resolve, reject) => {
            const startedAt = Date.now();
            const timer = window.setInterval(async () => {
              if (window.google?.maps?.importLibrary) {
                window.clearInterval(timer);
                await window.google.maps.importLibrary("places");
                resolve(window.google.maps.places);
                return;
              }

              if (Date.now() - startedAt > 8000) {
                window.clearInterval(timer);
                reject(new Error("Google Places sa nenačítal."));
              }
            }, 120);
          });

        const setupLocationAutocomplete = async () => {
          if (
            funnelForm.dataset.googlePlacesKey !== "true" ||
            !(locationInput instanceof HTMLInputElement)
          ) {
            return;
          }

          try {
            await waitForGooglePlaces();
            const autocomplete = new window.google.maps.places.Autocomplete(locationInput, {
              componentRestrictions: { country: "sk" },
              fields: ["formatted_address", "geometry", "name", "place_id"],
              types: ["geocode"],
            });

            locationInput.dataset.googleEnforced = "true";
            locationInput.classList.add("has-google-autocomplete");

            autocomplete.addListener("place_changed", () => {
              const place = autocomplete.getPlace();

              if (!place?.place_id || !place.formatted_address) {
                clearLocationVerification();
                return;
              }

              const location = place.geometry?.location;
              const latitude = typeof location?.lat === "function" ? location.lat() : "";
              const longitude = typeof location?.lng === "function" ? location.lng() : "";

              locationInput.value = place.formatted_address;
              locationInput.dataset.selectedLocation = place.formatted_address;

              if (locationPlaceId instanceof HTMLInputElement) locationPlaceId.value = place.place_id;
              if (locationLat instanceof HTMLInputElement) locationLat.value = latitude ? String(latitude) : "";
              if (locationLng instanceof HTMLInputElement) locationLng.value = longitude ? String(longitude) : "";
              if (locationVerified instanceof HTMLInputElement) locationVerified.value = "true";
              if (locationField instanceof HTMLElement) locationField.classList.add("is-verified");

              updateFunnelSummary();
              setFunnelError();
            });
          } catch {
            if (locationInput instanceof HTMLInputElement) locationInput.dataset.googleEnforced = "false";
          }
        };

        const updateFunnelSummary = () => {
          if (!funnelSummary) return;

          const items = [
            funnelValue("zamer"),
            funnelValue("typ_detail") || funnelValue("typ"),
            funnelValue("lokalita"),
            funnelValue("datum") && funnelValue("cas") ? `${funnelValue("datum")} o ${funnelValue("cas")}` : "",
          ].filter(Boolean);

          funnelSummary.textContent = items.length > 0 ? `Zatiaľ vybrané: ${items.join(" | ")}` : "";
        };

        const setSlotStatus = (message = "") => {
          if (slotStatus) slotStatus.textContent = message;
        };

        const selectedTimeField = () => funnelForm.elements.namedItem("cas");

        const clearSelectedTime = () => {
          const field = selectedTimeField();
          if (field instanceof HTMLInputElement) field.value = "";

          slotButtons.forEach((button) => {
            button.classList.remove("is-selected");
            button.setAttribute("aria-pressed", "false");
          });

          updateFunnelSummary();
        };

        const setSlotButtonsDisabled = (isDisabled) => {
          slotButtons.forEach((button) => {
            if (button instanceof HTMLButtonElement) {
              button.disabled = isDisabled;
              if (isDisabled) {
                button.hidden = false;
                button.classList.remove("is-unavailable");
                button.title = "";
              }
            }
          });
        };

        const applySlotAvailability = (slots = [], mode = "mock") => {
          const availableByTime = new Map(slots.map((slot) => [slot.time, slot]));
          let availableCount = 0;

          slotButtons.forEach((button) => {
            if (!(button instanceof HTMLButtonElement)) return;

            const slot = availableByTime.get(button.dataset.value || "");
            const isAvailable = slot ? slot.available : false;
            const isPast = slot?.reason === "past";
            button.disabled = !isAvailable;
            button.hidden = !isAvailable && !isPast;
            button.classList.toggle("is-unavailable", !isAvailable);
            button.title = !isAvailable ? (isPast ? "Tento čas už prešiel." : "Tento čas je obsadený.") : "";

            if (isAvailable) availableCount += 1;

            if (!isAvailable && button.classList.contains("is-selected")) {
              clearSelectedTime();
            }
          });

          if (availableCount === 0) {
            setSlotStatus("Na tento deň zatiaľ nie je dostupný žiadny čas. Skúste iný dátum.");
            return;
          }

          setSlotStatus(mode === "google" ? "Zobrazujem dostupné časy podľa kalendára." : "Vyberte čas, ktorý vám najviac sedí.");
        };

        const loadAvailability = async () => {
          if (!(dateInput instanceof HTMLInputElement) || !dateInput.value) return;

          if (availabilityController) availabilityController.abort();
          availabilityController = new AbortController();

          const endpoint = funnelForm.getAttribute("data-availability-endpoint") || "/api/availability";
          const url = `${endpoint}?date=${encodeURIComponent(dateInput.value)}`;

          setSlotStatus("Načítavam dostupné termíny...");
          setSlotButtonsDisabled(true);

          try {
            const response = await fetch(url, {
              headers: { Accept: "application/json" },
              signal: availabilityController.signal,
            });

            const data = await response.json();

            if (!response.ok || !data.ok) {
              throw new Error(data.error || "Dostupnosť sa nepodarilo načítať.");
            }

            applySlotAvailability(data.slots || [], data.mode || "mock");
          } catch (error) {
            if (error instanceof DOMException && error.name === "AbortError") return;

            setSlotButtonsDisabled(false);
            setSlotStatus("Dostupné časy sa teraz nepodarilo načítať. Vyberte preferovaný čas a potvrdím ho späť.");
          }
        };

        const buildLeadPayload = () => {
          const payload = {};

          new FormData(funnelForm).forEach((value, key) => {
            if (typeof value === "string") payload[key] = value.trim();
          });

          const route = currentRoute();
          const params = new URLSearchParams(window.location.search);
          const browserAttribution =
            typeof window.jakubGetAttribution === "function"
              ? window.jakubGetAttribution()
              : {
                  landing_path: window.location.pathname,
                  referrer: document.referrer || "",
                };
          const sourceAttribution = {
            source_lead_id: params.get("lead_id") || browserAttribution.source_lead_id || "",
            offer: params.get("offer") || browserAttribution.offer || "",
            zdroj: params.get("zdroj") || "",
            utm_source: params.get("utm_source") || browserAttribution.utm_source || "",
            utm_medium: params.get("utm_medium") || browserAttribution.utm_medium || "",
            utm_campaign: params.get("utm_campaign") || browserAttribution.utm_campaign || "",
            utm_content: params.get("utm_content") || browserAttribution.utm_content || "",
            utm_term: params.get("utm_term") || browserAttribution.utm_term || "",
          };
          payload.parametre = routeParameterLines();
          payload.lead_title = route.leadTitle;
          payload.subject_prefix = route.subjectPrefix;
          payload.page_url = window.location.href;
          payload.created_at = new Date().toISOString();
          payload.source_lead_id = sourceAttribution.source_lead_id;
          payload.offer = sourceAttribution.offer;
          payload.zdroj = sourceAttribution.zdroj;
          payload.utm_source = sourceAttribution.utm_source;
          payload.utm_medium = sourceAttribution.utm_medium;
          payload.utm_campaign = sourceAttribution.utm_campaign;
          payload.utm_content = sourceAttribution.utm_content;
          payload.utm_term = sourceAttribution.utm_term;
          payload.attribution = { ...browserAttribution, ...sourceAttribution };
          payload.session_id = payload.attribution?.session_id || "";
          payload.consent_state =
            typeof window.jakubGetConsentState === "function" ? window.jakubGetConsentState() : "unset";
          payload.lead_correlation_id = createLeadCorrelationId();

          return payload;
        };

        const buildMailFallbackHref = (payload) => {
          const targetEmail = funnelForm.getAttribute("data-email");
          if (!targetEmail) return "";

          const route = currentRoute();
          const subjectName = payload.meno || "nový kontakt";
          const intentName = payload.zamer || "rezervácia konzultácie";
          const body = [
            route.leadTitle,
            "",
            `Meno: ${payload.meno || "-"}`,
            `Telefón: ${payload.telefon || "-"}`,
            `Email: ${payload.email || "-"}`,
            `Zámer: ${intentName}`,
            `Zdrojový lead: ${payload.source_lead_id || "-"}`,
            `Offer: ${payload.offer || "-"}`,
            `Kampaň: ${payload.utm_source || "-"} / ${payload.utm_campaign || "-"}`,
            `Typ nehnuteľnosti / vetva: ${payload.typ || "-"}`,
            `Lokalita: ${payload.lokalita || "-"}`,
            "",
            "Parametre:",
            ...(Array.isArray(payload.parametre) && payload.parametre.length > 0 ? payload.parametre : ["-"]),
            "",
            `Preferovaný dátum: ${payload.datum || "-"}`,
            `Preferovaný čas: ${payload.cas || "-"}`,
            `Časový horizont: ${payload.horizont || "-"}`,
            "",
            "Čo je dôležité:",
            payload.sprava || "-",
          ].join("\n");

          return `mailto:${encodeURIComponent(targetEmail)}?subject=${encodeURIComponent(
            `${route.subjectPrefix} - ${subjectName} - ${intentName}`,
          )}&body=${encodeURIComponent(body)}`;
        };

        const showBookingConfirmation = (result) => {
          funnelSteps.forEach((panel) => {
            panel.toggleAttribute("hidden", true);
          });

          if (wizardActions instanceof HTMLElement) wizardActions.hidden = true;
          if (wizardProgress instanceof HTMLElement) wizardProgress.hidden = true;
          if (funnelSummary) funnelSummary.textContent = "";
          if (bookingConfirmation instanceof HTMLElement) bookingConfirmation.hidden = false;

          if (bookingConfirmationText) {
            bookingConfirmationText.textContent =
              result.bookingStatus === "calendar_created"
                ? "Termín je zapísaný v kalendári a mám podklady k hovoru."
                : "Ďakujem, mám podklady k hovoru a ozvem sa s potvrdením termínu.";
          }

          setFunnelError();
        };

        const submitBooking = async () => {
          if (isSubmitting) return;

          const endpoint = funnelForm.getAttribute("data-booking-endpoint") || "/api/book";
          const payload = buildLeadPayload();
          isSubmitting = true;
          trackFunnelEvent("submit_attempt", {
            intent: payload.zamer || "",
            source_lead_id: payload.source_lead_id || "",
            offer: payload.offer || "",
            utm_source: payload.utm_source || "",
            utm_campaign: payload.utm_campaign || "",
            utm_content: payload.utm_content || "",
          });

          if (funnelSubmit instanceof HTMLButtonElement) {
            funnelSubmit.disabled = true;
            funnelSubmit.textContent = "Odosielam...";
          }

          try {
            const response = await fetch(endpoint, {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
                Accept: "application/json",
              },
              body: JSON.stringify(payload),
            });

            const data = await response.json();

            if (response.status === 409 && data.code === "slot_unavailable") {
              setFunnelError(data.error || "Tento termín sa medzitým obsadil.");
              setFunnelStep(2);
              await loadAvailability();
              return;
            }

            if (!response.ok || !data.ok) {
              throw new Error(data.error || "Rezerváciu sa nepodarilo odoslať.");
            }

            trackFunnelEvent("submit_success", {
              intent: payload.zamer || "",
              booking_status: data.bookingStatus || "",
              mode: data.mode || "",
              lead_correlation_id: payload.lead_correlation_id || "",
              source_lead_id: payload.source_lead_id || "",
              offer: payload.offer || "",
              utm_source: payload.utm_source || "",
              utm_campaign: payload.utm_campaign || "",
              utm_content: payload.utm_content || "",
            });
            showBookingConfirmation(data);
          } catch {
            const fallbackHref = buildMailFallbackHref(payload);
            setFunnelError("Rezerváciu sa teraz nepodarilo odoslať. Otvorím email, aby sa správa nestratila.");
            trackFunnelEvent("submit_error", {
              intent: payload.zamer || "",
              source_lead_id: payload.source_lead_id || "",
              offer: payload.offer || "",
              utm_source: payload.utm_source || "",
              utm_campaign: payload.utm_campaign || "",
            });

            if (fallbackHref) {
              window.location.href = fallbackHref;
            }
          } finally {
            isSubmitting = false;

            if (
              funnelSubmit instanceof HTMLButtonElement &&
              !(bookingConfirmation instanceof HTMLElement && !bookingConfirmation.hidden)
            ) {
              funnelSubmit.disabled = false;
              applyIntentRoute();
            }
          }
        };

        const setFunnelStep = (step) => {
          activeStep = Math.max(0, Math.min(step, funnelSteps.length - 1));

          funnelSteps.forEach((panel, index) => {
            panel.toggleAttribute("hidden", index !== activeStep);
          });

          if (progressText) progressText.textContent = `${activeStep + 1} / ${funnelSteps.length}`;
          if (progressBar instanceof HTMLElement) progressBar.style.width = `${((activeStep + 1) / funnelSteps.length) * 100}%`;
          if (funnelPrev instanceof HTMLButtonElement) funnelPrev.disabled = activeStep === 0;
          if (funnelNext instanceof HTMLButtonElement) funnelNext.hidden = activeStep === funnelSteps.length - 1;
          if (funnelSubmit instanceof HTMLButtonElement) funnelSubmit.hidden = activeStep !== funnelSteps.length - 1;
          setFunnelError();
          updateFunnelSummary();
          trackFunnelEvent("step_view", {
            step: activeStep + 1,
            step_name: funnelStepNames[activeStep] || "unknown",
            intent: funnelValue("zamer") || "",
          });

          if (activeStep === 2) {
            loadAvailability();
          }
        };

        const validateFunnelStep = (step) => {
          const panel = funnelSteps[step];
          const requiredFields = Array.from(panel.querySelectorAll("[data-required]"));

          for (const field of requiredFields) {
            if (
              (field instanceof HTMLInputElement ||
                field instanceof HTMLTextAreaElement ||
                field instanceof HTMLSelectElement) &&
              field.type === "checkbox" &&
              field instanceof HTMLInputElement &&
              !field.checked
            ) {
              setFunnelError(`Potvrďte prosím ${field.dataset.label || "povinný súhlas"}.`);
              field.focus();
              return false;
            }

            if (
              (field instanceof HTMLInputElement ||
                field instanceof HTMLTextAreaElement ||
                field instanceof HTMLSelectElement) &&
              field.type !== "checkbox" &&
              !field.value.trim()
            ) {
              setFunnelError(`Doplňte prosím ${field.dataset.label || "povinné pole"}.`);

              if (field.type !== "hidden") {
                field.focus();
              }

              return false;
            }

            if (
              field instanceof HTMLInputElement &&
              field.dataset.locationInput !== undefined &&
              field.dataset.googleEnforced === "true" &&
              locationVerified instanceof HTMLInputElement &&
              locationVerified.value !== "true"
            ) {
              setFunnelError("Vyberte prosím adresu z návrhov.");
              field.focus();
              return false;
            }
          }

          setFunnelError();
          return true;
        };

        funnelForm.querySelectorAll("[data-choice]").forEach((button) => {
          button.addEventListener("click", () => {
            if (!(button instanceof HTMLButtonElement)) return;

            const name = button.dataset.choice;
            const value = button.dataset.value || button.textContent?.trim() || "";
            if (!name) return;

            const field = funnelForm.elements.namedItem(name);
            if (field instanceof HTMLInputElement) field.value = value;

            funnelForm.querySelectorAll(`[data-choice="${name}"]`).forEach((item) => {
              item.classList.toggle("is-selected", item === button);
              item.setAttribute("aria-pressed", item === button ? "true" : "false");
            });

            applyIntentRoute();
            updateFunnelSummary();
            setFunnelError();

            if (name === "zamer") {
              trackFunnelEvent("intent_select", { intent: value });
            }

            if (name === "cas") {
              trackFunnelEvent("time_select", { intent: funnelValue("zamer") || "" });
            }
          });
        });

        dateInput?.addEventListener("change", () => {
          clearSelectedTime();
          trackFunnelEvent("date_select", { intent: funnelValue("zamer") || "" });
          loadAvailability();
        });

        locationInput?.addEventListener("input", () => {
          if (!(locationInput instanceof HTMLInputElement)) return;

          if (locationInput.value !== locationInput.dataset.selectedLocation) {
            clearLocationVerification();
          }
        });

        funnelForm.addEventListener("input", updateFunnelSummary);

        funnelPrev?.addEventListener("click", () => setFunnelStep(activeStep - 1));
        funnelNext?.addEventListener("click", () => {
          if (validateFunnelStep(activeStep)) setFunnelStep(activeStep + 1);
        });

        funnelForm.addEventListener("submit", (event) => {
          event.preventDefault();

          for (let index = 0; index < funnelSteps.length; index += 1) {
            if (!validateFunnelStep(index)) {
              setFunnelStep(index);
              return;
            }
          }

          submitBooking();
        });

        setupLocationAutocomplete();

        const applyQueryIntent = () => {
          const params = new URLSearchParams(window.location.search);
          const intent = params.get("zamer");
          if (!intent) return;

          const button = Array.from(funnelForm.querySelectorAll('[data-choice="zamer"]')).find((item) => {
            return item instanceof HTMLButtonElement && item.dataset.value === intent;
          });
          if (!(button instanceof HTMLButtonElement)) return;

          const field = funnelForm.elements.namedItem("zamer");
          if (field instanceof HTMLInputElement) field.value = intent;

          funnelForm.querySelectorAll('[data-choice="zamer"]').forEach((item) => {
            item.classList.toggle("is-selected", item === button);
            item.setAttribute("aria-pressed", item === button ? "true" : "false");
          });

          trackFunnelEvent("intent_prefill", {
            intent,
            source: params.get("zdroj") || "",
            offer: params.get("offer") || "",
          });
        };

        applyQueryIntent();
        applyIntentRoute();
        setFunnelStep(0);
      }
    </script>

    <style>
      :root {
        --paper: #f6f1e8;
        --ink: #0b0b0a;
        --muted: #726b61;
        --wine: #9a5c32;
        --brass: #d8b878;
        --white: #fffaf2;
        --line: rgba(255, 250, 242, 0.16);
        --font-body: "Instrument Sans", system-ui, sans-serif;
        --font-display: "Newsreader", Georgia, serif;
      }

      * {
        box-sizing: border-box;
      }

      html {
        height: 100%;
        min-height: 100%;
        background: var(--ink);
      }

      body {
        display: flex;
        min-height: 100svh;
        flex-direction: column;
        margin: 0;
        background:
          linear-gradient(120deg, rgba(11, 11, 10, 0.97), rgba(27, 27, 25, 0.93)),
          var(--ink);
        color: var(--white);
        font-family: var(--font-body);
        line-height: 1.5;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        display: block;
        max-width: 100%;
      }

      .staging-ribbon {
        position: fixed;
        right: 18px;
        bottom: 18px;
        z-index: 20;
        border: 1px solid rgba(11, 11, 10, 0.16);
        border-radius: 999px;
        padding: 8px 12px;
        background: #f3cf74;
        color: var(--ink);
        box-shadow: 0 12px 30px rgba(11, 11, 10, 0.22);
        font-size: 12px;
        font-weight: 900;
      }

      .wizard-header {
        display: flex;
        width: min(1180px, calc(100% - 36px));
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        margin: 0 auto;
        padding: 22px 0;
      }

      .brand {
        display: flex;
        min-width: 0;
        align-items: center;
        gap: 12px;
      }

      .brand-cluster {
        display: flex;
        min-width: 0;
        align-items: center;
        gap: 13px;
      }

      .brand-divider {
        width: 1px;
        height: 34px;
        background: rgba(255, 250, 242, 0.2);
      }

      .bosen-logo {
        display: block;
        object-fit: contain;
        object-position: center;
        mix-blend-mode: screen;
      }

      .header-bosen-logo {
        width: 164px;
        height: 36px;
        opacity: 0.9;
      }

      .brand img {
        width: 112px;
        height: 42px;
        object-fit: contain;
      }

      .brand span {
        display: grid;
      }

      .brand strong {
        font-family: var(--font-display);
        font-size: 24px;
        line-height: 1;
      }

      .brand small {
        color: rgba(255, 250, 242, 0.68);
      }

      .back-link {
        border: 1px solid rgba(255, 250, 242, 0.22);
        border-radius: 6px;
        padding: 10px 13px;
        color: rgba(255, 250, 242, 0.82);
        font-size: 14px;
        font-weight: 800;
      }

      .wizard-shell {
        display: grid;
        width: min(1380px, calc(100% - 36px));
        flex: 1;
        gap: 34px;
        margin: 0 auto;
        padding: 42px 0 70px;
      }

      .wizard-copy {
        display: grid;
        width: min(980px, 100%);
        justify-self: center;
        gap: 16px;
        text-align: center;
      }

      .eyebrow {
        margin: 0;
        color: var(--brass);
        font-size: 14px;
        font-weight: 800;
      }

      h1,
      h2,
      p {
        margin-top: 0;
      }

      h1,
      h2 {
        font-family: var(--font-display);
        font-weight: 650;
        line-height: 0.98;
      }

      h1 {
        max-width: 980px;
        margin-bottom: 0;
        font-size: clamp(52px, 6vw, 82px);
      }

      h2 {
        margin-bottom: 0;
        font-size: clamp(34px, 4vw, 54px);
      }

      .wizard-copy > p,
      .wizard-step > p:not(.step-kicker) {
        margin: 0;
        color: rgba(255, 250, 242, 0.72);
        font-size: 18px;
      }

      .wizard-copy > p {
        max-width: 760px;
        justify-self: center;
      }

      .wizard-card {
        display: grid;
        gap: 18px;
        width: 100%;
        border: 1px solid rgba(255, 250, 242, 0.18);
        border-radius: 8px;
        padding: clamp(22px, 4vw, 38px);
        background: rgba(255, 250, 242, 0.08);
        box-shadow: 0 24px 70px rgba(0, 0, 0, 0.24);
      }

      .wizard-progress {
        display: grid;
        gap: 10px;
      }

      .wizard-progress span,
      .step-kicker {
        color: var(--brass);
        font-size: 13px;
        font-weight: 900;
      }

      .wizard-progress div {
        height: 8px;
        overflow: hidden;
        border-radius: 999px;
        background: rgba(255, 250, 242, 0.12);
      }

      .wizard-progress i {
        display: block;
        width: 25%;
        height: 100%;
        border-radius: inherit;
        background: var(--brass);
        transition: width 180ms ease;
      }

      .wizard-error {
        min-height: 22px;
        margin: 0;
        color: #ffd38c;
        font-size: 14px;
        font-weight: 800;
      }

      .hp-field {
        position: absolute;
        width: 1px;
        height: 1px;
        overflow: hidden;
        clip: rect(0 0 0 0);
        clip-path: inset(50%);
        white-space: nowrap;
      }

      .wizard-step {
        display: grid;
        width: 100%;
        gap: 16px;
      }

      .wizard-step[hidden] {
        display: none;
      }

      .step-kicker {
        margin: 0;
      }

      .choice-grid,
      .slot-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
      }

      .choice-grid.compact {
        grid-template-columns: repeat(5, minmax(0, 1fr));
      }

      .choice-button,
      .slot-button {
        min-height: 54px;
        border: 1px solid rgba(255, 250, 242, 0.18);
        border-radius: 8px;
        padding: 12px 14px;
        background: rgba(11, 11, 10, 0.24);
        color: rgba(255, 250, 242, 0.86);
        cursor: pointer;
        font: inherit;
        font-weight: 800;
        line-height: 1.18;
        text-align: left;
        transition: background 160ms ease, border-color 160ms ease, color 160ms ease, transform 160ms ease;
      }

      .slot-button {
        display: grid;
        min-height: 58px;
        place-items: center;
        text-align: center;
        font-size: 19px;
      }

      .choice-button:hover,
      .slot-button:hover,
      .choice-button.is-selected,
      .slot-button.is-selected {
        border-color: rgba(216, 184, 120, 0.78);
        background: rgba(216, 184, 120, 0.16);
        color: var(--white);
        transform: translateY(-1px);
      }

      .slot-button:disabled,
      .slot-button.is-unavailable {
        border-color: rgba(255, 250, 242, 0.1);
        background: rgba(255, 250, 242, 0.06);
        color: rgba(255, 250, 242, 0.34);
        cursor: not-allowed;
        transform: none;
      }

      .slot-status {
        min-height: 20px;
        margin: 0;
        color: rgba(255, 250, 242, 0.58);
        font-size: 13px;
        font-weight: 750;
      }

      .wizard-fields {
        display: grid;
        gap: 12px;
      }

      .wizard-fields.two {
        grid-template-columns: repeat(4, minmax(0, 1fr));
        row-gap: 18px;
      }

      .wizard-fields label {
        display: grid;
        gap: 7px;
      }

      .wizard-fields [data-param-field][hidden] {
        display: none;
      }

      .wizard-fields .location-field {
        grid-column: span 2;
      }

      .wizard-fields label.full {
        grid-column: 1 / -1;
      }

      .wizard-fields .consent-field {
        display: flex;
        align-items: flex-start;
        gap: 11px;
        margin-top: 2px;
      }

      .wizard-fields span {
        color: rgba(255, 250, 242, 0.64);
        font-size: 12px;
        font-weight: 850;
      }

      .wizard-fields .consent-field span {
        color: rgba(255, 250, 242, 0.72);
        font-size: 13px;
        font-weight: 700;
        line-height: 1.45;
      }

      .wizard-fields .consent-field a {
        color: var(--brass);
        text-decoration: none;
      }

      .wizard-fields input,
      .wizard-fields select,
      .wizard-fields textarea {
        width: 100%;
        border: 1px solid rgba(255, 250, 242, 0.16);
        border-radius: 6px;
        background: rgba(11, 11, 10, 0.28);
        color: var(--white);
        color-scheme: dark;
        font: inherit;
      }

      .wizard-fields input,
      .wizard-fields select {
        min-height: 48px;
        padding: 0 13px;
      }

      .wizard-fields .consent-field input {
        flex: 0 0 auto;
        width: 18px;
        min-height: 18px;
        height: 18px;
        margin: 1px 0 0;
        accent-color: var(--brass);
      }

      .wizard-fields textarea {
        min-height: 118px;
        padding: 12px 13px;
        resize: vertical;
      }

      .wizard-fields input::placeholder,
      .wizard-fields textarea::placeholder {
        color: rgba(255, 250, 242, 0.36);
      }

      .location-field.is-verified input[data-location-input] {
        border-color: rgba(216, 184, 120, 0.72);
      }

      :global(.pac-container) {
        z-index: 10000;
        border: 1px solid rgba(11, 11, 10, 0.14);
        border-radius: 8px;
        margin-top: 6px;
        background: var(--white);
        box-shadow: 0 18px 44px rgba(0, 0, 0, 0.24);
        font-family: var(--font-body);
      }

      :global(.pac-item) {
        padding: 9px 12px;
        cursor: pointer;
      }

      :global(.pac-item-query) {
        color: var(--ink);
        font-size: 14px;
      }

      .wizard-fields input:focus,
      .wizard-fields select:focus,
      .wizard-fields textarea:focus,
      .choice-button:focus-visible,
      .slot-button:focus-visible,
      .button:focus-visible,
      .back-link:focus-visible {
        border-color: rgba(216, 184, 120, 0.72);
        outline: 2px solid var(--brass);
        outline-offset: 3px;
      }

      .wizard-summary {
        min-height: 24px;
        color: rgba(255, 250, 242, 0.66);
        font-size: 13px;
        font-weight: 750;
      }

      .booking-confirmation {
        display: grid;
        gap: 16px;
        max-width: 820px;
      }

      .booking-confirmation[hidden] {
        display: none;
      }

      .booking-confirmation p:not(.step-kicker) {
        margin: 0;
        color: rgba(255, 250, 242, 0.72);
        font-size: 18px;
      }

      .booking-confirmation .button {
        justify-self: start;
      }

      .wizard-actions {
        display: flex;
        gap: 10px;
        justify-content: space-between;
      }

      .wizard-actions[hidden],
      .wizard-progress[hidden] {
        display: none;
      }

      .button {
        appearance: none;
        -webkit-appearance: none;
        display: inline-flex;
        min-height: 50px;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(255, 250, 242, 0.26);
        border-radius: 6px;
        padding: 0 20px;
        color: var(--white);
        cursor: pointer;
        font: inherit;
        font-weight: 800;
        transition: transform 160ms ease, background 160ms ease, color 160ms ease;
      }

      .button[hidden] {
        display: none;
      }

      .button:hover {
        transform: translateY(-2px);
      }

      .button.primary {
        border-color: var(--brass);
        background: var(--brass);
        color: var(--ink);
      }

      .button.secondary {
        border-color: rgba(255, 250, 242, 0.18);
        background: rgba(255, 250, 242, 0.1);
        color: rgba(255, 250, 242, 0.78);
        -webkit-text-fill-color: rgba(255, 250, 242, 0.78);
      }

      .button.secondary:hover {
        border-color: rgba(255, 250, 242, 0.26);
        background: rgba(255, 250, 242, 0.14);
        color: rgba(255, 250, 242, 0.9);
        -webkit-text-fill-color: rgba(255, 250, 242, 0.9);
      }

      .button:disabled {
        border-color: rgba(255, 250, 242, 0.12);
        background: rgba(255, 250, 242, 0.08);
        color: rgba(255, 250, 242, 0.42);
        -webkit-text-fill-color: rgba(255, 250, 242, 0.42);
        cursor: not-allowed;
        transform: none;
      }

      .button.secondary:disabled {
        border-color: rgba(255, 250, 242, 0.12);
        background-color: rgba(255, 250, 242, 0.08);
        color: rgba(255, 250, 242, 0.42);
        -webkit-text-fill-color: rgba(255, 250, 242, 0.42);
      }

      .wizard-actions .button:disabled {
        border-color: rgba(255, 250, 242, 0.12) !important;
        background: rgba(255, 250, 242, 0.08) !important;
        background-color: rgba(255, 250, 242, 0.08) !important;
        color: rgba(255, 250, 242, 0.42) !important;
        -webkit-text-fill-color: rgba(255, 250, 242, 0.42) !important;
      }

      .button:disabled:hover {
        transform: none;
      }

      .wizard-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        margin-top: auto;
        padding: 26px max(28px, calc((100vw - 1180px) / 2)) 110px;
        background: #0b0b0a;
        color: rgba(255, 250, 242, 0.72);
      }

      .footer-brand {
        display: flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
      }

      .wizard-footer p {
        margin: 0;
      }

      .footer-links {
        display: grid;
        justify-items: end;
        gap: 8px;
      }

      .social-icon {
        display: inline-grid;
        width: 38px;
        height: 38px;
        place-items: center;
        border: 1px solid rgba(255, 250, 242, 0.2);
        border-radius: 999px;
        color: rgba(255, 250, 242, 0.78);
        transition: border-color 160ms ease, color 160ms ease, transform 160ms ease;
      }

      .social-icon svg {
        width: 19px;
        height: 19px;
        fill: none;
        stroke: currentColor;
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-width: 1.8;
      }

      .social-icon:hover {
        border-color: var(--brass);
        color: var(--brass);
        transform: translateY(-1px);
      }

      .social-icon.is-disabled {
        cursor: default;
        opacity: 0.42;
        transform: none;
      }

      .social-icon.is-disabled:hover {
        border-color: rgba(255, 250, 242, 0.2);
        color: rgba(255, 250, 242, 0.78);
      }

      .footer-brand img {
        width: 118px;
        height: 52px;
        object-fit: contain;
      }

      .footer-brand .footer-bosen-logo {
        width: 170px;
        height: 42px;
        opacity: 0.88;
      }

      .footer-brand p {
        color: var(--white);
        font-family: var(--font-display);
        font-size: 24px;
        font-weight: 650;
      }

      .wizard-footer a {
        text-decoration-line: underline;
        text-decoration-color: transparent;
        text-decoration-thickness: 1px;
        text-underline-offset: 5px;
        transition: color 160ms ease, text-decoration-color 160ms ease;
      }

      .wizard-footer a:hover {
        color: var(--brass);
        text-decoration-color: currentColor;
      }

      @media (max-width: 980px) {
        .wizard-shell {
          width: min(760px, calc(100% - 36px));
        }

        .wizard-copy > p {
          max-width: none;
        }

        .choice-grid,
        .choice-grid.compact,
        .wizard-fields.two {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .wizard-fields .location-field {
          grid-column: 1 / -1;
        }

      }

      @media (max-width: 620px) {
        .wizard-header,
        .wizard-shell {
          width: calc(100% - 36px);
        }

        .wizard-footer {
          display: grid;
          padding-right: 18px;
          padding-bottom: 150px;
          padding-left: 18px;
        }

        .footer-links {
          justify-items: start;
        }

        .brand span {
          display: none;
        }

        .brand img {
          width: 86px;
        }

        .brand-cluster {
          gap: 8px;
        }

        .brand-divider {
          height: 28px;
        }

        .header-bosen-logo {
          width: 104px;
          height: 30px;
        }

        .footer-brand .footer-bosen-logo {
          width: 142px;
          height: 36px;
        }

        h1 {
          font-size: 42px;
        }

        h2 {
          font-size: 32px;
        }

        .wizard-shell {
          padding-top: 28px;
          padding-bottom: 52px;
        }

        .choice-grid,
        .choice-grid.compact,
        .slot-grid,
        .wizard-fields.two {
          grid-template-columns: 1fr;
        }

        .wizard-fields .location-field {
          grid-column: auto;
        }

        .wizard-actions {
          display: grid;
        }

        .button {
          width: 100%;
        }

      }
    </style>
    <AnalyticsConsent />
  </body>
</html>
