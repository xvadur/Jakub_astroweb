---
import { site } from "../../data/site";

export function getStaticPaths() {
  return site.listings.map((listing) => ({
    params: { slug: listing.slug },
    props: { listing },
  }));
}

const { listing } = Astro.props;
const cleanPhone = site.contact.phone.replace(/[^\d+]/g, "");
const contactHref = cleanPhone.length >= 10 ? `tel:${cleanPhone}` : "/";
const gallery = listing.gallery?.length ? listing.gallery : [listing.image];
const isSold = listing.group === "sold";
---

<!doctype html>
<html lang="sk">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={`${listing.title} | ${listing.place}. ${listing.summary}`} />
    <meta property="og:title" content={`${listing.title} | ${site.brand}`} />
    <meta property="og:description" content={listing.summary} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={listing.image} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Source+Serif+4:opsz,wght@8..60,500;8..60,600;8..60,700&display=swap"
      rel="stylesheet"
    />
    <title>{listing.title} | {site.brand}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">
        <img class="brand-mark" src={site.logoImage} alt="" />
        <span class="brand-label">
          <span>{site.brand}</span>
          <small>{site.role}</small>
        </span>
      </a>
      <nav aria-label="Navigácia detailu">
        <a href="/#ponuky">Ponuky</a>
        <a href="/#kontakt">Kontakt</a>
      </nav>
      <a class="header-phone" href={contactHref}>{site.contact.phone}</a>
    </header>

    <main>
      <section class="detail-hero">
        <div>
          <a class="back-link" href="/#ponuky">← Späť na ponuky</a>
          <p class="eyebrow">{listing.status}</p>
          <h1>{listing.title}</h1>
          <p class="summary">{listing.summary}</p>
          <div class="meta-row">
            <span>{listing.place}</span>
            <strong>{listing.price}</strong>
          </div>
        </div>
        <img src={listing.image} alt="" />
      </section>

      <section class="detail-section gallery-section" aria-label="Fotogaléria">
        {
          gallery.map((image) => (
            <img src={image} alt="" loading="lazy" />
          ))
        }
      </section>

      <section class="detail-section detail-grid">
        <div>
          <p class="eyebrow">{isSold ? "Referenčný predaj" : "Detail ponuky"}</p>
          <h2>{isSold ? "Výsledok predaja" : "Informácie o nehnuteľnosti"}</h2>
          <p>{listing.detail}</p>
        </div>
        <dl class="specs">
          {
            listing.specs.map((spec) => (
              <div>
                <dt>{spec.label}</dt>
                <dd>{spec.value}</dd>
              </div>
            ))
          }
        </dl>
      </section>

      <section class="detail-section highlights" aria-label="Hlavné body">
        {
          listing.highlights.map((highlight) => (
            <span>{highlight}</span>
          ))
        }
      </section>

      <section class="detail-cta" id="kontakt">
        <div>
          <p class="eyebrow">{isSold ? "Chcete podobný výsledok?" : "Máte záujem?"}</p>
          <h2>{isSold ? "Porozprávajme sa o vašej nehnuteľnosti." : "Dohodnite si obhliadku alebo krátky rozhovor."}</h2>
        </div>
        <div class="cta-actions">
          <a class="button primary" href={contactHref}>{site.contact.phone}</a>
          <a class="button secondary" href={`mailto:${site.contact.email}`}>{site.contact.email}</a>
        </div>
      </section>
    </main>

    <style>
      :root {
        --paper: #f4f5f1;
        --paper-strong: #e3e9df;
        --ink: #101513;
        --charcoal: #1b2421;
        --muted: #68716d;
        --wine: #506a5f;
        --brass: #c98452;
        --brass-muted: #8c6448;
        --white: #fbfbf6;
        --line: rgba(16, 21, 19, 0.16);
        --shadow: 0 24px 70px rgba(16, 21, 19, 0.2);
        --font-body: "Inter", system-ui, sans-serif;
        --font-display: "Source Serif 4", Georgia, serif;
      }

      * {
        box-sizing: border-box;
      }

      html {
        overflow-x: hidden;
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background: var(--paper);
        color: var(--ink);
        font-family: var(--font-body);
        line-height: 1.5;
        overflow-x: clip;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        display: block;
        max-width: 100%;
      }

      .site-header {
        position: fixed;
        top: 18px;
        left: 50%;
        z-index: 50;
        display: flex;
        width: min(1180px, calc(100% - 32px));
        min-height: 64px;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        padding: 10px 14px 10px 18px;
        border: 1px solid rgba(201, 132, 82, 0.3);
        border-radius: 8px;
        background: rgba(16, 21, 19, 0.78);
        color: var(--white);
        transform: translateX(-50%);
        backdrop-filter: blur(18px);
      }

      .brand {
        display: flex;
        min-width: 0;
        align-items: center;
        gap: 12px;
      }

      .brand-mark {
        width: 112px;
        height: 36px;
        object-fit: contain;
        object-position: center;
      }

      .brand-label {
        display: grid;
      }

      .brand-label span {
        font-family: var(--font-display);
        font-size: 24px;
        font-weight: 600;
        line-height: 1;
      }

      .brand-label small,
      nav {
        color: rgba(251, 251, 246, 0.72);
      }

      nav {
        display: flex;
        gap: 20px;
        font-size: 14px;
      }

      .header-phone {
        display: inline-flex;
        min-height: 42px;
        align-items: center;
        border: 1px solid rgba(251, 251, 246, 0.22);
        border-radius: 6px;
        padding: 0 14px;
        font-weight: 700;
        white-space: nowrap;
      }

      .detail-hero,
      .detail-section,
      .detail-cta {
        padding-inline: max(28px, calc((100vw - 1180px) / 2));
      }

      .detail-hero {
        display: grid;
        min-height: 92svh;
        grid-template-columns: minmax(0, 0.9fr) minmax(420px, 1.1fr);
        gap: 54px;
        align-items: center;
        padding-top: 118px;
        padding-bottom: 72px;
        background:
          radial-gradient(circle at 84% 18%, rgba(201, 132, 82, 0.16), transparent 30%),
          var(--paper);
      }

      .detail-hero > div {
        max-width: 650px;
      }

      .back-link {
        display: inline-flex;
        margin-bottom: 28px;
        color: var(--wine);
        font-weight: 800;
      }

      .eyebrow {
        margin: 0 0 18px;
        color: var(--wine);
        font-size: 14px;
        font-weight: 800;
      }

      h1,
      h2,
      p {
        margin-top: 0;
      }

      h1,
      h2 {
        font-family: var(--font-display);
        font-weight: 600;
        line-height: 0.96;
      }

      h1 {
        margin-bottom: 22px;
        font-size: clamp(50px, 6.4vw, 86px);
      }

      h2 {
        margin-bottom: 18px;
        font-size: clamp(38px, 4.8vw, 64px);
      }

      .summary,
      .detail-grid p {
        color: var(--muted);
        font-size: 18px;
      }

      .meta-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-top: 36px;
        border-top: 1px solid var(--line);
        padding-top: 18px;
        font-weight: 800;
      }

      .meta-row span {
        color: var(--muted);
      }

      .detail-hero > img {
        width: 100%;
        height: min(680px, 72vh);
        object-fit: cover;
        border-radius: 8px;
        box-shadow: var(--shadow);
      }

      .gallery-section {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 18px;
        padding-top: 0;
        padding-bottom: 100px;
      }

      .gallery-section img {
        width: 100%;
        height: 100%;
        min-height: 340px;
        object-fit: cover;
        border-radius: 8px;
      }

      .gallery-section img:first-child:last-child {
        grid-column: 1 / -1;
      }

      .detail-grid {
        display: grid;
        grid-template-columns: minmax(0, 0.9fr) minmax(360px, 0.7fr);
        gap: 70px;
        padding-top: 100px;
        padding-bottom: 100px;
        background: var(--white);
      }

      .specs {
        display: grid;
        gap: 0;
        margin: 0;
        border-top: 1px solid var(--line);
      }

      .specs div {
        display: grid;
        grid-template-columns: 0.46fr 1fr;
        gap: 22px;
        padding: 18px 0;
        border-bottom: 1px solid var(--line);
      }

      dt {
        color: var(--muted);
        font-size: 14px;
      }

      dd {
        margin: 0;
        font-weight: 800;
      }

      .highlights {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        padding-top: 70px;
        padding-bottom: 70px;
        background: var(--paper-strong);
      }

      .highlights span {
        border: 1px solid rgba(16, 21, 19, 0.18);
        border-radius: 999px;
        padding: 10px 14px;
        background: rgba(251, 251, 246, 0.54);
        font-weight: 800;
      }

      .detail-cta {
        display: grid;
        grid-template-columns: minmax(0, 0.9fr) minmax(320px, 0.7fr);
        gap: 70px;
        align-items: center;
        padding-top: 100px;
        padding-bottom: 100px;
        background: linear-gradient(110deg, var(--ink), var(--charcoal));
        color: var(--white);
      }

      .detail-cta .eyebrow {
        color: var(--brass);
      }

      .cta-actions {
        display: grid;
        gap: 12px;
      }

      .button {
        display: inline-flex;
        min-height: 50px;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--brass);
        border-radius: 6px;
        padding: 0 20px;
        font-weight: 800;
      }

      .button.primary {
        background: var(--brass);
        color: var(--ink);
      }

      .button.secondary {
        color: var(--white);
      }

      @media (max-width: 980px) {
        .site-header {
          position: absolute;
          top: 12px;
        }

        nav {
          display: none;
        }

        .detail-hero,
        .detail-grid,
        .detail-cta {
          grid-template-columns: 1fr;
        }

        .detail-hero {
          min-height: auto;
          padding-top: 104px;
        }

        .gallery-section {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 620px) {
        .site-header {
          width: calc(100% - 20px);
          min-height: 58px;
          gap: 10px;
        }

        .brand-label span {
          font-size: 21px;
        }

        .brand-label {
          display: none;
        }

        .brand-mark {
          width: 88px;
        }

        .header-phone {
          min-height: 38px;
          padding: 0 10px;
          font-size: 13px;
        }

        .detail-hero,
        .detail-section,
        .detail-cta {
          padding-inline: 18px;
        }

        h1 {
          font-size: 48px;
        }

        .meta-row,
        .specs div {
          grid-template-columns: 1fr;
          gap: 4px;
        }
      }
    </style>
  </body>
</html>
