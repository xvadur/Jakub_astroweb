---
import "../../styles/global.css";
import { site } from "../../data/site";
import { createListingJsonLd, createPageMeta, serializeJsonLd } from "../../data/seo";

export function getStaticPaths() {
  return site.listings.map((listing) => ({
    params: { slug: listing.slug },
    props: { listing },
  }));
}

const { listing } = Astro.props;
const gallery = listing.gallery?.length ? listing.gallery : [listing.image];
const isSold = listing.group === "sold";
const bosenUrl = listing.bosenUrl ?? "";
const hasInstagram = site.contact.instagram.startsWith("http");
const siteEnv = import.meta.env.PUBLIC_SITE_ENV ?? "production";
const isStaging = siteEnv !== "production";
const pageMeta = createPageMeta({
  title: `${listing.title} | ${site.brand}`,
  description: `${listing.title} | ${listing.place}. ${listing.summary}`,
  path: listing.href,
  image: listing.image,
});
const jsonLd = createListingJsonLd(listing, pageMeta);
---

<!doctype html>
<html lang="sk">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="icon" type="image/png" href="/favicon.png?v=2" />
    <link rel="icon" href="/favicon.ico?v=2" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageMeta.description} />
    <link rel="canonical" href={pageMeta.canonicalUrl} />
    <meta property="og:title" content={pageMeta.title} />
    <meta property="og:description" content={listing.summary} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageMeta.canonicalUrl} />
    <meta property="og:image" content={pageMeta.imageUrl} />
    <meta property="og:locale" content={site.locale.replace("-", "_")} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageMeta.title} />
    <meta name="twitter:description" content={listing.summary} />
    <meta name="twitter:image" content={pageMeta.imageUrl} />
    {isStaging ? <meta name="robots" content="noindex,nofollow,noarchive" /> : null}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Newsreader:opsz,wght@6..72,500;6..72,650;6..72,700&display=swap"
      rel="stylesheet"
    />
    <title>{pageMeta.title}</title>
    <script type="application/ld+json" set:html={serializeJsonLd(jsonLd)} />
  </head>
  <body>
    <header class="site-header">
      <div class="brand-cluster">
        <a class="brand" href="/">
          <img class="brand-mark" src={site.logoImage} alt="" />
          <span class="brand-label">
            <span>{site.brand}</span>
            <small>{site.role}</small>
          </span>
        </a>
        <span class="brand-divider" aria-hidden="true"></span>
        <img class="bosen-logo header-bosen-logo" src={site.bosenGroupLogo} alt="BOSEN Group" />
      </div>
      <nav aria-label="Navigácia detailu">
        <a href="/#ponuky">Ponuky</a>
        <a href="/#kontakt">Kontakt</a>
      </nav>
      <a class="header-booking" href="/rezervacia/">Rezervácia konzultácie</a>
    </header>

    <main>
      <section class="detail-hero">
        <div>
          <a class="back-link" href="/#ponuky">← Späť na ponuky</a>
          <p class="eyebrow">{listing.status}</p>
          <h1>{listing.title}</h1>
          <p class="summary">{listing.summary}</p>
          <div class="meta-row">
            <span>{listing.place}</span>
            <strong>{listing.price}</strong>
          </div>
          {
            bosenUrl ? (
              <a class="hero-bosen-link" href={bosenUrl} target="_blank" rel="noreferrer">
                Pozrieť inzerát na BOSEN Group
              </a>
            ) : null
          }
        </div>
        <img src={listing.image} alt="" />
      </section>

      <section class="detail-section gallery-section" aria-label="Fotogaléria">
        {
          gallery.map((image) => (
            <img src={image} alt="" loading="lazy" />
          ))
        }
      </section>

      <section class="detail-section detail-grid">
        <div>
          <p class="eyebrow">{isSold ? "Referenčný predaj" : "Detail ponuky"}</p>
          <h2>{isSold ? "Výsledok predaja" : "Informácie o nehnuteľnosti"}</h2>
          <p>{listing.detail}</p>
        </div>
        <dl class="specs">
          {
            listing.specs.map((spec) => (
              <div>
                <dt>{spec.label}</dt>
                <dd>{spec.value}</dd>
              </div>
            ))
          }
        </dl>
      </section>

      <section class="detail-section highlights" aria-label="Hlavné body">
        {
          listing.highlights.map((highlight) => (
            <span>{highlight}</span>
          ))
        }
      </section>

      <section class="detail-cta" id="kontakt">
        <div>
          <p class="eyebrow">{isSold ? "Chcete podobný výsledok?" : "Máte záujem?"}</p>
          <h2>{isSold ? "Povedzte mi o vašej nehnuteľnosti." : "Dohodnite si so mnou obhliadku alebo krátky rozhovor."}</h2>
        </div>
        <div class="cta-actions">
          {
            bosenUrl ? (
              <a class="button secondary bosen-button" href={bosenUrl} target="_blank" rel="noreferrer">
                Pozrieť inzerát na BOSEN
              </a>
            ) : null
          }
          <a class="button primary" href="/rezervacia/">Rezervovať konzultáciu</a>
          <a class="button secondary" href={`mailto:${site.contact.email}`}>{site.contact.email}</a>
        </div>
      </section>
    </main>

    <footer>
      <div class="footer-brand">
        <img src={site.logoImage} alt="" />
        <img class="bosen-logo footer-bosen-logo" src={site.bosenGroupLogo} alt="BOSEN Group" />
        {
          hasInstagram ? (
            <a
              class="social-icon"
              href={site.contact.instagram}
              target="_blank"
              rel="noreferrer"
              aria-label={site.contact.instagramLabel}
              title={site.contact.instagramLabel}
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="5" />
                <circle cx="12" cy="12" r="4" />
                <circle cx="17.5" cy="6.5" r="1.2" />
              </svg>
            </a>
          ) : (
            <span
              class="social-icon is-disabled"
              aria-label="Instagram doplniť pred spustením"
              title="Instagram doplniť pred spustením"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="5" />
                <circle cx="12" cy="12" r="4" />
                <circle cx="17.5" cy="6.5" r="1.2" />
              </svg>
            </span>
          )
        }
        <p>{site.brand}</p>
      </div>
      <p>{site.shortPromise}</p>
      <div class="footer-links">
        <a href="/#ponuky">Pozrieť ponuky</a>
        <a href="/ochrana-osobnych-udajov/">Ochrana údajov a cookies</a>
      </div>
    </footer>

    <style>
      :root {
        --paper: #f6f1e8;
        --paper-strong: #e9dfcf;
        --ink: #0b0b0a;
        --charcoal: #1b1b19;
        --muted: #6f6a62;
        --wine: #9a5c32;
        --brass: #d8b878;
        --brass-muted: #b8945b;
        --white: #fffaf2;
        --line: rgba(11, 11, 10, 0.16);
        --shadow: 0 24px 70px rgba(11, 11, 10, 0.2);
        --font-body: "Instrument Sans", system-ui, sans-serif;
        --font-display: "Newsreader", Georgia, serif;
      }

      * {
        box-sizing: border-box;
      }

      html {
        overflow-x: hidden;
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background: var(--paper);
        color: var(--ink);
        font-family: var(--font-body);
        line-height: 1.5;
        overflow-x: clip;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        display: block;
        max-width: 100%;
      }

      .site-header {
        position: fixed;
        top: 18px;
        left: 50%;
        z-index: 50;
        display: flex;
        width: min(1180px, calc(100% - 32px));
        min-height: 64px;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        padding: 10px 14px 10px 18px;
        border: 1px solid rgba(216, 184, 120, 0.3);
        border-radius: 8px;
        background: rgba(11, 11, 10, 0.78);
        color: var(--white);
        transform: translateX(-50%);
        backdrop-filter: blur(18px);
      }

      .brand {
        display: flex;
        min-width: 0;
        align-items: center;
        gap: 12px;
      }

      .brand-cluster {
        display: flex;
        min-width: 0;
        align-items: center;
        gap: 13px;
      }

      .brand-divider {
        width: 1px;
        height: 34px;
        background: rgba(255, 250, 242, 0.2);
      }

      .bosen-logo {
        display: block;
        object-fit: contain;
        object-position: center;
        mix-blend-mode: screen;
      }

      .header-bosen-logo {
        width: 164px;
        height: 36px;
        opacity: 0.9;
      }

      .brand-mark {
        width: 112px;
        height: 36px;
        object-fit: contain;
        object-position: center;
      }

      .brand-label {
        display: grid;
      }

      .brand-label span {
        font-family: var(--font-display);
        font-size: 24px;
        font-weight: 650;
        line-height: 1;
      }

      .brand-label small,
      nav {
        color: rgba(255, 250, 242, 0.72);
      }

      nav {
        display: flex;
        gap: 20px;
        font-size: 14px;
      }

      nav a,
      .header-booking,
      footer a {
        text-decoration-line: underline;
        text-decoration-color: transparent;
        text-decoration-thickness: 1px;
        text-underline-offset: 5px;
        transition: text-decoration-color 160ms ease, color 160ms ease;
      }

      nav a:hover,
      .header-booking:hover,
      footer a:hover {
        color: var(--brass);
        text-decoration-color: currentColor;
      }

      .header-booking {
        display: inline-flex;
        min-height: 42px;
        align-items: center;
        border: 1px solid rgba(255, 250, 242, 0.22);
        border-radius: 6px;
        padding: 0 14px;
        font-weight: 700;
        white-space: nowrap;
      }

      .detail-hero,
      .detail-section,
      .detail-cta {
        padding-inline: max(28px, calc((100vw - 1180px) / 2));
      }

      .detail-hero {
        display: grid;
        min-height: auto;
        grid-template-columns: minmax(0, 1fr) minmax(420px, 1fr);
        gap: 54px;
        align-items: center;
        padding-top: 150px;
        padding-bottom: 72px;
        background:
          radial-gradient(circle at 84% 18%, rgba(216, 184, 120, 0.16), transparent 30%),
          var(--paper);
      }

      .detail-hero > div {
        max-width: 650px;
        min-width: 0;
      }

      .back-link {
        display: inline-flex;
        margin-bottom: 28px;
        color: var(--wine);
        font-weight: 800;
      }

      .eyebrow {
        margin: 0 0 18px;
        color: var(--wine);
        font-size: 14px;
        font-weight: 800;
      }

      h1,
      h2,
      p {
        margin-top: 0;
      }

      h1,
      h2 {
        font-family: var(--font-display);
        font-weight: 650;
        line-height: 0.96;
      }

      h1 {
        margin-bottom: 22px;
        font-size: clamp(52px, 5.9vw, 88px);
        overflow-wrap: anywhere;
      }

      h2 {
        margin-bottom: 18px;
        font-size: clamp(38px, 4.8vw, 64px);
      }

      .summary,
      .detail-grid p {
        color: var(--muted);
        font-size: 18px;
      }

      .meta-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-top: 36px;
        border-top: 1px solid var(--line);
        padding-top: 18px;
        font-weight: 800;
      }

      .meta-row span {
        color: var(--muted);
      }

      .hero-bosen-link {
        display: inline-flex;
        min-height: 48px;
        align-items: center;
        gap: 12px;
        margin-top: 28px;
        border: 1px solid var(--brass-muted);
        border-radius: 6px;
        padding: 0 18px;
        background: var(--ink);
        color: var(--white);
        font-weight: 800;
        box-shadow: 0 14px 38px rgba(11, 11, 10, 0.12);
      }

      .hero-bosen-link::after {
        content: "↗";
        font-size: 18px;
        line-height: 1;
      }

      .detail-hero > img {
        width: 100%;
        height: min(680px, 72vh);
        object-fit: cover;
        border-radius: 8px;
        box-shadow: var(--shadow);
      }

      .gallery-section {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 18px;
        padding-top: 0;
        padding-bottom: 100px;
      }

      .gallery-section img {
        width: 100%;
        height: 100%;
        min-height: 340px;
        object-fit: cover;
        border-radius: 8px;
      }

      .gallery-section img:first-child:last-child {
        grid-column: 1 / -1;
      }

      .detail-grid {
        display: grid;
        grid-template-columns: minmax(0, 0.9fr) minmax(360px, 0.7fr);
        gap: 70px;
        padding-top: 100px;
        padding-bottom: 100px;
        background: var(--white);
      }

      .specs {
        display: grid;
        gap: 0;
        margin: 0;
        border-top: 1px solid var(--line);
      }

      .specs div {
        display: grid;
        grid-template-columns: 0.46fr 1fr;
        gap: 22px;
        padding: 18px 0;
        border-bottom: 1px solid var(--line);
      }

      dt {
        color: var(--muted);
        font-size: 14px;
      }

      dd {
        margin: 0;
        font-weight: 800;
      }

      .highlights {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        padding-top: 70px;
        padding-bottom: 70px;
        background: var(--paper-strong);
      }

      .highlights span {
        border: 1px solid rgba(11, 11, 10, 0.18);
        border-radius: 999px;
        padding: 10px 14px;
        background: rgba(255, 250, 242, 0.54);
        font-weight: 800;
      }

      .detail-cta {
        display: grid;
        grid-template-columns: minmax(0, 0.9fr) minmax(320px, 0.7fr);
        gap: 70px;
        align-items: center;
        padding-top: 100px;
        padding-bottom: 100px;
        background: linear-gradient(110deg, var(--ink), var(--charcoal));
        color: var(--white);
      }

      .detail-cta .eyebrow {
        color: var(--brass);
      }

      .cta-actions {
        display: grid;
        gap: 12px;
      }

      .button {
        display: inline-flex;
        min-height: 50px;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--brass);
        border-radius: 6px;
        padding: 0 20px;
        font-weight: 800;
      }

      .button.primary {
        background: var(--brass);
        color: var(--ink);
      }

      .button.secondary {
        color: var(--white);
      }

      .bosen-button {
        justify-content: space-between;
        gap: 12px;
      }

      .bosen-button::after {
        content: "↗";
        font-size: 18px;
        line-height: 1;
      }

      footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        padding: 26px max(28px, calc((100vw - 1180px) / 2)) 110px;
        background: #0b0b0a;
        color: rgba(255, 250, 242, 0.72);
      }

      footer p {
        margin: 0;
      }

      .footer-brand {
        display: flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
      }

      .footer-links {
        display: grid;
        justify-items: end;
        gap: 8px;
      }

      .social-icon {
        display: inline-grid;
        width: 38px;
        height: 38px;
        place-items: center;
        border: 1px solid rgba(255, 250, 242, 0.2);
        border-radius: 999px;
        color: rgba(255, 250, 242, 0.78);
        transition: border-color 160ms ease, color 160ms ease, transform 160ms ease;
      }

      .social-icon svg {
        width: 19px;
        height: 19px;
        fill: none;
        stroke: currentColor;
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-width: 1.8;
      }

      .social-icon:hover {
        border-color: var(--brass);
        color: var(--brass);
        transform: translateY(-1px);
      }

      .social-icon.is-disabled {
        cursor: default;
        opacity: 0.42;
        transform: none;
      }

      .social-icon.is-disabled:hover {
        border-color: rgba(255, 250, 242, 0.2);
        color: rgba(255, 250, 242, 0.78);
      }

      .footer-brand img {
        width: 118px;
        height: 52px;
        object-fit: contain;
      }

      .footer-brand .footer-bosen-logo {
        width: 170px;
        height: 42px;
        opacity: 0.88;
      }

      .footer-brand p {
        color: var(--white);
        font-family: var(--font-display);
        font-size: 24px;
        font-weight: 650;
      }

      @media (max-width: 980px) {
        .site-header {
          position: absolute;
          top: 12px;
        }

        nav {
          display: none;
        }

        .detail-hero,
        .detail-grid,
        .detail-cta {
          grid-template-columns: 1fr;
        }

        .detail-hero {
          min-height: auto;
          padding-top: 104px;
        }

        .gallery-section {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 620px) {
        .site-header {
          width: calc(100% - 20px);
          min-height: 58px;
          gap: 10px;
        }

        .brand-label span {
          font-size: 21px;
        }

        .brand-label {
          display: none;
        }

        .brand-cluster {
          gap: 8px;
        }

        .brand-divider {
          height: 28px;
        }

        .header-bosen-logo {
          width: 104px;
          height: 30px;
        }

        .brand-mark {
          width: 88px;
        }

        .header-booking {
          min-height: 38px;
          padding: 0 10px;
          font-size: 13px;
        }

        .detail-hero,
        .detail-section,
        .detail-cta {
          padding-inline: 18px;
        }

        h1 {
          font-size: 48px;
        }

        .meta-row,
        .specs div {
          grid-template-columns: 1fr;
          gap: 4px;
        }

        footer {
          display: grid;
          padding-inline: 18px;
          padding-bottom: 150px;
        }

        .footer-links {
          justify-items: start;
        }

        .footer-brand .footer-bosen-logo {
          width: 142px;
          height: 36px;
        }
      }
    </style>
  </body>
</html>
