---
import "../styles/global.css";
import CookieConsent from "../components/CookieConsent.astro";
import { site } from "../data/site";
import { createPageMeta, createSellerIntentJsonLd, serializeJsonLd } from "../data/seo";

const siteEnv = import.meta.env.PUBLIC_SITE_ENV ?? "production";
const isStaging = siteEnv !== "production";
const hasInstagram = site.contact.instagram.startsWith("http");
const pageMeta = createPageMeta({
  title: `Predaj bytu Bratislava | ${site.brand}`,
  description:
    "Predaj bytu v Bratislave s osobným maklérom Jakubom Olšom, predajnou stratégiou, BOSEN servisom, prezentáciou, kupujúcimi, právom a financovaním.",
  path: "/predaj-bytu-bratislava/",
  image: site.heroImage,
});

const faqs = [
  {
    question: "Ako začať predaj bytu v Bratislave?",
    answer:
      "Najprv treba oddeliť želanú cenu od reálneho predajného potenciálu. Prejdem lokalitu, stav bytu, dispozíciu, porovnateľné ponuky, časový tlak, právne riziká a cieľ majiteľa. Až potom má zmysel rozhodnúť, či ísť do verejnej inzercie, tichého predpredaja alebo najprv byt pripraviť.",
  },
  {
    question: "Prečo neriešiť predaj len cez inzerát na portáli?",
    answer:
      "Portál je iba distribučný kanál. Pri dobrom predaji rozhoduje cena, prezentácia, práca s databázou kupujúcich, obhliadky, vyjednávanie, zmluvy, financovanie a kataster. Ak sa tieto časti neriadia spolu, majiteľ často stráca čas, pokoj alebo časť ceny.",
  },
  {
    question: "Čo znamená BOSEN zázemie pri predaji bytu?",
    answer:
      "Majiteľ komunikuje s Jakubom ako jedným zodpovedným maklérom. Za procesom je však servisné zázemie BOSEN Group: marketing, obchodná sieť, právna a finančná koordinácia, príprava podkladov a skúsenosť s predajom rôznych typov nehnuteľností.",
  },
  {
    question: "Je konzultácia vhodná aj vtedy, keď ešte nechcem hneď predávať?",
    answer:
      "Áno. Práve vtedy má predajná stratégia najväčší zmysel. Dá sa porovnať predaj, prenájom, úprava bytu pred fotením, tichý test dopytu alebo načasovanie podľa nadväzujúcej kúpy.",
  },
];

const jsonLd = createSellerIntentJsonLd(pageMeta, faqs);

const intentSignals = [
  "chcem vedieť realistické cenové pásmo",
  "neviem, či predávať hneď alebo byt najprv pripraviť",
  "potrebujem vyriešiť kúpu ďalšieho bývania",
  "nechcem riešiť obhliadky, zmluvy a chaos sám",
];

const processSteps = [
  {
    step: "01",
    title: "Predajný audit",
    text: "Lokalita, dispozícia, stav, list vlastníctva, porovnateľné ponuky, časový tlak a cieľ majiteľa.",
  },
  {
    step: "02",
    title: "Stratégia ceny",
    text: "Cenové pásmo, argumenty pre kupujúceho, riziká prestrelenia ceny a plán úprav pred uvedením na trh.",
  },
  {
    step: "03",
    title: "Prezentácia a sieť",
    text: "Fotky, text, video alebo 3D podľa situácie, aktivácia BOSEN siete, kupujúcich a vhodných distribučných kanálov.",
  },
  {
    step: "04",
    title: "Obhliadky a vyjednávanie",
    text: "Kvalifikácia záujemcov, spätná väzba po obhliadkach, práca s ponukami a ochrana pozície majiteľa.",
  },
  {
    step: "05",
    title: "Zmluvy a odovzdanie",
    text: "Rezervácia, kúpna dokumentácia, úschova, hypotéka, kataster a odovzdanie bytu bez presúvania práce na predávajúceho.",
  },
];

const proofReferences = site.listings
  .filter((listing) => listing.group === "sold" && listing.title.toLowerCase().includes("byt"))
  .slice(0, 5);
---

<!doctype html>
<html lang="sk">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="icon" type="image/png" href="/favicon.png?v=2" />
    <link rel="icon" href="/favicon.ico?v=2" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={pageMeta.description} />
    <link rel="canonical" href={pageMeta.canonicalUrl} />
    <meta property="og:title" content={pageMeta.title} />
    <meta property="og:description" content={pageMeta.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageMeta.canonicalUrl} />
    <meta property="og:image" content={pageMeta.imageUrl} />
    <meta property="og:locale" content={site.locale.replace("-", "_")} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageMeta.title} />
    <meta name="twitter:description" content={pageMeta.description} />
    <meta name="twitter:image" content={pageMeta.imageUrl} />
    {isStaging ? <meta name="robots" content="noindex,nofollow,noarchive" /> : null}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700;800&family=Newsreader:opsz,wght@6..72,500;6..72,650;6..72,700&display=swap"
      rel="stylesheet"
    />
    <title>{pageMeta.title}</title>
    <script type="application/ld+json" set:html={serializeJsonLd(jsonLd)} />
  </head>
  <body>
    <a class="skip-link" href="#content">Prejsť na obsah</a>
    {isStaging ? <div class="staging-ribbon" aria-hidden="true">STAGING</div> : null}

    <header class="site-header">
      <div class="brand-cluster">
        <a class="brand" href="/" aria-label={`${site.brand}, späť na úvod`}>
          <img class="brand-mark" src={site.logoImage} alt="" />
          <span class="brand-label">
            <span>{site.brand}</span>
            <small>{site.role}</small>
          </span>
        </a>
        <span class="brand-divider" aria-hidden="true"></span>
        <img class="bosen-logo header-bosen-logo" src={site.bosenGroupLogo} alt="BOSEN Group" />
      </div>
      <nav aria-label="Navigácia stránky">
        <a href="#strategia">Stratégia</a>
        <a href="#proces">Proces</a>
        <a href="#dokazy">Referencie</a>
        <a href="#faq">FAQ</a>
      </nav>
      <a class="header-booking" href="/rezervacia/">Rezervácia</a>
    </header>

    <main id="content">
      <section class="seller-hero" aria-labelledby="hero-title">
        <div class="hero-copy">
          <a class="back-link" href="/">Späť na úvod</a>
          <p class="eyebrow">Predaj bytu v Bratislave</p>
          <h1 id="hero-title">Predajte byt ako riadený obchod, nie ako ďalší inzerát.</h1>
          <p class="summary">
            Jakub Olša vedie predaj osobne. BOSEN Group pridáva servisné zázemie pre stratégiu,
            prezentáciu, kupujúcich, právne kroky, financovanie a dotiahnutie obchodu.
          </p>
          <div class="hero-actions" aria-label="Hlavné akcie">
            <a class="button primary" href="/rezervacia/">Rezervovať predajnú konzultáciu</a>
            <a class="button secondary" href="#strategia">Ako začíname</a>
          </div>
        </div>
        <div class="hero-panel" aria-label="Čo majiteľ získa">
          <img src={site.cityPanoramaImage} alt="Bratislavská panoráma" />
          <div>
            <p>BOSEN zázemie</p>
            <strong>Jeden maklér na vašej strane, servisný aparát za procesom.</strong>
          </div>
        </div>
      </section>

      <section class="signal-strip" aria-label="Kedy má konzultácia zmysel">
        {
          intentSignals.map((signal) => (
            <p>
              <span></span>
              {signal}
            </p>
          ))
        }
      </section>

      <section class="section intro-grid" id="strategia" aria-labelledby="strategy-title">
        <div>
          <p class="eyebrow">Najprv stratégia</p>
          <h2 id="strategy-title">V Bratislave sa cena bytu neláme len na metroch.</h2>
          <p>
            Rozhoduje mikro-lokalita, stav domu, podlažie, dispozícia, parkovanie, energetika,
            susedné ponuky, aktivita kupujúcich a to, či byt pôsobí ako problém alebo príležitosť.
            Preto predaj nezačínam slovami „dáme to na portál“.
          </p>
        </div>
        <div class="strategy-card">
          <h3>Čo kontrolujem pred inzerciou</h3>
          <ul>
            <li>cenové pásmo a porovnateľné ponuky v Bratislave,</li>
            <li>stav, dispozíciu, fotogenickosť a nutné úpravy pred fotením,</li>
            <li>riziká z listu vlastníctva, financovania alebo nadväzujúcej kúpy,</li>
            <li>či má zmysel verejná kampaň, tichý predpredaj alebo najprv príprava bytu.</li>
          </ul>
        </div>
      </section>

      <section class="section dark-section" aria-labelledby="positioning-title">
        <div>
          <p class="eyebrow">Jakub + BOSEN Group</p>
          <h2 id="positioning-title">Osobný kontakt bez slabého zázemia.</h2>
        </div>
        <div class="positioning-grid">
          <article>
            <h3>Jakub drží obchod</h3>
            <p>
              Stratégia, komunikácia s majiteľom, obhliadky, spätná väzba a vyjednávanie
              ostávajú u jedného zodpovedného človeka.
            </p>
          </article>
          <article>
            <h3>BOSEN drží servis</h3>
            <p>
              Marketing, obchodná sieť, právna a finančná koordinácia, dokumenty a procesné
              zázemie nevznikajú improvizovane až po prvom záujemcovi.
            </p>
          </article>
          <article>
            <h3>Systém drží follow-up</h3>
            <p>
              Rezervácia konzultácie posiela kontext dopredu: zámer, lokalitu, typ bytu a časový
              horizont. Prvý hovor tak rieši konkrétny postup.
            </p>
          </article>
        </div>
      </section>

      <section class="section process-section" id="proces" aria-labelledby="process-title">
        <div class="section-heading">
          <p class="eyebrow">Proces predaja</p>
          <h2 id="process-title">Päť krokov, ktoré majú chrániť cenu, čas a pokoj majiteľa.</h2>
        </div>
        <div class="process-grid">
          {
            processSteps.map((item) => (
              <article class="process-item">
                <span>{item.step}</span>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section proof-section" id="dokazy" aria-labelledby="proof-title">
        <div class="section-heading">
          <p class="eyebrow">Referenčné predaje</p>
          <h2 id="proof-title">Dôkaz netreba nafukovať. Stačí ukázať konkrétne predaje.</h2>
          <p>
            Toto sú existujúce referencie z webu. Slúžia ako orientačný obraz práce s rôznymi
            bytmi v Bratislave, nie ako garancia rovnakého výsledku pri každej nehnuteľnosti.
          </p>
        </div>
        <div class="proof-grid">
          {
            proofReferences.map((listing) => (
              <article class="proof-card">
                <img src={listing.image} alt="" loading="lazy" />
                <div>
                  <p>{listing.status}</p>
                  <h3>{listing.title}</h3>
                  <dl>
                    <div>
                      <dt>Lokalita</dt>
                      <dd>{listing.place}</dd>
                    </div>
                    <div>
                      <dt>Výsledok</dt>
                      <dd>{listing.price}</dd>
                    </div>
                  </dl>
                  <a href={listing.href}>Pozrieť referenciu</a>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section audit-section" aria-labelledby="audit-title">
        <div>
          <p class="eyebrow">Predajný audit</p>
          <h2 id="audit-title">Ak uvažujete nad predajom bytu, pošlite najprv kontext.</h2>
          <p>
            V rezervačnom formulári vyberiete zámer, lokalitu, základné parametre a termín.
            Na hovor tak neprichádzame od nuly a vieme riešiť cenu, riziká aj ďalší krok.
          </p>
        </div>
        <a class="button primary" href="/rezervacia/">Prejsť na rezerváciu</a>
      </section>

      <section class="section faq-section" id="faq" aria-labelledby="faq-title">
        <div class="section-heading">
          <p class="eyebrow">FAQ</p>
          <h2 id="faq-title">Najčastejšie otázky pred predajom bytu v Bratislave.</h2>
        </div>
        <div class="faq-list">
          {
            faqs.map((faq) => (
              <details>
                <summary>{faq.question}</summary>
                <p>{faq.answer}</p>
              </details>
            ))
          }
        </div>
      </section>

      <section class="final-cta" aria-labelledby="final-cta-title">
        <div>
          <p class="eyebrow">Rezervácia konzultácie</p>
          <h2 id="final-cta-title">Najprv si povedzme, čo má váš byt reálne robiť na trhu.</h2>
        </div>
        <a class="button primary" href="/rezervacia/">Rezervovať konzultáciu</a>
      </section>
    </main>

    <a class="mobile-cta" href="/rezervacia/">Rezervácia konzultácie</a>

    <footer>
      <div class="footer-brand">
        <img src={site.logoImage} alt="" />
        <img class="bosen-logo footer-bosen-logo" src={site.bosenGroupLogo} alt="BOSEN Group" />
        {
          hasInstagram ? (
            <a
              class="social-icon"
              href={site.contact.instagram}
              target="_blank"
              rel="noreferrer"
              aria-label={site.contact.instagramLabel}
              title={site.contact.instagramLabel}
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="5" />
                <circle cx="12" cy="12" r="4" />
                <circle cx="17.5" cy="6.5" r="1.2" />
              </svg>
            </a>
          ) : null
        }
        <p>{site.brand}</p>
      </div>
      <p>{site.shortPromise}</p>
      <div class="footer-links">
        <a href="/#ponuky">Pozrieť ponuky</a>
        <a href="/ochrana-osobnych-udajov/">Ochrana údajov a cookies</a>
        <button type="button" data-cookie-consent-manage>Spravovať cookies</button>
      </div>
    </footer>

    <style>
      :root {
        --paper: #f6f1e8;
        --paper-strong: #e9dfcf;
        --ink: #0b0b0a;
        --charcoal: #1b1b19;
        --muted: #6f6a62;
        --wine: #9a5c32;
        --brass: #d8b878;
        --brass-muted: #b8945b;
        --white: #fffaf2;
        --line: rgba(11, 11, 10, 0.16);
        --shadow: 0 24px 70px rgba(11, 11, 10, 0.2);
        --font-body: "Instrument Sans", system-ui, sans-serif;
        --font-display: "Newsreader", Georgia, serif;
      }

      * {
        box-sizing: border-box;
      }

      html {
        overflow-x: hidden;
        scroll-behavior: smooth;
        scroll-padding-top: 110px;
      }

      body {
        margin: 0;
        background: var(--paper);
        color: var(--ink);
        font-family: var(--font-body);
        line-height: 1.5;
        overflow-x: clip;
      }

      body::after {
        position: fixed;
        inset: 0;
        z-index: 999;
        pointer-events: none;
        content: "";
        opacity: 0.035;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 180 180' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.45'/%3E%3C/svg%3E");
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        display: block;
        max-width: 100%;
      }

      .skip-link {
        position: fixed;
        top: 12px;
        left: 12px;
        z-index: 1000;
        transform: translateY(-140%);
        padding: 10px 14px;
        background: var(--ink);
        color: var(--white);
        border-radius: 4px;
      }

      .skip-link:focus {
        transform: translateY(0);
      }

      .staging-ribbon {
        position: fixed;
        right: 18px;
        bottom: 18px;
        z-index: 1200;
        border: 1px solid rgba(11, 11, 10, 0.16);
        border-radius: 999px;
        padding: 8px 12px;
        background: #f3cf74;
        color: var(--ink);
        box-shadow: 0 12px 30px rgba(11, 11, 10, 0.22);
        font-size: 12px;
        font-weight: 900;
      }

      .site-header {
        position: fixed;
        top: 18px;
        left: 50%;
        z-index: 50;
        display: flex;
        width: min(1180px, calc(100% - 32px));
        min-height: 64px;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        padding: 10px 14px 10px 18px;
        border: 1px solid rgba(216, 184, 120, 0.3);
        border-radius: 8px;
        background: rgba(11, 11, 10, 0.78);
        color: var(--white);
        transform: translateX(-50%);
        backdrop-filter: blur(18px);
      }

      .brand,
      .brand-cluster {
        display: flex;
        min-width: 0;
        align-items: center;
      }

      .brand {
        gap: 12px;
      }

      .brand-cluster {
        gap: 13px;
      }

      .brand-divider {
        width: 1px;
        height: 34px;
        background: rgba(255, 250, 242, 0.2);
      }

      .bosen-logo {
        display: block;
        object-fit: contain;
        object-position: center;
        mix-blend-mode: screen;
      }

      .header-bosen-logo {
        width: 164px;
        height: 36px;
        opacity: 0.9;
      }

      .brand-mark {
        width: 112px;
        height: 36px;
        object-fit: contain;
        object-position: center;
      }

      .brand-label {
        display: grid;
      }

      .brand-label span {
        font-family: var(--font-display);
        font-size: 24px;
        font-weight: 650;
        line-height: 1;
      }

      .brand-label small,
      nav {
        color: rgba(255, 250, 242, 0.72);
      }

      nav {
        display: flex;
        gap: 20px;
        font-size: 14px;
        font-weight: 650;
      }

      nav a,
      .header-booking,
      footer a {
        text-decoration-line: underline;
        text-decoration-color: transparent;
        text-decoration-thickness: 1px;
        text-underline-offset: 5px;
        transition: text-decoration-color 160ms ease, color 160ms ease;
      }

      nav a:hover,
      .header-booking:hover,
      footer a:hover {
        color: var(--brass);
        text-decoration-color: currentColor;
      }

      .header-booking {
        display: inline-flex;
        min-height: 42px;
        align-items: center;
        border: 1px solid rgba(255, 250, 242, 0.22);
        border-radius: 6px;
        padding: 0 14px;
        font-weight: 800;
        white-space: nowrap;
      }

      .seller-hero,
      .section,
      .signal-strip,
      .final-cta {
        padding-inline: max(28px, calc((100vw - 1180px) / 2));
      }

      .seller-hero {
        display: grid;
        min-height: 100svh;
        grid-template-columns: minmax(0, 0.92fr) minmax(420px, 1.08fr);
        gap: clamp(34px, 5vw, 72px);
        align-items: center;
        padding-top: 140px;
        padding-bottom: 78px;
        background:
          linear-gradient(108deg, rgba(11, 11, 10, 0.98) 0%, rgba(24, 24, 21, 0.94) 48%, rgba(11, 11, 10, 0.92) 100%),
          radial-gradient(circle at 76% 18%, rgba(216, 184, 120, 0.2), transparent 32%),
          var(--ink);
        color: var(--white);
      }

      .hero-copy {
        max-width: 720px;
      }

      .back-link {
        display: inline-flex;
        margin-bottom: 26px;
        color: var(--brass);
        font-weight: 800;
      }

      .eyebrow {
        margin: 0 0 18px;
        color: var(--wine);
        font-size: 14px;
        font-weight: 800;
      }

      .seller-hero .eyebrow,
      .dark-section .eyebrow,
      .final-cta .eyebrow {
        color: var(--brass);
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      h1,
      h2,
      h3,
      p {
        margin-top: 0;
      }

      h1,
      h2 {
        font-family: var(--font-display);
        font-weight: 650;
        line-height: 0.96;
      }

      h1 {
        max-width: 820px;
        margin-bottom: 22px;
        font-size: clamp(52px, 6vw, 86px);
        text-wrap: balance;
      }

      h2 {
        margin-bottom: 18px;
        font-size: clamp(38px, 4.8vw, 64px);
        text-wrap: balance;
      }

      h3 {
        margin-bottom: 10px;
        font-size: 23px;
        line-height: 1.15;
      }

      .summary {
        max-width: 690px;
        margin-bottom: 30px;
        color: rgba(255, 250, 242, 0.78);
        font-size: clamp(18px, 1.45vw, 22px);
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
      }

      .button {
        display: inline-flex;
        min-height: 50px;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--brass);
        border-radius: 6px;
        padding: 0 20px;
        font-weight: 800;
        transition: transform 160ms ease, background 160ms ease, color 160ms ease;
      }

      .button:hover {
        transform: translateY(-2px);
      }

      .button.primary {
        background: var(--brass);
        color: var(--ink);
      }

      .button.secondary {
        color: var(--white);
      }

      a:focus-visible,
      summary:focus-visible {
        outline: 2px solid var(--brass);
        outline-offset: 4px;
      }

      .hero-panel {
        position: relative;
      }

      .hero-panel img {
        width: 100%;
        height: min(660px, 72vh);
        object-fit: cover;
        border-radius: 8px;
        box-shadow: var(--shadow);
      }

      .hero-panel div {
        position: absolute;
        right: 22px;
        bottom: 22px;
        max-width: 330px;
        border: 1px solid rgba(216, 184, 120, 0.36);
        border-radius: 8px;
        padding: 18px;
        background: rgba(11, 11, 10, 0.82);
        color: var(--white);
        backdrop-filter: blur(16px);
      }

      .hero-panel p {
        margin-bottom: 8px;
        color: var(--brass);
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .hero-panel strong {
        font-family: var(--font-display);
        font-size: 26px;
        font-weight: 650;
        line-height: 1.04;
      }

      .signal-strip {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0;
        background: var(--paper-strong);
      }

      .signal-strip p {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 12px;
        min-height: 112px;
        align-items: center;
        margin: 0;
        border-right: 1px solid rgba(11, 11, 10, 0.12);
        padding: 20px 22px;
        font-weight: 800;
      }

      .signal-strip p:last-child {
        border-right: 0;
      }

      .signal-strip span {
        width: 9px;
        height: 9px;
        border-radius: 999px;
        background: var(--wine);
      }

      .section {
        padding-top: 100px;
        padding-bottom: 100px;
      }

      .intro-grid,
      .audit-section,
      .final-cta {
        display: grid;
        grid-template-columns: minmax(0, 0.95fr) minmax(340px, 0.75fr);
        gap: clamp(34px, 5vw, 70px);
        align-items: center;
      }

      .intro-grid p,
      .section-heading p,
      .audit-section p,
      .faq-list p,
      .positioning-grid p,
      .process-item p {
        color: var(--muted);
        font-size: 18px;
      }

      .strategy-card {
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
        padding: 30px 0;
      }

      .strategy-card ul {
        display: grid;
        gap: 14px;
        margin: 0;
        padding-left: 20px;
        color: var(--muted);
        font-size: 17px;
      }

      .dark-section,
      .final-cta {
        background: linear-gradient(110deg, var(--ink), var(--charcoal));
        color: var(--white);
      }

      .dark-section h2,
      .final-cta h2 {
        max-width: 820px;
      }

      .positioning-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
        margin-top: 26px;
      }

      .positioning-grid article {
        border-top: 1px solid rgba(255, 250, 242, 0.16);
        padding-top: 22px;
      }

      .positioning-grid h3,
      .positioning-grid p {
        color: var(--white);
      }

      .positioning-grid p {
        opacity: 0.72;
      }

      .section-heading {
        max-width: 760px;
        margin-bottom: 42px;
      }

      .process-grid {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 14px;
      }

      .process-item {
        border-top: 1px solid var(--line);
        padding-top: 18px;
      }

      .process-item span {
        display: inline-flex;
        margin-bottom: 18px;
        color: var(--wine);
        font-weight: 900;
      }

      .process-item h3 {
        min-height: 54px;
      }

      .proof-section {
        background: var(--white);
      }

      .proof-grid {
        display: grid;
        grid-template-columns: repeat(5, minmax(220px, 1fr));
        gap: 16px;
        overflow-x: auto;
        padding-bottom: 8px;
      }

      .proof-card {
        min-width: 220px;
        border-radius: 8px;
        background: var(--paper);
        overflow: hidden;
      }

      .proof-card img {
        width: 100%;
        aspect-ratio: 4 / 3;
        object-fit: cover;
      }

      .proof-card > div {
        padding: 18px;
      }

      .proof-card p {
        margin-bottom: 8px;
        color: var(--wine);
        font-size: 13px;
        font-weight: 900;
        text-transform: uppercase;
      }

      .proof-card h3 {
        min-height: 78px;
        font-size: 20px;
      }

      .proof-card dl {
        display: grid;
        gap: 10px;
        margin: 0 0 18px;
      }

      .proof-card dt {
        color: var(--muted);
        font-size: 12px;
      }

      .proof-card dd {
        margin: 0;
        font-weight: 800;
      }

      .proof-card a {
        color: var(--wine);
        font-weight: 900;
        text-decoration: underline;
        text-underline-offset: 4px;
      }

      .audit-section {
        background: var(--paper-strong);
      }

      .audit-section .button {
        justify-self: start;
      }

      .faq-list {
        display: grid;
        gap: 12px;
      }

      details {
        border-top: 1px solid var(--line);
        padding: 20px 0;
      }

      details:last-child {
        border-bottom: 1px solid var(--line);
      }

      summary {
        cursor: pointer;
        color: var(--ink);
        font-size: 22px;
        font-weight: 800;
      }

      details p {
        max-width: 860px;
        margin: 16px 0 0;
      }

      .final-cta {
        padding-top: 96px;
        padding-bottom: 104px;
      }

      .final-cta .button {
        justify-self: start;
      }

      .mobile-cta {
        position: fixed;
        left: 14px;
        right: 14px;
        bottom: 14px;
        z-index: 60;
        display: none;
        min-height: 54px;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        background: var(--brass);
        color: var(--ink);
        box-shadow: 0 14px 36px rgba(11, 11, 10, 0.24);
        font-weight: 900;
      }

      footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        padding: 26px max(28px, calc((100vw - 1180px) / 2)) 110px;
        background: #0b0b0a;
        color: rgba(255, 250, 242, 0.72);
      }

      footer p {
        margin: 0;
      }

      .footer-brand {
        display: flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
      }

      .footer-brand img {
        width: 118px;
        height: 52px;
        object-fit: contain;
      }

      .footer-brand .footer-bosen-logo {
        width: 170px;
        height: 42px;
        opacity: 0.88;
      }

      .footer-brand p {
        color: var(--white);
        font-family: var(--font-display);
        font-size: 24px;
        font-weight: 650;
      }

      .footer-links {
        display: grid;
        justify-items: end;
        gap: 8px;
      }

      .social-icon {
        display: inline-grid;
        width: 38px;
        height: 38px;
        place-items: center;
        border: 1px solid rgba(255, 250, 242, 0.2);
        border-radius: 999px;
        color: rgba(255, 250, 242, 0.78);
      }

      .social-icon svg {
        width: 19px;
        height: 19px;
        fill: none;
        stroke: currentColor;
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-width: 1.8;
      }

      @media (max-width: 1080px) {
        nav {
          display: none;
        }

        .seller-hero,
        .intro-grid,
        .audit-section,
        .final-cta {
          grid-template-columns: 1fr;
        }

        .seller-hero {
          min-height: auto;
        }

        .process-grid,
        .positioning-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .proof-grid {
          grid-template-columns: repeat(3, minmax(220px, 1fr));
        }
      }

      @media (max-width: 680px) {
        .site-header {
          position: absolute;
          top: 12px;
          width: calc(100% - 20px);
          min-height: 58px;
          gap: 10px;
        }

        .brand-label {
          display: none;
        }

        .brand-cluster {
          gap: 8px;
        }

        .brand-divider {
          height: 28px;
        }

        .header-bosen-logo {
          width: 104px;
          height: 30px;
        }

        .brand-mark {
          width: 88px;
        }

        .header-booking {
          min-height: 38px;
          padding: 0 10px;
          font-size: 13px;
        }

        .seller-hero,
        .section,
        .signal-strip,
        .final-cta {
          padding-inline: 18px;
        }

        .seller-hero {
          padding-top: 104px;
          padding-bottom: 56px;
        }

        h1 {
          font-size: 46px;
        }

        .hero-panel img {
          height: 360px;
        }

        .hero-panel div {
          position: static;
          max-width: none;
          border-radius: 0 0 8px 8px;
        }

        .signal-strip,
        .process-grid,
        .positioning-grid {
          grid-template-columns: 1fr;
        }

        .signal-strip p {
          min-height: 76px;
          border-right: 0;
          border-bottom: 1px solid rgba(11, 11, 10, 0.12);
          padding: 16px 0;
        }

        .signal-strip p:last-child {
          border-bottom: 0;
        }

        .section {
          padding-top: 72px;
          padding-bottom: 72px;
        }

        .process-item h3,
        .proof-card h3 {
          min-height: 0;
        }

        .proof-grid {
          grid-template-columns: 1fr;
          overflow-x: visible;
        }

        .mobile-cta {
          display: flex;
        }

        footer {
          display: grid;
          padding-inline: 18px;
          padding-bottom: 150px;
        }

        .footer-links {
          justify-items: start;
        }

        .footer-brand .footer-bosen-logo {
          width: 142px;
          height: 36px;
        }
      }
    </style>
    <CookieConsent />
  </body>
</html>
