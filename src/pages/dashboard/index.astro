  {
    index: "3",
    tone: "gold",
    title: "Schváliť OpenClaw draft",
    client: "Martinčekova inzerát",
    action: "Skontrolovať a publikovať",
    detail: "AI pripravil popis a parametre",
    time: "Čaká 2 hodiny",
  },
  {
    index: "4",
    tone: "blue",
    title: "Konzultácia o cene",
    client: "Anna Dudášová",
    action: "Pripraviť trhové porovnanie",
    detail: "Rodinný dom Rača - očakáva EUR 450k, trh je EUR 380-400k",
    time: "Zajtra, 10:00",
  },
  {
    index: "5",
    tone: "blue",
    title: "Poslať ponuku",
    client: "Tomáš Beňa",
    action: "Vybrať 3 byty v Ružinove",
    detail: "4-izb, rozpočet EUR 320k, potrebuje do 2 mesiacov",
    time: "Do konca dňa",
  },
];

const stats = [
  { icon: "€", value: "€2,414,000", label: "Celkový objem predajov", note: "6 predaných nehnuteľností", tone: "gold" },
  { icon: "↗", value: "€8,200", label: "Forecast provízie (30d)", note: "2 obchody v záverečnej fáze", tone: "green" },
  { icon: "◎", value: "12", label: "Nové leady (tento týždeň)", note: "3 kvalitných (A)", tone: "cyan" },
  { icon: "%", value: "42%", label: "Conversion rate", note: "Lead -> Konzultácia", tone: "purple" },
  { icon: "⌂", value: "1", label: "Aktívne ponuky", note: "Martinčekova - 2 dni na trhu", tone: "dark" },
  { icon: "◷", value: "14 dní", label: "Priemerná doba predaja", note: "Najrýchlejší: 8 dní", tone: "gold" },
  { icon: "⚡", value: "8", label: "Obhliadky (tento týždeň)", note: "3 plánované, 5 uskutočnené", tone: "orange" },
  { icon: "↗", value: "19", label: "Uzavreté obchody (YTD)", note: "2 miliónové obchody", tone: "green" },
];

const properties = [
  ["3-izb byt, Mamateyova 15", "Byt", "Bratislava", "Predané", "205,000 €", "12d", "8", "5", "Kataster", "Predané"],
  ["1,5-izb byt, Martinčekova", "Byt", "Bratislava", "V predaji", "cena na vyžiadanie", "2d", "3", "1", "Schváliť draft inzerátu", "Interný predpredaj"],
  ["3-izb byt, Šalviová 36", "Byt", "Bratislava", "Predané", "234,500 €", "15d", "12", "7", "Uzavreté", "Predané"],
  ["Polyfunkčný objekt, Orenburská", "Komerčný", "Podunajské Biskupice", "Predané", "810,000 €", "45d", "6", "4", "Uzavreté", "Predané"],
  ["4-izb byt, Skalická cesta", "Byt", "Bratislava", "Predané", "650,000 €", "8d", "15", "8", "Uzavreté", "Predané"],
  ["3-izb byt, luxusná rekonštrukcia", "Byt", "Bratislava", "Predané", "259,500 €", "10d", "18", "9", "Uzavreté", "Predané"],
  ["2-izb byt, Slnečnice", "Byt", "Petržalka", "Predané", "255,000 €", "14d", "10", "6", "Uzavreté", "Predané"],
];

const pipeline = [
  {
    stage: "Nový lead",
    count: "2",
    tone: "neutral",
    cards: [
      ["Petra Vrabcová", "B", "Kupujúci", "3-izb byt • Petržalka", "EUR 250,000", "3 mesiace", "Prvé bývanie", "Zajtra, 10:00"],
      ["Milan Koščo", "C", "Investor", "2-izb byt • Centrum", "EUR 180,000", "Flexibilný", "Investícia", "Kontakt: včera"],
    ],
  },
  {
    stage: "Kvalifikácia",
    count: "1",
    tone: "cyan",
    cards: [
      ["Anna Dudášová", "A", "Predávajúci", "Rodinný dom • Rača", "EUR 450,000 očakáva", "6 mesiacov", "Sťahovanie do zahraničia", "Zajtra - konzultácia"],
    ],
  },
  {
    stage: "Konzultácia",
    count: "1",
    tone: "purple",
    cards: [
      ["Tomáš Beňa", "A", "Kupujúci", "4-izb byt • Ružinov", "EUR 320,000", "2 mesiace", "Rozširuje rodinu", "Poslať ponuku"],
    ],
  },
  {
    stage: "Obhliadka",
    count: "2",
    tone: "gold",
    cards: [
      ["Eva Krajčová", "A", "Kupujúci", "1,5-izb byt • Martinčekova", "Cena na vyžiadanie", "urgentné", "Nutne potrebuje bývanie", "Follow-up urgentný"],
    ],
  },
];

const approvals = [
  ["Martinčekova - popis bytu", "inzerát", "Pred 2 hodinami"],
  ["Sumarizácia hovoru s E. Krajčovou", "poznámka", "Pred 18 hodinami"],
  ["Follow-up P. Vrabcová", "task", "Dnes, 14:30"],
];
---

<!doctype html>
<html lang="sk">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="icon" type="image/png" href="/favicon.png?v=2" />
    <link rel="icon" href="/favicon.ico?v=2" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta
      name="description"
      content="Interný prototyp dashboardu pre Jakuba Olšu, booking, OpenClaw agenta a realitný CRM workflow."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>Staging dashboard | {site.brand}</title>
    <style>
      :root {
        --bg: #f6f7f8;
        --panel: #ffffff;
        --panel-soft: #f4f6f8;
        --line: #dfe4ea;
        --line-strong: #cfd7df;
        --text: #172033;
        --muted: #687382;
        --gold: #d39a2d;
        --gold-soft: #fff7eb;
        --green: #20a84f;
        --green-soft: #edf9f1;
        --cyan: #12a8bc;
        --cyan-soft: #eefbfe;
        --orange: #f39a16;
        --orange-soft: #fff6e8;
        --purple: #875cff;
        --purple-soft: #f3efff;
        --danger: #e23a55;
        --danger-soft: #fff0f3;
        --shadow: 0 10px 28px rgba(21, 31, 45, 0.08);
        --radius: 18px;
        --font-body: "Instrument Sans", system-ui, sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      body {
        min-width: 320px;
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: var(--font-body);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .dashboard-shell {
        width: min(1500px, 100%);
        margin: 0 auto;
        padding: 28px;
      }

      .topbar {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 24px;
        align-items: start;
        padding-bottom: 28px;
        border-bottom: 1px solid var(--line-strong);
      }

      .identity {
        display: grid;
        grid-template-columns: 56px minmax(0, 1fr);
        gap: 16px;
        align-items: center;
      }

      .mark,
      .icon-bubble {
        display: grid;
        width: 56px;
        height: 56px;
        place-items: center;
        border-radius: 50%;
      }

      .mark {
        background: var(--gold);
        color: #fff;
        font-size: 26px;
        font-weight: 800;
      }

      h1,
      h2,
      h3,
      p {
        margin-top: 0;
      }

      h1 {
        margin-bottom: 2px;
        font-size: clamp(30px, 4vw, 42px);
        line-height: 1;
        letter-spacing: 0;
      }

      .role {
        margin-bottom: 12px;
        color: var(--muted);
        font-size: 16px;
      }

      .role span {
        color: var(--gold);
      }

      .contact-row {
        display: flex;
        flex-wrap: wrap;
        gap: 14px 22px;
        color: var(--muted);
        font-size: 15px;
      }

      .contact-row span {
        display: inline-flex;
        gap: 7px;
        align-items: center;
      }

      .datebox {
        text-align: right;
      }

      .datebox p {
        margin-bottom: 6px;
        color: var(--muted);
        font-size: 15px;
      }

      .datebox strong {
        font-size: 30px;
        font-weight: 500;
      }

      .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 22px;
        margin-top: 40px;
      }

      .card,
      .stat-card {
        border: 1px solid var(--line);
        border-radius: var(--radius);
        background: var(--panel);
        box-shadow: var(--shadow);
      }

      .stat-card {
        min-height: 174px;
        padding: 24px;
      }

      .icon-bubble {
        width: 46px;
        height: 46px;
        margin-bottom: 20px;
        font-size: 19px;
        font-weight: 800;
      }

      .tone-gold {
        color: var(--gold);
      }

      .tone-green {
        color: var(--green);
      }

      .tone-cyan {
        color: var(--cyan);
      }

      .tone-orange {
        color: var(--orange);
      }

      .tone-purple {
        color: var(--purple);
      }

      .tone-danger {
        color: var(--danger);
      }

      .bg-gold {
        background: var(--gold-soft);
      }

      .bg-green {
        background: var(--green-soft);
      }

      .bg-cyan {
        background: var(--cyan-soft);
      }

      .bg-orange {
        background: var(--orange-soft);
      }

      .bg-purple {
        background: var(--purple-soft);
      }

      .bg-danger {
        background: var(--danger-soft);
      }

      .bg-dark {
        background: #eef1f4;
      }

      .stat-card strong {
        display: block;
        margin-bottom: 8px;
        font-size: clamp(26px, 3vw, 34px);
        font-weight: 500;
      }

      .stat-card p {
        margin-bottom: 7px;
        font-size: 15px;
        font-weight: 600;
      }

      .stat-card small {
        color: var(--muted);
        font-size: 13px;
      }

      .main-grid {
        display: grid;
        grid-template-columns: minmax(0, 3fr) minmax(300px, 1fr);
        gap: 26px;
        margin-top: 30px;
      }

      .section-card {
        padding: 30px;
      }

      .section-head {
        display: flex;
        gap: 16px;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
      }

      .section-head h2 {
        margin: 0;
        font-size: 26px;
        letter-spacing: 0;
      }

      .pill {
        display: inline-flex;
        min-height: 30px;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 4px 12px;
        background: var(--panel-soft);
        color: var(--muted);
        font-size: 13px;
        font-weight: 600;
        white-space: nowrap;
      }

      .pill.gold {
        border-color: #edd4a6;
        background: var(--gold-soft);
        color: var(--gold);
      }

      .pill.green {
        border-color: #bfeacb;
        background: var(--green-soft);
        color: var(--green);
      }

      .pill.danger {
        border-color: #ffc2cb;
        background: var(--danger-soft);
        color: var(--danger);
      }

      .priority-list {
        display: grid;
        gap: 16px;
      }

      .priority-card {
        display: grid;
        grid-template-columns: 46px 46px minmax(0, 1fr) auto;
        gap: 16px;
        align-items: start;
        border: 2px solid transparent;
        border-radius: 22px;
        padding: 18px;
      }

      .priority-card.danger {
        border-color: #ffc1ca;
        background: var(--danger-soft);
      }

      .priority-card.gold {
        border-color: #efd6a8;
        background: #fffbf4;
      }

      .priority-card.blue {
        border-color: #bdeaf0;
        background: var(--cyan-soft);
      }

      .priority-index {
        display: grid;
        width: 38px;
        height: 38px;
        place-items: center;
        border-radius: 50%;
        background: var(--gold);
        color: #fff;
        font-weight: 800;
      }

      .priority-card.danger .priority-index {
        background: var(--danger);
      }

      .priority-card.blue .priority-index {
        background: var(--cyan);
      }

      .priority-icon {
        display: grid;
        width: 38px;
        height: 38px;
        place-items: center;
        border: 1px solid var(--line);
        border-radius: 50%;
        background: #fff;
        color: inherit;
        font-weight: 800;
      }

      .priority-card h3 {
        margin: 0 0 6px;
        font-size: 19px;
      }

      .priority-card .client {
        margin-bottom: 10px;
        color: var(--gold);
        font-weight: 600;
      }

      .priority-card.danger .client {
        color: var(--danger);
      }

      .priority-card.blue .client {
        color: var(--cyan);
      }

      .action-line {
        width: min(720px, 100%);
        margin-bottom: 12px;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 10px 14px;
        background: #fff;
        font-weight: 600;
      }

      .action-line span {
        font-weight: 800;
      }

      .detail {
        margin: 0;
        color: var(--muted);
        font-size: 14px;
      }

      .priority-summary {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
        margin-top: 28px;
        border-top: 1px solid var(--line);
        padding-top: 22px;
        text-align: center;
      }

      .priority-summary strong {
        display: block;
        margin-bottom: 6px;
        font-size: 26px;
        font-weight: 500;
      }

      .openclaw-card {
        position: sticky;
        top: 20px;
      }

      .status-list {
        display: grid;
        gap: 13px;
        margin-bottom: 28px;
      }

      .status-pill {
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-radius: 999px;
        padding: 12px 14px;
        background: #e9edf1;
        font-weight: 600;
      }

      .dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        margin-right: 8px;
        border-radius: 50%;
        background: var(--green);
      }

      .approval-list {
        display: grid;
        gap: 12px;
        margin-bottom: 22px;
      }

      .approval-card {
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 16px;
        background: #fff;
      }

      .approval-card p {
        margin-bottom: 8px;
        font-weight: 700;
      }

      .approval-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
        color: var(--muted);
        font-size: 13px;
      }

      .button {
        display: inline-flex;
        width: 100%;
        min-height: 52px;
        align-items: center;
        justify-content: center;
        border: 0;
        border-radius: 999px;
        background: var(--text);
        color: #fff;
        font: inherit;
        font-weight: 800;
      }

      .portfolio-card,
      .pipeline-card,
      .analytics-card {
        margin-top: 30px;
      }

      .table-wrap {
        overflow-x: auto;
        padding-bottom: 4px;
      }

      table {
        width: 100%;
        min-width: 1060px;
        border-collapse: separate;
        border-spacing: 0 10px;
      }

      th {
        background: #e8edf2;
        color: var(--muted);
        font-size: 13px;
        font-weight: 700;
        text-align: left;
      }

      th,
      td {
        padding: 13px 14px;
      }

      th:first-child {
        border-radius: 999px 0 0 999px;
      }

      th:last-child {
        border-radius: 0 999px 999px 0;
      }

      tbody tr {
        background: #fff;
        outline: 1px solid var(--line);
      }

      tbody tr.active-row {
        background: #f7fcf9;
        outline: 2px solid var(--green);
      }

      td:first-child {
        border-radius: 18px 0 0 18px;
      }

      td:last-child {
        border-radius: 0 18px 18px 0;
      }

      .property-title {
        display: flex;
        gap: 12px;
        align-items: center;
        font-weight: 700;
      }

      .bullet {
        width: 9px;
        height: 9px;
        border-radius: 50%;
        background: var(--muted);
      }

      .active-row .bullet {
        background: var(--green);
      }

      .sub {
        display: block;
        margin-top: 3px;
        color: var(--muted);
        font-size: 13px;
        font-weight: 500;
      }

      .pipeline-scroll {
        overflow-x: auto;
        padding-bottom: 6px;
      }

      .pipeline-grid {
        display: grid;
        width: max(100%, 1180px);
        grid-template-columns: repeat(4, minmax(270px, 1fr));
        gap: 16px;
      }

      .stage {
        display: grid;
        gap: 12px;
      }

      .stage-head {
        border: 1px solid var(--line);
        border-radius: 22px;
        padding: 16px;
        background: #f8f9fa;
        text-align: center;
      }

      .stage-head strong {
        display: block;
        margin-top: 6px;
        color: var(--muted);
        font-size: 28px;
        font-weight: 500;
      }

      .lead-card {
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 18px;
        background: #fff;
      }

      .lead-card h3 {
        margin-bottom: 8px;
        font-size: 17px;
      }

      .lead-card .grade {
        display: inline-flex;
        margin-left: 6px;
        border: 1px solid #eed4a5;
        border-radius: 5px;
        padding: 1px 6px;
        color: var(--gold);
        font-size: 12px;
      }

      .lead-card p {
        margin-bottom: 9px;
        color: var(--muted);
        font-size: 14px;
      }

      .lead-tag {
        display: inline-flex;
        border-radius: 999px;
        padding: 8px 12px;
        background: #e9edf1;
        font-size: 13px;
        font-weight: 600;
      }

      .bottom-grid {
        display: grid;
        grid-template-columns: minmax(0, 2fr) minmax(300px, 1fr);
        gap: 26px;
        margin-top: 30px;
      }

      .chart-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 280px;
        gap: 32px;
        align-items: center;
      }

      .bars {
        display: grid;
        height: 260px;
        grid-template-columns: repeat(6, 1fr);
        gap: 16px;
        align-items: end;
        border-left: 1px dashed var(--line-strong);
        border-bottom: 1px dashed var(--line-strong);
        padding: 20px 0 0 20px;
      }

      .bar {
        position: relative;
        border-radius: 9px 9px 0 0;
        background: linear-gradient(180deg, #d9a94e, #c99332);
      }

      .bar span {
        position: absolute;
        right: 0;
        bottom: -28px;
        left: 0;
        color: var(--muted);
        font-size: 13px;
        text-align: center;
      }

      .donut {
        width: 170px;
        height: 170px;
        margin: 0 auto 20px;
        border-radius: 50%;
        background: conic-gradient(var(--cyan) 0 35%, var(--green) 35% 63%, var(--gold) 63% 85%, var(--purple) 85% 95%, #6b7280 95%);
        mask: radial-gradient(circle, transparent 43%, #000 44%);
      }

      .source-list {
        display: grid;
        gap: 10px;
      }

      .source-list div {
        display: flex;
        justify-content: space-between;
        color: var(--muted);
        font-size: 14px;
      }

      .mini-stats {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 16px;
        margin-top: 34px;
        border-top: 1px solid var(--line);
        padding-top: 28px;
      }

      .mini-stat {
        border-radius: 18px;
        padding: 16px;
        background: #e9edf1;
        text-align: center;
      }

      .mini-stat span {
        display: block;
        margin-bottom: 8px;
        color: var(--muted);
        font-size: 13px;
      }

      .mini-stat strong {
        color: var(--text);
        font-size: 24px;
        font-weight: 500;
      }

      .track-record {
        border-color: #d9a94e;
      }

      .track-list {
        display: grid;
        gap: 26px;
        margin-top: 26px;
      }

      .track-list div {
        display: grid;
        grid-template-columns: 46px 1fr;
        gap: 14px;
        align-items: center;
      }

      .dashboard-note {
        margin: 30px 0 0;
        color: var(--muted);
        font-size: 13px;
        text-align: center;
      }

      @media (max-width: 1320px) {
        .stats-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .main-grid,
        .bottom-grid,
        .chart-grid {
          grid-template-columns: 1fr;
        }

        .openclaw-card {
          position: static;
        }
      }

      @media (max-width: 720px) {
        .dashboard-shell {
          padding: 18px 14px 34px;
        }

        .topbar {
          grid-template-columns: 1fr;
        }

        .datebox {
          text-align: left;
        }

        .identity {
          grid-template-columns: 48px 1fr;
        }

        .mark {
          width: 48px;
          height: 48px;
          font-size: 22px;
        }

        .contact-row {
          display: grid;
          gap: 8px;
        }

        .stats-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
          gap: 12px;
          margin-top: 24px;
        }

        .stat-card {
          min-height: 152px;
          padding: 16px;
        }

        .stat-card strong {
          font-size: 24px;
          word-break: break-word;
        }

        .section-card {
          padding: 18px;
        }

        .priority-card {
          grid-template-columns: 36px minmax(0, 1fr);
          gap: 12px;
        }

        .priority-icon,
        .priority-card .pill {
          display: none;
        }

        .priority-summary,
        .mini-stats {
          grid-template-columns: 1fr;
        }

        .pipeline-grid {
          width: 100%;
          grid-template-columns: 1fr;
        }

        .bars {
          height: 210px;
          gap: 8px;
        }
      }
    </style>
  </head>
  <body>
    <div class="dashboard-app-shell">
      <DashboardSidebar active="overview" />
      <main class="dashboard-shell dashboard-content">
      <section class="stats-grid" aria-label="Kľúčové metriky">
        {stats.map((stat) => (
          <article class="stat-card">
            <span class={`icon-bubble bg-${stat.tone} tone-${stat.tone}`}>{stat.icon}</span>
            <strong class={`tone-${stat.tone}`}>{stat.value}</strong>
            <p>{stat.label}</p>
            <small>{stat.note}</small>
          </article>
        ))}
      </section>

      <section class="main-grid">
        <article class="card section-card">
          <div class="section-head">
            <h2>Dnešné priority - TOP 5</h2>
            <span class="pill danger">1 urgentné</span>
          </div>
          <div class="priority-list">
            {priorities.map((item) => (
              <article class={`priority-card ${item.tone}`}>
                <span class="priority-index">{item.index}</span>
                <span class="priority-icon" aria-hidden="true">◷</span>
                <div>
                  <h3>{item.title}</h3>
                  <div class="client">{item.client}</div>
                  <div class="action-line"><span>Akcia:</span> {item.action}</div>
                  <p class="detail">{item.detail}</p>
                </div>
                <span class="pill">{item.time}</span>
              </article>
            ))}
          </div>
          <div class="priority-summary">
            <div><strong class="tone-danger">2</strong><span>Kritické</span></div>
            <div><strong class="tone-gold">2</strong><span>Vysoká priorita</span></div>
            <div><strong class="tone-cyan">1</strong><span>Normálna</span></div>
          </div>
        </article>

        <aside class="card section-card openclaw-card" id="openclaw">
          <div class="section-head">
            <h2>OpenClaw Agent</h2>
          </div>
          <div class="status-list">
            <div class="status-pill"><span><i class="dot"></i>Agent status</span><span class="pill green">Online</span></div>
            <div class="status-pill"><span>Telegram</span><span class="tone-green">✓</span></div>
            <div class="status-pill"><span>Google Calendar</span><span class="tone-green">✓</span></div>
          </div>
          <div class="section-head">
            <h3>Na schválenie</h3>
            <span class="pill gold">3</span>
          </div>
          <div class="approval-list">
            {approvals.map((approval) => (
              <article class="approval-card">
                <p>{approval[0]}</p>
                <div class="approval-meta">
                  <span class="pill">{approval[1]}</span>
                  <span>{approval[2]}</span>
                </div>
              </article>
            ))}
          </div>
          <a class="button" href="/rezervacia/">Skontrolovať drafty</a>
        </aside>
      </section>

      <section class="card section-card portfolio-card" id="nehnutelnosti">
        <div class="section-head">
          <h2>Moje nehnuteľnosti</h2>
          <span class="sub">1 aktívne • 6 predané</span>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Názov / Typ</th>
                <th>Lokalita</th>
                <th>Status</th>
                <th>Cena</th>
                <th>DoM</th>
                <th>Leady</th>
                <th>Obhl.</th>
                <th>Ďalší krok</th>
                <th>Stratégia</th>
              </tr>
            </thead>
            <tbody>
              {properties.map((row) => (
                <tr class={row[3] === "V predaji" ? "active-row" : ""}>
                  <td>
                    <span class="property-title"><span class="bullet"></span>{row[0]}</span>
                    <span class="sub">{row[1]}</span>
                  </td>
                  <td>{row[2]}</td>
                  <td><span class={row[3] === "V predaji" ? "pill green" : "pill"}>{row[3]}</span></td>
                  <td>{row[4]}</td>
                  <td><span class="pill">{row[5]}</span></td>
                  <td>{row[6]}</td>
                  <td>{row[7]}</td>
                  <td><span class="pill">{row[8]}</span></td>
                  <td><span class={row[9] === "Interný predpredaj" ? "pill gold" : "pill"}>{row[9]}</span></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section class="card section-card pipeline-card">
        <div class="section-head">
          <h2>Pipeline klientov</h2>
          <span class="sub">7 aktívnych klientov</span>
        </div>
        <div class="pipeline-scroll">
          <div class="pipeline-grid">
            {pipeline.map((stage) => (
              <div class="stage">
                <div class={`stage-head bg-${stage.tone}`}>
                  <span>{stage.stage}</span>
                  <strong class={`tone-${stage.tone}`}>{stage.count}</strong>
                </div>
                {stage.cards.map((card) => (
                  <article class="lead-card">
                    <h3>{card[0]} <span class="grade">{card[1]}</span></h3>
                    <p>{card[2]}</p>
                    <p><strong>{card[3]}</strong></p>
                    <p>{card[4]} · {card[5]}</p>
                    <span class="lead-tag">{card[6]}</span>
                    <p class="detail" style="margin-top: 12px;">{card[7]}</p>
                  </article>
                ))}
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="bottom-grid">
        <article class="card section-card analytics-card">
          <div class="section-head">
            <h2>Výkonnosť a zdroje dealov</h2>
          </div>
          <div class="chart-grid">
            <div>
              <h3>Mesačná výkonnosť</h3>
              <div class="bars" aria-label="Mesačná výkonnosť graf">
                <div class="bar" style="height: 42%;"><span>Jan</span></div>
                <div class="bar" style="height: 32%;"><span>Feb</span></div>
                <div class="bar" style="height: 92%;"><span>Mar</span></div>
                <div class="bar" style="height: 74%;"><span>Apr</span></div>
                <div class="bar" style="height: 28%;"><span>Máj</span></div>
                <div class="bar" style="height: 16%;"><span>Jún</span></div>
              </div>
            </div>
            <div>
              <h3>Zdroje dealov</h3>
              <div class="donut" aria-hidden="true"></div>
              <div class="source-list">
                <div><span>Web</span><strong>35%</strong></div>
                <div><span>Odporúčanie</span><strong>28%</strong></div>
                <div><span>BOSEN sieť</span><strong>22%</strong></div>
                <div><span>Reklama</span><strong>10%</strong></div>
                <div><span>Vlastná sieť</span><strong>5%</strong></div>
              </div>
            </div>
          </div>
          <div class="mini-stats">
            <div class="mini-stat"><span>Objem (6M)</span><strong class="tone-gold">€2.41M</strong></div>
            <div class="mini-stat"><span>Leady (6M)</span><strong>69</strong></div>
            <div class="mini-stat"><span>Avg. obchod</span><strong class="tone-green">€402k</strong></div>
            <div class="mini-stat"><span>Conv. rate</span><strong class="tone-cyan">8.7%</strong></div>
          </div>
        </article>

        <aside class="card section-card track-record">
          <h2 class="tone-gold">Track Record</h2>
          <div class="track-list">
            <div><span class="icon-bubble bg-gold tone-gold">↗</span><p>19 uzavretých predajov za posledných 12 mesiacov</p></div>
            <div><span class="icon-bubble bg-gold tone-gold">◎</span><p>2 miliónové obchody</p></div>
            <div><span class="icon-bubble bg-gold tone-gold">▤</span><p>5 rokov skúseností v obchode, bankovníctve a realitách</p></div>
          </div>
        </aside>
      </section>

      <p class="dashboard-note">
        Interný staging prototyp: booking, Google Calendar a Supabase CRM už majú funkčný základ, ale verejný dashboard zobrazuje iba demo dáta, kým nebude zapnutá ochrana prístupu.
      </p>
      </main>
    </div>
  </body>
</html>
