---
import "../../styles/global.css";
import { site } from "../../data/site";
import DashboardSidebar from "../../components/dashboard/DashboardSidebar.astro";

const priorities = [
  {
    index: "1",
    tone: "danger",
    title: "Follow-up po obhliadke",
    client: "Eva Krajčová",
    action: "Zavolať a zistiť feedback",
    detail: "Martinčekova, 1,5-izb - prejavila veľký záujem",
    time: "Pred 18 hodinami",
  },
  {
    index: "2",
    tone: "gold",
    title: "Prvý kontakt - nový lead",
    client: "Petra Vrabcová",
