const firstLead = leads[0];
const followUpTasks = leads
  .map((lead) => ({
    id: lead.id,
    name: lead.name,
    action: lead.nextAction,
    time: lead.nextTime,
    property: lead.property,
    status: lead.status,
    priority: lead.priority,
    window: lead.followUpWindow,
    grade: lead.grade,
