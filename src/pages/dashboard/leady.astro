---

<!doctype html>
<html lang="sk">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="icon" type="image/png" href="/favicon.png?v=2" />
    <link rel="icon" href="/favicon.ico?v=2" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta
      name="description"
      content="Lead zoznam pre interný dashboard Jakuba Olšu a OpenClaw realitný workflow."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>Lead zoznam | Staging dashboard | {site.brand}</title>
    <style>
      :root {
        --bg: #f6f7f8;
        --panel: #ffffff;
        --panel-soft: #f4f6f8;
        --line: #dfe4ea;
        --line-strong: #cfd7df;
        --text: #172033;
        --muted: #687382;
        --gold: #d39a2d;
        --gold-soft: #fff7eb;
        --green: #20a84f;
        --green-soft: #edf9f1;
        --cyan: #12a8bc;
        --cyan-soft: #eefbfe;
        --purple: #875cff;
        --purple-soft: #f3efff;
        --danger: #e23a55;
        --danger-soft: #fff0f3;
        --shadow: 0 10px 28px rgba(21, 31, 45, 0.08);
        --radius: 18px;
        --sidebar: #111827;
        --font-body: "Instrument Sans", system-ui, sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: var(--font-body);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      button {
        font: inherit;
      }

      .app-shell {
        display: grid;
        min-height: 100svh;
        grid-template-columns: 280px minmax(0, 1fr);
      }

      .sidebar {
        position: sticky;
        top: 0;
        display: flex;
        height: 100svh;
        flex-direction: column;
        gap: 24px;
        padding: 24px;
        background: var(--sidebar);
        color: #f9fafb;
      }

      .brand-lockup {
        display: grid;
        grid-template-columns: 46px minmax(0, 1fr);
        gap: 12px;
        align-items: center;
      }

      .brand-mark {
        display: grid;
        width: 46px;
        height: 46px;
        place-items: center;
        border-radius: 50%;
        background: var(--gold);
        color: #fff;
        font-weight: 800;
      }

      .brand-lockup strong {
        display: block;
        font-size: 18px;
      }

      .brand-lockup span {
        color: #aab4c2;
        font-size: 13px;
      }

      .side-nav {
        display: grid;
        gap: 8px;
      }

      .side-nav a {
        display: grid;
        grid-template-columns: 32px 1fr;
        gap: 10px;
        align-items: center;
        border: 1px solid transparent;
        border-radius: 12px;
        padding: 11px 12px;
        color: #cbd5e1;
        font-size: 15px;
        font-weight: 700;
      }

      .side-nav a:hover,
      .side-nav a.active {
        border-color: rgba(211, 154, 45, 0.35);
        background: rgba(211, 154, 45, 0.14);
        color: #fff;
      }

      .side-meta {
        margin-top: auto;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 14px;
        padding: 14px;
        color: #aab4c2;
        font-size: 13px;
      }

      .side-meta strong {
        display: block;
        margin-bottom: 6px;
        color: #fff;
      }

      .content {
        width: min(1320px, 100%);
        margin: 0 auto;
        padding: 30px;
      }

      .topbar {
        display: flex;
        gap: 18px;
        align-items: start;
        justify-content: space-between;
        margin-bottom: 26px;
      }

      .eyebrow {
        margin: 0 0 8px;
        color: var(--gold);
        font-size: 13px;
        font-weight: 800;
        text-transform: uppercase;
      }

      h1,
      h2,
      h3,
      p {
        margin-top: 0;
      }

      h1 {
        margin-bottom: 10px;
        font-size: clamp(34px, 5vw, 54px);
        line-height: 1;
        letter-spacing: 0;
      }

      .lead-intro {
        max-width: 680px;
        margin-bottom: 0;
        color: var(--muted);
        font-size: 17px;
        line-height: 1.55;
      }

      .status-chip {
        display: inline-flex;
        min-height: 34px;
        align-items: center;
        justify-content: center;
        border: 1px solid #bfeacb;
        border-radius: 999px;
        padding: 6px 13px;
        background: var(--green-soft);
        color: var(--green);
        font-size: 13px;
        font-weight: 800;
        white-space: nowrap;
      }

      .metrics {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 16px;
        margin-bottom: 28px;
      }

      .metric-card,
      .panel {
        border: 1px solid var(--line);
        border-radius: var(--radius);
        background: var(--panel);
        box-shadow: var(--shadow);
      }

      .metric-card {
        padding: 18px;
      }

      .metric-card span {
        display: block;
        margin-bottom: 8px;
        color: var(--muted);
        font-size: 13px;
        font-weight: 700;
      }

      .metric-card strong {
        font-size: 30px;
        font-weight: 500;
      }

      .page-divider {
        width: 100%;
        height: 1px;
        margin: 0 0 28px;
        border: 0;
        background: var(--line-strong);
      }

      .workspace {
        display: grid;
        grid-template-columns: minmax(280px, 0.82fr) minmax(0, 1.8fr);
        gap: 18px;
        align-items: start;
      }

      .panel {
        padding: 24px;
      }

      .panel-head {
        display: flex;
        gap: 14px;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
      }

      .panel-head h2 {
        margin: 0;
        font-size: 24px;
      }

      .panel-kicker {
        margin: 6px 0 0;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.45;
      }

      .queue-panel {
        position: sticky;
        top: 20px;
      }

      .queue-list {
        display: grid;
        gap: 10px;
      }

      .queue-card {
        display: grid;
        width: 100%;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 12px;
        align-items: start;
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 13px;
        background: #fff;
        color: inherit;
        cursor: pointer;
        text-align: left;
      }

      .queue-card:hover,
      .queue-card.is-active {
        border-color: var(--gold);
        background: #fffdf8;
      }

      .queue-card.urgent {
        border-color: #ffc2cb;
        background: var(--danger-soft);
      }

      .queue-card strong,
      .queue-card span {
        display: block;
      }

      .queue-card strong {
        margin-bottom: 5px;
        font-size: 15px;
      }

      .queue-card small {
        display: block;
        color: var(--muted);
        font-size: 12px;
        line-height: 1.4;
      }

      .queue-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: 10px;
      }

      .searchbar {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 12px;
        margin-bottom: 16px;
      }

      .searchbar input {
        min-height: 46px;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 0 16px;
        background: var(--panel-soft);
        color: var(--text);
        font: inherit;
      }

      .searchbar button,
      .primary-action {
        border: 0;
        border-radius: 999px;
        background: var(--text);
        color: #fff;
        cursor: pointer;
        font-weight: 800;
      }

      .searchbar button {
        padding: 0 18px;
      }

      .lead-list {
        display: grid;
        gap: 12px;
      }

      .lead-row {
        display: grid;
        width: 100%;
        grid-template-columns: 44px minmax(0, 1fr) auto;
        gap: 14px;
        align-items: center;
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 15px;
        background: #fff;
        color: inherit;
        cursor: pointer;
        text-align: left;
      }

      .lead-row:hover,
      .lead-row.is-active {
        border-color: var(--gold);
        background: #fffdf8;
      }

      .lead-row:focus-visible {
        outline: 3px solid rgba(211, 154, 45, 0.28);
        outline-offset: 2px;
      }

      .avatar {
        display: grid;
        width: 44px;
        height: 44px;
        place-items: center;
        border-radius: 50%;
        background: var(--cyan-soft);
        color: var(--cyan);
        font-weight: 900;
      }

      .lead-row.is-hot .avatar,
      .detail-hero.is-hot .avatar {
        background: var(--gold-soft);
        color: var(--gold);
      }

      .lead-main {
        min-width: 0;
      }

      .lead-name {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
        margin-bottom: 5px;
        font-weight: 800;
      }

      .grade {
        display: inline-flex;
        border: 1px solid #eed4a5;
        border-radius: 5px;
        padding: 1px 6px;
        color: var(--gold);
        font-size: 12px;
        font-weight: 800;
      }

      .lead-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px 14px;
        color: var(--muted);
        font-size: 13px;
      }

      .pill {
        display: inline-flex;
        min-height: 30px;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 4px 12px;
        background: var(--panel-soft);
        color: var(--muted);
        font-size: 13px;
        font-weight: 700;
        white-space: nowrap;
      }

      .pill.green {
        border-color: #bfeacb;
        background: var(--green-soft);
        color: var(--green);
      }

      .pill.gold {
        border-color: #edd4a6;
        background: var(--gold-soft);
        color: var(--gold);
      }

      .pill.danger {
        border-color: #ffc2cb;
        background: var(--danger-soft);
        color: var(--danger);
      }

      .pill.cyan {
        border-color: #bdeaf0;
        background: var(--cyan-soft);
        color: var(--cyan);
      }

      .drawer-shell {
        position: fixed;
        inset: 0;
        z-index: 50;
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(360px, 460px);
        opacity: 0;
        pointer-events: none;
        transition: opacity 180ms ease;
      }

      .drawer-shell.is-open {
        opacity: 1;
        pointer-events: auto;
      }

      .drawer-backdrop {
        border: 0;
        background: rgba(17, 24, 39, 0.45);
        cursor: pointer;
      }

      .detail-card {
        height: 100svh;
        overflow: auto;
        border-left: 1px solid var(--line);
        border-radius: 0;
        box-shadow: -20px 0 42px rgba(21, 31, 45, 0.16);
        transform: translateX(100%);
        transition: transform 220ms ease;
      }

      .drawer-shell.is-open .detail-card {
        transform: translateX(0);
      }

      .drawer-head {
        display: flex;
        gap: 14px;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 22px;
      }

      .drawer-head h2 {
        margin: 0;
        font-size: 22px;
      }

      .drawer-close {
        display: grid;
        width: 40px;
        height: 40px;
        place-items: center;
        border: 1px solid var(--line);
        border-radius: 50%;
        background: var(--panel-soft);
        color: var(--text);
        cursor: pointer;
        font-size: 20px;
        font-weight: 800;
      }

      .detail-hero {
        display: grid;
        grid-template-columns: 56px 1fr;
        gap: 14px;
        align-items: center;
        margin-bottom: 22px;
      }

      .detail-hero .avatar {
        width: 56px;
        height: 56px;
        font-size: 20px;
      }

      .detail-hero h2 {
        margin-bottom: 5px;
        font-size: 26px;
      }

      .detail-hero p {
        margin: 0;
        color: var(--muted);
      }

      .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-bottom: 20px;
      }

      .detail-item {
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 13px;
        background: var(--panel-soft);
      }

      .detail-item span {
        display: block;
        margin-bottom: 5px;
        color: var(--muted);
        font-size: 12px;
        font-weight: 800;
        text-transform: uppercase;
      }

      .detail-item strong {
        font-size: 16px;
      }

      .detail-note {
        border: 1px solid #edd4a6;
        border-radius: 16px;
        padding: 16px;
        background: var(--gold-soft);
      }

      .detail-note h3 {
        margin-bottom: 8px;
        font-size: 17px;
      }

      .detail-note p {
        margin-bottom: 0;
        color: var(--muted);
        line-height: 1.5;
      }

      .detail-section {
        display: grid;
        gap: 12px;
        margin-top: 16px;
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 16px;
        background: #fff;
      }

      .detail-section h3 {
        margin: 0;
        font-size: 17px;
      }

      .followup-box {
        border-color: #ffc2cb;
        background: var(--danger-soft);
      }

      .followup-box h3 {
        color: var(--danger);
      }

      .section-row {
        display: grid;
        grid-template-columns: 118px minmax(0, 1fr);
        gap: 10px;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.45;
      }

      .section-row span:first-child {
        color: var(--text);
        font-weight: 800;
      }

      .notes-list {
        display: grid;
        gap: 8px;
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .notes-list li {
        border-radius: 12px;
        padding: 10px 12px;
        background: var(--panel-soft);
        color: var(--muted);
        font-size: 14px;
        line-height: 1.45;
      }

      .actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-top: 18px;
      }

      .primary-action,
      .secondary-action {
        display: inline-flex;
        min-height: 46px;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: 0 14px;
        text-align: center;
      }

      .secondary-action {
        border: 1px solid var(--line);
        background: var(--panel-soft);
        color: var(--text);
        font-weight: 800;
      }

      @media (max-width: 1120px) {
        .app-shell {
          grid-template-columns: 1fr;
        }

        .sidebar {
          position: static;
          height: auto;
        }

        .side-nav {
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .side-meta {
          display: none;
        }

        .drawer-shell {
          grid-template-columns: minmax(0, 1fr) minmax(340px, 420px);
        }

        .workspace {
          grid-template-columns: 1fr;
        }

        .queue-panel {
          position: static;
        }
      }

      @media (max-width: 720px) {
        .content,
        .sidebar {
          padding: 18px 14px;
        }

        .side-nav {
          grid-template-columns: 1fr 1fr;
        }

        .topbar {
          display: grid;
        }

        .metrics {
          grid-template-columns: 1fr 1fr;
        }

        .searchbar,
        .lead-row,
        .detail-hero,
        .detail-grid,
        .actions,
        .section-row {
          grid-template-columns: 1fr;
        }

        .lead-row {
          align-items: start;
        }

        .drawer-shell {
          grid-template-columns: 1fr;
        }

        .drawer-backdrop {
          display: none;
        }

        .detail-card {
          width: 100%;
          border-left: 0;
        }
      }
    </style>
  </head>
  <body>
    <div class="dashboard-app-shell">
      <DashboardSidebar active="leady" />

      <main class="content dashboard-content">
        <header class="topbar">
          <div>
            <p class="eyebrow">CRM cockpit V1</p>
            <h1>Follow-up a lead cockpit</h1>
            <p class="lead-intro">
              Operačný prototyp pre rýchle rozhodovanie: kto horí, čo má byť ďalší krok a kde chýba kontext pred ďalším kontaktom.
            </p>
          </div>
          <span class="status-chip">Demo CRM režim</span>
        </header>

        <section class="metrics" aria-label="Lead metriky">
          <article class="metric-card"><span>Aktívne leady</span><strong>6</strong></article>
          <article class="metric-card"><span>Kvalita A</span><strong>3</strong></article>
          <article class="metric-card"><span>Vyžadujú follow-up</span><strong>2</strong></article>
          <article class="metric-card"><span>Napojené na nehnuteľnosť</span><strong>6/6</strong></article>
        </section>

        <hr class="page-divider" />

        <section class="workspace">
          <aside class="panel queue-panel">
            <div class="panel-head">
              <div>
                <h2>Follow-up fronta</h2>
                <p class="panel-kicker">Najbližšie úkony zoradené podľa naliehavosti a obchodnej hodnoty.</p>
              </div>
              <span class="pill gold">V1</span>
            </div>
            <div class="queue-list" data-followup-list>
              {followUpTasks.map((task) => (
                <button
                  type="button"
                  class={`queue-card ${task.priority === "Urgentné" || task.window === "Po termíne" ? "urgent" : ""}`}
                  data-lead-id={task.id}
                >
                  <span>
                    <strong>{task.action}</strong>
                    <small>{task.name} · {task.property}</small>
                    <span class="queue-meta">
                      <span class={task.priority === "Urgentné" ? "pill danger" : task.priority === "Vysoká" ? "pill gold" : "pill"}>{task.priority}</span>
                      <span class="pill">{task.status}</span>
                    </span>
                  </span>
                  <span class="pill">{task.time}</span>
                </button>
              ))}
            </div>
          </aside>

          <article class="panel">
            <div class="panel-head">
              <div>
                <h2>Lead zoznam</h2>
                <p class="panel-kicker">Pracovný zoznam klientov s kvalitou, zámerom a ďalším krokom.</p>
              </div>
              <span class="pill gold">klik otvorí detail</span>
            </div>
            <div class="searchbar">
              <input type="search" placeholder="Hľadať meno, lokalitu alebo typ nehnuteľnosti" aria-label="Hľadať lead" />
              <button type="button">Filtrovať</button>
            </div>

            <div class="lead-list" data-lead-list>
              {leads.map((lead, index) => (
                <button
                  type="button"
                  class={`lead-row ${lead.grade === "A" ? "is-hot" : ""}`}
                  data-lead={JSON.stringify(lead)}
                  aria-pressed="false"
                >
                  <span class="avatar">{lead.name.slice(0, 1)}</span>
                  <span class="lead-main">
                    <span class="lead-name">
                      {lead.name}
                      <span class="grade">{lead.grade}</span>
                    </span>
                    <span class="lead-meta">
                      <span>{lead.type}</span>
                      <span>{lead.property}</span>
                      <span>{lead.location}</span>
                      <span>{lead.budget}</span>
                    </span>
                  </span>
                  <span class={lead.status === "Uzavretie" ? "pill green" : lead.grade === "A" ? "pill gold" : "pill cyan"}>
                    {lead.status}
                  </span>
                </button>
              ))}
            </div>
          </article>
        </section>
      </main>
    </div>

    <div class="drawer-shell" data-drawer aria-hidden="true">
      <button class="drawer-backdrop" type="button" data-drawer-close aria-label="Zavrieť detail leadu"></button>
      <aside class="panel detail-card" role="dialog" aria-modal="true" aria-labelledby="lead-detail-title">
            <div class="drawer-head">
              <h2 id="lead-detail-title">Detail leadu</h2>
              <button class="drawer-close" type="button" data-drawer-close aria-label="Zavrieť detail leadu">×</button>
            </div>
            <div class={`detail-hero ${firstLead.grade === "A" ? "is-hot" : ""}`}>
              <span class="avatar" data-detail-initial>{firstLead.name.slice(0, 1)}</span>
              <div>
                <h2 data-detail-name>{firstLead.name}</h2>
                <p data-detail-type>{firstLead.type} · {firstLead.status}</p>
              </div>
            </div>

            <div class="detail-grid">
              <div class="detail-item">
                <span>Nehnuteľnosť</span>
                <strong data-detail-property>{firstLead.property}</strong>
              </div>
              <div class="detail-item">
                <span>Lokalita</span>
                <strong data-detail-location>{firstLead.location}</strong>
              </div>
              <div class="detail-item">
                <span>Rozpočet / očakávanie</span>
                <strong data-detail-budget>{firstLead.budget}</strong>
              </div>
              <div class="detail-item">
                <span>Časový rámec</span>
                <strong data-detail-timing>{firstLead.timing}</strong>
              </div>
              <div class="detail-item">
                <span>Zdroj</span>
                <strong data-detail-source>{firstLead.source}</strong>
              </div>
              <div class="detail-item">
                <span>Kontakt</span>
                <strong data-detail-contact>{firstLead.phone}</strong>
              </div>
            </div>

            <div class="detail-note">
              <h3>Motivácia</h3>
              <p data-detail-motivation>{firstLead.motivation}</p>
            </div>

            <section class="detail-section followup-box" aria-label="Ďalší follow-up">
              <h3>Ďalší follow-up</h3>
              <div class="section-row">
                <span>Akcia</span>
                <strong data-detail-action>{firstLead.nextAction}</strong>
              </div>
              <div class="section-row">
                <span>Termín</span>
                <strong data-detail-time>{firstLead.nextTime}</strong>
              </div>
              <div class="section-row">
                <span>SLA okno</span>
                <strong data-detail-window>{firstLead.followUpWindow}</strong>
              </div>
            </section>

            <section class="detail-section" aria-label="Poznámky">
              <h3>Poznámky</h3>
              <ul class="notes-list" data-detail-notes>
                {firstLead.notes.map((note) => <li>{note}</li>)}
              </ul>
            </section>

            <section class="detail-section" aria-label="Zdroj a atribúcia">
              <h3>Zdroj / atribúcia</h3>
              <div class="section-row">
                <span>Zdroj</span>
                <strong data-detail-source-line>{firstLead.source}</strong>
              </div>
              <div class="section-row">
                <span>Atribúcia</span>
                <strong data-detail-attribution>{firstLead.attribution}</strong>
              </div>
            </section>

            <section class="detail-section" aria-label="Approval status">
              <h3>Approval status</h3>
              <div class="section-row">
                <span>Stav</span>
                <strong data-detail-approval>{firstLead.approvalStatus}</strong>
              </div>
              <div class="section-row">
                <span>Placeholder</span>
                <span>Schvaľovanie OpenClaw draftov čaká na napojenie interného workflow.</span>
              </div>
            </div>

            <div class="actions">
              <a class="primary-action" href="/rezervacia/">Vytvoriť task</a>
              <a class="secondary-action" data-detail-phone-link href={`tel:${firstLead.phone.replace(/[^\d+]/g, "")}`}>Zavolať</a>
            </div>
          </aside>
    </div>

    <script>
      const leadList = document.querySelector("[data-lead-list]");
      const followupList = document.querySelector("[data-followup-list]");
      let rows = Array.from(document.querySelectorAll("[data-lead]"));
      let queueRows = Array.from(document.querySelectorAll("[data-lead-id], [data-queue-lead]"));
      const drawer = document.querySelector("[data-drawer]");
      const closeButtons = Array.from(document.querySelectorAll("[data-drawer-close]"));
      const detail = {
        hero: document.querySelector(".detail-hero"),
        initial: document.querySelector("[data-detail-initial]"),
        name: document.querySelector("[data-detail-name]"),
        type: document.querySelector("[data-detail-type]"),
        property: document.querySelector("[data-detail-property]"),
        location: document.querySelector("[data-detail-location]"),
        budget: document.querySelector("[data-detail-budget]"),
        timing: document.querySelector("[data-detail-timing]"),
        source: document.querySelector("[data-detail-source]"),
        contact: document.querySelector("[data-detail-contact]"),
        motivation: document.querySelector("[data-detail-motivation]"),
        action: document.querySelector("[data-detail-action]"),
        time: document.querySelector("[data-detail-time]"),
        window: document.querySelector("[data-detail-window]"),
        notes: document.querySelector("[data-detail-notes]"),
        sourceLine: document.querySelector("[data-detail-source-line]"),
        attribution: document.querySelector("[data-detail-attribution]"),
        approval: document.querySelector("[data-detail-approval]"),
        phoneLink: document.querySelector("[data-detail-phone-link]"),
      };

      function setText(node, value) {
        if (node) node.textContent = value;
      }

      function escapeHtml(value) {
        return String(value || "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }

      function derivePriority(lead) {
        const grade = String(lead.grade || "").toUpperCase();
        const status = String(lead.status || "").toLowerCase();
        const time = String(lead.nextTime || "").toLowerCase();

        if (time.includes("pred") || status.includes("uzavretie")) return "Urgentné";
        if (grade === "A" || status.includes("obhliadka") || status.includes("konzultácia")) return "Vysoká";
        return "Stredná";
      }

      function deriveFollowUpWindow(lead) {
        const time = String(lead.nextTime || "").toLowerCase();
        if (time.includes("pred")) return "Po termíne";
        if (time.includes("dnes") || time.includes("konca dňa")) return "Dnes";
        if (time.includes("zajtra")) return "Zajtra";
        return "Naplánovať";
      }

      function normalizeLead(lead = {}) {
        const normalized = {
          id: lead.id || lead.name || crypto.randomUUID?.() || `lead-${Date.now()}`,
          name: lead.name || "Bez mena",
          grade: lead.grade || "C",
          status: lead.status || "Nový lead",
          type: lead.type || "Lead",
          property: lead.property || "Neurčené",
          location: lead.location || "-",
          budget: lead.budget || "neuvedené",
          timing: lead.timing || "-",
          source: lead.source || "CRM",
          motivation: lead.motivation || "Bez poznámky.",
          nextAction: lead.nextAction || "Doplniť ďalší krok.",
          nextTime: lead.nextTime || "bez termínu",
          phone: lead.phone || "",
          email: lead.email || "",
          attribution: lead.attribution || `${lead.source || "CRM"} / UTM a referrer zatiaľ nie sú uložené`,
          approvalStatus: lead.approvalStatus || "Placeholder - approval workflow nie je napojený",
        };

        normalized.priority = lead.priority || derivePriority(normalized);
        normalized.followUpWindow = lead.followUpWindow || deriveFollowUpWindow(normalized);
        normalized.notes = Array.isArray(lead.notes) && lead.notes.length
          ? lead.notes
          : [
              normalized.motivation,
              normalized.email ? `Kontakt email: ${normalized.email}` : "Email zatiaľ nie je uložený.",
            ];

        return normalized;
      }

      function getStatusClass(lead) {
        if (lead.status === "Uzavretie") return "pill green";
        if (lead.grade === "A") return "pill gold";
        return "pill cyan";
      }

      function renderLeadRow(lead) {
        const normalized = normalizeLead(lead);
        const leadJson = escapeHtml(JSON.stringify(normalized));
        const hotClass = normalized.grade === "A" ? "is-hot" : "";
        const initial = escapeHtml((normalized.name || "?").slice(0, 1));
        const meta = [normalized.type, normalized.property, normalized.location, normalized.budget]
          .filter(Boolean)
          .map((item) => `<span>${escapeHtml(item)}</span>`)
          .join("");

        return `
          <button type="button" class="lead-row ${hotClass}" data-lead="${leadJson}" aria-pressed="false">
            <span class="avatar">${initial}</span>
            <span class="lead-main">
              <span class="lead-name">
                ${escapeHtml(normalized.name)}
                <span class="grade">${escapeHtml(normalized.grade)}</span>
              </span>
              <span class="lead-meta">${meta}</span>
            </span>
            <span class="${getStatusClass(normalized)}">${escapeHtml(normalized.status)}</span>
          </button>
        `;
      }

      function renderQueueCard(lead) {
        const normalized = normalizeLead(lead);
        const leadJson = escapeHtml(JSON.stringify(normalized));
        const urgent = normalized.priority === "Urgentné" || normalized.followUpWindow === "Po termíne";
        const priorityClass = normalized.priority === "Urgentné" ? "pill danger" : normalized.priority === "Vysoká" ? "pill gold" : "pill";

        return `
          <button type="button" class="queue-card ${urgent ? "urgent" : ""}" data-queue-lead="${leadJson}">
            <span>
              <strong>${escapeHtml(normalized.nextAction)}</strong>
              <small>${escapeHtml(normalized.name)} · ${escapeHtml(normalized.property)}</small>
              <span class="queue-meta">
                <span class="${priorityClass}">${escapeHtml(normalized.priority)}</span>
                <span class="pill">${escapeHtml(normalized.status)}</span>
              </span>
            </span>
            <span class="pill">${escapeHtml(normalized.nextTime)}</span>
          </button>
        `;
      }

      function renderFollowupQueue(leads) {
        if (!followupList || !Array.isArray(leads) || !leads.length) return;
        followupList.innerHTML = leads.map(normalizeLead).slice(0, 5).map(renderQueueCard).join("");
        bindQueueRows();
      }

      function renderLeadRows(leads) {
        if (!leadList || !Array.isArray(leads) || !leads.length) return;
        leadList.innerHTML = leads.map(renderLeadRow).join("");
        bindRows();
        renderFollowupQueue(leads);
      }

      function openDrawer() {
        drawer?.classList.add("is-open");
        drawer?.setAttribute("aria-hidden", "false");
        document.body.style.overflow = "hidden";
      }

      function closeDrawer() {
        drawer?.classList.remove("is-open");
        drawer?.setAttribute("aria-hidden", "true");
        document.body.style.overflow = "";
      }

      closeButtons.forEach((button) => {
        button.addEventListener("click", closeDrawer);
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") closeDrawer();
      });

      function renderNotes(notes) {
        if (!detail.notes) return;
        const safeNotes = Array.isArray(notes) && notes.length ? notes : ["Poznámka zatiaľ nie je uložená."];
        detail.notes.innerHTML = safeNotes.map((note) => `<li>${escapeHtml(note)}</li>`).join("");
      }

      function setActiveRow(activeLead) {
        rows.forEach((item) => {
          const itemLead = normalizeLead(JSON.parse(item.dataset.lead || "{}"));
          const isActive = itemLead.id === activeLead.id;
          item.classList.toggle("is-active", isActive);
          item.setAttribute("aria-pressed", isActive ? "true" : "false");
        });

        queueRows.forEach((item) => {
          let itemLead = null;
          if (item.dataset.queueLead) {
            itemLead = normalizeLead(JSON.parse(item.dataset.queueLead || "{}"));
          } else if (item.dataset.leadId) {
            itemLead = { id: item.dataset.leadId };
          }
          item.classList.toggle("is-active", itemLead?.id === activeLead.id);
        });
      }

      function showLeadDetail(rawLead) {
        const lead = normalizeLead(rawLead);
        setActiveRow(lead);

        setText(detail.initial, (lead.name || "?").slice(0, 1));
        setText(detail.name, lead.name);
        setText(detail.type, `${lead.type} · ${lead.status}`);
        setText(detail.property, lead.property);
        setText(detail.location, lead.location);
        setText(detail.budget, lead.budget);
        setText(detail.timing, lead.timing);
        setText(detail.source, lead.source);
        setText(detail.contact, lead.phone || lead.email || "Kontakt chýba");
        setText(detail.motivation, lead.motivation);
        setText(detail.action, lead.nextAction);
        setText(detail.time, lead.nextTime);
        setText(detail.window, lead.followUpWindow);
        setText(detail.sourceLine, lead.source);
        setText(detail.attribution, lead.attribution);
        setText(detail.approval, lead.approvalStatus);
        renderNotes(lead.notes);
        detail.hero?.classList.toggle("is-hot", lead.grade === "A");
        if (detail.phoneLink && lead.phone) {
          detail.phoneLink.setAttribute("href", `tel:${lead.phone.replace(/[^\d+]/g, "")}`);
        }
        openDrawer();
      }

      function bindRows() {
        rows = Array.from(document.querySelectorAll("[data-lead]"));
        rows.forEach((row) => {
          row.addEventListener("click", () => {
            const lead = JSON.parse(row.dataset.lead || "{}");
            showLeadDetail(lead);
          });
        });
      }

      function bindQueueRows() {
        queueRows = Array.from(document.querySelectorAll("[data-lead-id], [data-queue-lead]"));
        queueRows.forEach((row) => {
          row.addEventListener("click", () => {
            if (row.dataset.queueLead) {
              showLeadDetail(JSON.parse(row.dataset.queueLead || "{}"));
              return;
            }

            const matchingRow = rows.find((item) => {
              const lead = normalizeLead(JSON.parse(item.dataset.lead || "{}"));
              return lead.id === row.dataset.leadId;
            });

            matchingRow?.click();
          });
        });
      }

      async function loadSupabaseLeads() {
        try {
          const response = await fetch("/api/dashboard/leads", {
            headers: { Accept: "application/json" },
          });

          if (!response.ok) return;

          const data = await response.json();

          if (data?.ok && Array.isArray(data.leads)) {
            renderLeadRows(data.leads);
          }
        } catch {
          // Keep static fallback data when API is unavailable.
        }
      }

      bindRows();
      bindQueueRows();
      loadSupabaseLeads();
    </script>
  </body>
</html>
