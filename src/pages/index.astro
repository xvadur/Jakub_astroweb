---
import { site } from "../data/site";

const cleanPhone = site.contact.phone.replace(/[^\d+]/g, "");
const hasPhone = cleanPhone.length >= 10;
const hasEmail = site.contact.email.includes("@") && !site.contact.email.includes("example.");
const hasInstagram = site.contact.instagram.startsWith("http");
const hasBooking = site.bookingUrl.startsWith("https://");
const siteEnv = import.meta.env.PUBLIC_SITE_ENV ?? "production";
const isStaging = siteEnv !== "production";
const availableListings = site.listings.filter((listing) => listing.group === "available");
const soldListings = site.listings.filter((listing) => listing.group === "sold");
const availableListingsLabel =
  availableListings.length === 1
    ? "1 aktuálna ponuka"
    : availableListings.length > 1 && availableListings.length < 5
      ? `${availableListings.length} aktuálne ponuky`
      : availableListings.length > 0
        ? `${availableListings.length} aktuálnych ponúk`
        : "pripravené na doplnenie";
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "RealEstateAgent",
  name: site.brand,
  description: `${site.brand}, ${site.role}. ${site.shortPromise}`,
  areaServed: site.cityLabel,
  ...(hasPhone ? { telephone: site.contact.phone } : {}),
  ...(hasEmail ? { email: site.contact.email } : {}),
  ...(hasInstagram ? { sameAs: [site.contact.instagram] } : {}),
};
---

<!doctype html>
<html lang="sk">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="icon" type="image/png" href="/favicon.png?v=2" />
    <link rel="icon" href="/favicon.ico?v=2" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content={`${site.brand} je ${site.role}. ${site.shortPromise} Dohodnite si predajný audit nehnuteľnosti.`}
    />
    <meta property="og:title" content={`${site.brand} | ${site.shortPromise}`} />
    <meta
      property="og:description"
      content="Osobný maklér so servisným zázemím BOSEN pre predaj, kúpu, prenájom a stratégiu hodnotnej nehnuteľnosti."
    />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={site.heroImage} />
    {isStaging ? <meta name="robots" content="noindex,nofollow,noarchive" /> : null}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Newsreader:opsz,wght@6..72,500;6..72,650;6..72,700&display=swap"
      rel="stylesheet"
    />
    <title>{site.brand} | {site.shortPromise}</title>
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a class="skip-link" href="#kontakt">Prejsť na kontakt</a>
    {isStaging ? <div class="staging-ribbon" aria-hidden="true">STAGING</div> : null}

    <header class="site-header">
      <a class="brand" href="#top" aria-label={`${site.brand}, úvod`}>
        <img class="brand-mark" src={site.logoImage} alt="" />
        <span class="brand-label">
          <span>{site.brand}</span>
          <small>{site.role}</small>
        </span>
      </a>
      <nav aria-label="Hlavná navigácia">
        <a href="#servis">Servis</a>
        <a href="#ponuky">Ponuky</a>
        <a href="#proces">Proces</a>
        <a href="/rezervacia/">Konzultácia</a>
      </nav>
      <a class="header-phone" href="/rezervacia/">Rezervácia konzultácie</a>
    </header>

    <main id="top">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-copy" data-reveal>
          <p class="eyebrow">Osobný maklér s kompletným zázemím BOSEN</p>
          <h1 id="hero-title">{site.brand}</h1>
          <p class="promise">{site.shortPromise}</p>
          <p class="intro">{site.intro}</p>
          <div class="hero-actions" aria-label="Hlavné akcie">
            <a class="button primary" href="/rezervacia/">Rezervácia konzultácie</a>
            <a class="button secondary" href="#servis">Čo za vás prevezmem</a>
          </div>
        </div>
        <div class="hero-visual" data-reveal>
          <img src={site.heroImage} alt="Portrét realitného makléra Jakuba Olšu" />
          <div class="portrait-note">
            <p>
              <strong>Jeden človek na vašej strane.</strong>
              Za mnou je marketing, právo, financovanie a realitné zázemie BOSEN.
            </p>
          </div>
        </div>
      </section>

      <section class="proof-strip" aria-label="Čo môžete čakať">
        {
          site.proofPoints.map((point) => (
            <p data-reveal>
              <span></span>
              {point}
            </p>
          ))
        }
      </section>

      <div
        class="city-panorama"
        aria-hidden="true"
        style={`--city-panorama-image: url('${site.cityPanoramaImage}')`}
      ></div>

      <section class="section backing" id="servis" aria-labelledby="backing-title">
        <div class="backing-lead" data-reveal>
          <p class="eyebrow">{site.backing.eyebrow}</p>
          <h2 id="backing-title">{site.backing.title}</h2>
          <p>{site.backing.text}</p>
        </div>
        <div class="backing-grid">
          {
            site.backing.items.map((item) => (
              <article class="backing-item" data-reveal>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section split" id="sluzby">
        <div class="section-heading" data-reveal>
          <p class="eyebrow">Čo pre vás prevezmem</p>
          <h2>Nie každá situácia potrebuje rovnaké riešenie. Najprv vyberieme správnu stratégiu.</h2>
        </div>
        <div class="service-list">
          {
            site.services.map((service) => (
              <article class="service" data-reveal>
                <h3>{service.title}</h3>
                <p>{service.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section track-record" aria-labelledby="track-record-title">
        <div class="track-copy" data-reveal>
          <p class="eyebrow">{site.trackRecord.eyebrow}</p>
          <h2 id="track-record-title">{site.trackRecord.title}</h2>
          <p>{site.trackRecord.text}</p>
        </div>
        <div class="stat-grid" aria-label="Moje výsledky">
          {
            site.trackRecord.stats.map((stat) => (
              <article class="stat-item" data-reveal>
                <strong>{stat.value}</strong>
                <span>{stat.label}</span>
              </article>
            ))
          }
        </div>
        <article class="positioning-panel" data-reveal>
          <h3>{site.positioning.title}</h3>
          <p>{site.positioning.text}</p>
        </article>
      </section>

      <section class="section listings" id="ponuky">
        <div class="section-heading" data-reveal>
          <p class="eyebrow">{site.listingsIntro.eyebrow}</p>
          <h2>{site.listingsIntro.title}</h2>
          <p>{site.listingsIntro.text}</p>
        </div>
        <div class="listing-groups">
          <div class="listing-group available-listings" data-reveal>
            <div class="listing-group-heading">
              <div>
                <h3 class="listing-section-title">Aktuálne ponúkané byty</h3>
                <span>{availableListingsLabel}</span>
              </div>
            </div>
            {
              availableListings.length > 0 ? (
                <div class="listing-grid">
                  {
                    availableListings.map((listing) => (
                      <article class="listing">
                        <a href={listing.href} aria-label={`Detail: ${listing.title}`}>
                          <img src={listing.image} alt="" loading="lazy" />
                          <div>
                            <p>{listing.status}</p>
                            <h3>{listing.title}</h3>
                            <dl>
                              <div>
                                <dt>Lokalita</dt>
                                <dd>{listing.place}</dd>
                              </div>
                              <div>
                                <dt>Cena</dt>
                                <dd>{listing.price}</dd>
                              </div>
                            </dl>
                            <span>{listing.note}</span>
                            <strong>{listing.cta}</strong>
                          </div>
                        </a>
                      </article>
                    ))
                  }
                </div>
              ) : (
                <article class="listing-empty">
                  <p>Aktuálne nie je zverejnený žiadny byt v ponuke.</p>
                  <span>Ak hľadáte konkrétny byt alebo chcete vedieť, čo sa pripravuje, najrýchlejšie je ozvať sa priamo.</span>
                  <a class="button primary" href="/rezervacia/">Rezervácia konzultácie</a>
                </article>
              )
            }
          </div>

          <div class="listing-group sold-listings" data-reveal>
            <div class="listing-group-heading">
              <div>
                <h3 class="listing-section-title">Referenčné predaje</h3>
                <span>{soldListings.length} referenčných predajov</span>
              </div>
              <div class="carousel-controls" aria-label="Ovládanie referencií">
                <button type="button" class="carousel-button" data-carousel-prev aria-label="Predchádzajúca referencia">
                  ‹
                </button>
                <button type="button" class="carousel-button" data-carousel-next aria-label="Ďalšia referencia">
                  ›
                </button>
              </div>
            </div>
            <div class="listing-carousel" data-carousel-track>
              {
                soldListings.map((listing) => (
                  <article class="listing sold">
                    <a href={listing.href} aria-label={`Detail: ${listing.title}`}>
                      <img src={listing.image} alt="" loading="lazy" />
                      <div>
                        <p>{listing.status}</p>
                        <h3>{listing.title}</h3>
                        <dl>
                          <div>
                            <dt>Lokalita</dt>
                            <dd>{listing.place}</dd>
                          </div>
                          <div>
                            <dt>Výsledok</dt>
                            <dd>{listing.price}</dd>
                          </div>
                        </dl>
                        <span>{listing.note}</span>
                        <strong>{listing.cta}</strong>
                      </div>
                    </a>
                  </article>
                ))
              }
            </div>
          </div>
        </div>
      </section>

      <section class="section process-section" id="proces">
        <div class="section-heading centered" data-reveal>
          <p class="eyebrow">Ako prebieha spolupráca</p>
          <h2>Tri kroky, ktoré chránia čas, cenu aj nervy.</h2>
        </div>
        <div class="process-grid">
          {
            site.process.map((item) => (
              <article class="process-item" data-reveal>
                <span>{item.step}</span>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section
        class="image-band"
        aria-label="Poznámka k práci realitného makléra"
        style={`--band-image: url('${site.handshakeImage}')`}
      >
        <div data-reveal>
          <p class="eyebrow">Môj spôsob práce</p>
          <h2>Najprv sa pozriem na realitu. Potom až na inzerát.</h2>
        </div>
      </section>

      <section class="section principles">
        <div class="principle-lead" data-reveal>
          <p class="eyebrow">Ako pracujem</p>
          <h2>Od prvého stretnutia musí byť jasné, čo robím a prečo.</h2>
        </div>
        <div class="principle-list">
          {
            site.principles.map((item) => (
              <article data-reveal>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section sale-time" aria-labelledby="sale-time-title">
        <div data-reveal>
          <p class="eyebrow">{site.saleTime.eyebrow}</p>
          <h2 id="sale-time-title">{site.saleTime.title}</h2>
        </div>
        <p data-reveal>{site.saleTime.text}</p>
      </section>

      <section class="section consultation-cta" aria-labelledby="consultation-title">
        <div data-reveal>
          <p class="eyebrow">Rezervácia konzultácie</p>
          <h2 id="consultation-title">Ak chcete riešiť predaj vážne, začnime krátkym hovorom.</h2>
        </div>
        <div class="consultation-card" data-reveal>
          <p>
            Pred hovorom si vyberiete zámer, typ nehnuteľnosti a preferovaný termín. Jakub tak neprichádza
            do rozhovoru naslepo a vy nestrácate čas všeobecnými otázkami.
          </p>
          <a class="button primary" href="/rezervacia/">Rezervácia konzultácie</a>
        </div>
      </section>

      <section class="contact-section" id="kontakt">
        <div class="contact-copy" data-reveal>
          <p class="eyebrow">{site.leadMagnet.eyebrow}</p>
          <h2>{site.leadMagnet.title}</h2>
          <p>{site.leadMagnet.text}</p>
          <div class="direct-contact" aria-label="Priamy kontakt">
            <p>Rýchly kontakt</p>
            {
              hasPhone ? (
                <a href={`tel:${cleanPhone}`}>
                  <span>Telefón</span>
                  <strong>{site.contact.phone}</strong>
                </a>
              ) : null
            }
            {
              hasBooking ? (
                <a href={site.bookingUrl} target="_blank" rel="noreferrer">
                  <span>Kalendár</span>
                  <strong>Rezervovať v kalendári</strong>
                </a>
              ) : null
            }
            <a href="/rezervacia/">
              <span>Preferovaný termín</span>
              <strong>Rezervácia konzultácie</strong>
            </a>
          </div>
        </div>

        <div class="booking-panel" data-reveal>
          <p class="eyebrow">Audit nehnuteľnosti</p>
          <h3>Pošlite základ. Ozvem sa s konkrétnym ďalším krokom.</h3>
          <p>
            Formulár pripraví podklady k vašej situácii. Následne viem povedať, či dáva zmysel
            klasický predaj, rýchle riešenie, prenájom alebo iný postup.
          </p>
          <form class="contact-form" data-contact-form data-email={site.contact.email}>
            <div class="form-grid">
              <label>
                <span>Meno</span>
                <input name="meno" autocomplete="name" required />
              </label>
              <label>
                <span>Telefón</span>
                <input name="telefon" type="tel" autocomplete="tel" required />
              </label>
              <label>
                <span>Email</span>
                <input name="email" type="email" autocomplete="email" />
              </label>
              <label>
                <span>Čo riešite?</span>
                <select name="zamer" required>
                  <option value="">Vyberte možnosť</option>
                  <option value="Predaj za čo najlepšiu cenu">Predaj za čo najlepšiu cenu</option>
                  <option value="Rýchly predaj alebo výkup">Rýchly predaj alebo výkup</option>
                  <option value="Prenájom alebo správa">Prenájom alebo správa</option>
                  <option value="Kúpa nového a predaj starej nehnuteľnosti">Kúpa nového a predaj starej</option>
                  <option value="Konzultácia / neviem vybrať postup">Konzultácia / neviem vybrať postup</option>
                </select>
              </label>
              <label>
                <span>Typ nehnuteľnosti</span>
                <select name="typ">
                  <option value="">Vyberte typ</option>
                  <option value="Byt">Byt</option>
                  <option value="Dom">Dom</option>
                  <option value="Pozemok">Pozemok</option>
                  <option value="Komerčný priestor">Komerčný priestor</option>
                  <option value="Investičná nehnuteľnosť">Investičná nehnuteľnosť</option>
                </select>
              </label>
              <label>
                <span>Lokalita</span>
                <input name="lokalita" placeholder="Mesto, časť alebo ulica" />
              </label>
              <label>
                <span>Časový horizont</span>
                <select name="horizont">
                  <option value="">Vyberte horizont</option>
                  <option value="Ihneď">Ihneď</option>
                  <option value="1-3 mesiace">1-3 mesiace</option>
                  <option value="3-6 mesiacov">3-6 mesiacov</option>
                  <option value="Zatiaľ len zisťujem možnosti">Zatiaľ len zisťujem možnosti</option>
                </select>
              </label>
              <label>
                <span>Výmera / izby</span>
                <input name="parametre" placeholder="napr. 4 izby, 156 m², terasa" />
              </label>
              <label class="full">
                <span>Čo je pre vás dôležité?</span>
                <textarea name="sprava" rows="4" placeholder="Cena, rýchlosť, diskrétnosť, kúpa nového bývania, investícia..."></textarea>
              </label>
            </div>
            <button class="button primary" type="submit">Pripraviť predajný audit</button>
          </form>
        </div>
      </section>
    </main>

    <a class="mobile-cta" href="/rezervacia/">Rezervácia konzultácie</a>

    <footer>
      <div class="footer-brand">
        <img src={site.logoImage} alt="" />
        {
          hasInstagram ? (
            <a
              class="social-icon"
              href={site.contact.instagram}
              target="_blank"
              rel="noreferrer"
              aria-label={site.contact.instagramLabel}
              title={site.contact.instagramLabel}
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="5" />
                <circle cx="12" cy="12" r="4" />
                <circle cx="17.5" cy="6.5" r="1.2" />
              </svg>
            </a>
          ) : (
            <span
              class="social-icon is-disabled"
              aria-label="Instagram doplniť pred spustením"
              title="Instagram doplniť pred spustením"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="5" />
                <circle cx="12" cy="12" r="4" />
                <circle cx="17.5" cy="6.5" r="1.2" />
              </svg>
            </span>
          )
        }
        <p>{site.brand}</p>
      </div>
      <p>{site.shortPromise}</p>
      <div class="footer-links">
        <a href="#ponuky">Pozrieť ponuky</a>
        <a href="/ochrana-osobnych-udajov/">Ochrana údajov a cookies</a>
      </div>
    </footer>

    <script>
      const revealItems = document.querySelectorAll("[data-reveal]");

      if ("IntersectionObserver" in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12 },
        );

        revealItems.forEach((item) => {
          const rect = item.getBoundingClientRect();

          if (rect.top < window.innerHeight * 0.9) {
            item.classList.add("is-visible");
            return;
          }

          observer.observe(item);
        });
      } else {
        revealItems.forEach((item) => item.classList.add("is-visible"));
      }

      const carouselTrack = document.querySelector("[data-carousel-track]");
      const carouselPrev = document.querySelector("[data-carousel-prev]");
      const carouselNext = document.querySelector("[data-carousel-next]");

      const scrollCarousel = (direction) => {
        if (!carouselTrack) return;

        const firstCard = carouselTrack.querySelector(".listing");
        const cardWidth = firstCard?.getBoundingClientRect().width ?? 320;
        const gap = Number.parseFloat(getComputedStyle(carouselTrack).columnGap || "18");
        const maxScroll = carouselTrack.scrollWidth - carouselTrack.clientWidth;
        const nearStart = carouselTrack.scrollLeft <= 4;
        const nearEnd = carouselTrack.scrollLeft >= maxScroll - 4;

        if (direction > 0 && nearEnd) {
          carouselTrack.scrollTo({ left: 0, behavior: "smooth" });
          return;
        }

        if (direction < 0 && nearStart) {
          carouselTrack.scrollTo({ left: maxScroll, behavior: "smooth" });
          return;
        }

        carouselTrack.scrollBy({ left: direction * (cardWidth + gap), behavior: "smooth" });
      };

      carouselPrev?.addEventListener("click", () => scrollCarousel(-1));
      carouselNext?.addEventListener("click", () => scrollCarousel(1));

      const mobileCta = document.querySelector(".mobile-cta");
      const toggleMobileCta = () => {
        mobileCta?.classList.toggle("is-visible", window.scrollY > 520);
      };

      toggleMobileCta();
      window.addEventListener("scroll", toggleMobileCta, { passive: true });

      const contactForm = document.querySelector("[data-contact-form]");

      contactForm?.addEventListener("submit", (event) => {
        event.preventDefault();

        if (!(contactForm instanceof HTMLFormElement)) return;

        const targetEmail = contactForm.getAttribute("data-email");
        if (!targetEmail) return;

        const formData = new FormData(contactForm);
        const value = (name) => String(formData.get(name) || "").trim();
        const subjectName = value("meno") || "nový kontakt";
        const intentName = value("zamer") || "predajný audit";
        const body = [
          "Predajný audit z webu Jakuba Olšu",
          "",
          `Meno: ${value("meno")}`,
          `Telefón: ${value("telefon")}`,
          `Email: ${value("email") || "-"}`,
          `Zámer: ${intentName}`,
          `Typ nehnuteľnosti: ${value("typ") || "-"}`,
          `Lokalita: ${value("lokalita") || "-"}`,
          `Časový horizont: ${value("horizont") || "-"}`,
          `Výmera / izby: ${value("parametre") || "-"}`,
          "",
          "Čo je dôležité:",
          value("sprava") || "-",
        ].join("\n");

        const href = `mailto:${encodeURIComponent(targetEmail)}?subject=${encodeURIComponent(
          `Predajný audit - ${subjectName} - ${intentName}`,
        )}&body=${encodeURIComponent(body)}`;

        window.location.href = href;
      });

    </script>

    <style>
      :root {
        --paper: #f6f1e8;
        --paper-strong: #e9dfcf;
        --ink: #0b0b0a;
        --charcoal: #1b1b19;
        --muted: #6f6a62;
        --olive: #8a8d91;
        --wine: #9a5c32;
        --brass: #d8b878;
        --brass-muted: #b8945b;
        --white: #fffaf2;
        --line: rgba(11, 11, 10, 0.16);
        --shadow: 0 24px 70px rgba(11, 11, 10, 0.2);
        --font-body: "Instrument Sans", system-ui, sans-serif;
        --font-display: "Newsreader", Georgia, serif;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
        overflow-x: hidden;
      }

      body {
        margin: 0;
        background: var(--paper);
        color: var(--ink);
        font-family: var(--font-body);
        line-height: 1.5;
        overflow-x: clip;
      }

      body::after {
        position: fixed;
        inset: 0;
        z-index: 999;
        pointer-events: none;
        content: "";
        opacity: 0.04;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 180 180' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.45'/%3E%3C/svg%3E");
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        display: block;
        max-width: 100%;
      }

      .skip-link {
        position: fixed;
        top: 12px;
        left: 12px;
        z-index: 1000;
        transform: translateY(-140%);
        padding: 10px 14px;
        background: var(--ink);
        color: var(--white);
        border-radius: 4px;
      }

      .skip-link:focus {
        transform: translateY(0);
      }

      .staging-ribbon {
        position: fixed;
        right: 18px;
        bottom: 18px;
        z-index: 1200;
        border: 1px solid rgba(11, 11, 10, 0.16);
        border-radius: 999px;
        padding: 8px 12px;
        background: #f3cf74;
        color: var(--ink);
        box-shadow: 0 12px 30px rgba(11, 11, 10, 0.22);
        font-size: 12px;
        font-weight: 900;
        letter-spacing: 0;
      }

      .site-header {
        position: fixed;
        top: 18px;
        left: 50%;
        z-index: 50;
        display: flex;
        width: min(1180px, calc(100% - 32px));
        min-height: 64px;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        padding: 10px 14px 10px 18px;
        border: 1px solid rgba(216, 184, 120, 0.3);
        border-radius: 8px;
        background: rgba(11, 11, 10, 0.78);
        color: var(--white);
        transform: translateX(-50%);
        backdrop-filter: blur(18px);
      }

      .brand {
        display: flex;
        min-width: 0;
        align-items: center;
        gap: 12px;
      }

      .brand-mark {
        width: 118px;
        height: 42px;
        object-fit: contain;
        object-position: center;
      }

      .brand-label {
        display: grid;
        gap: 0;
      }

      .brand-label span {
        font-family: var(--font-display);
        font-size: 24px;
        font-weight: 650;
        line-height: 1;
      }

      .brand-label small {
        color: rgba(255, 250, 242, 0.72);
        font-size: 13px;
      }

      nav {
        display: flex;
        gap: clamp(24px, 2.2vw, 34px);
        color: rgba(255, 250, 242, 0.8);
        font-size: 15.5px;
        font-weight: 650;
      }

      nav a,
      .header-phone,
      .direct-contact a,
      footer a {
        text-decoration-line: underline;
        text-decoration-color: transparent;
        text-decoration-thickness: 1px;
        text-underline-offset: 5px;
        transition: text-decoration-color 160ms ease, color 160ms ease;
      }

      nav a:hover,
      .header-phone:hover,
      .direct-contact a:hover,
      footer a:hover {
        color: var(--brass);
        text-decoration-color: currentColor;
      }

      .header-phone {
        display: inline-flex;
        min-height: 42px;
        align-items: center;
        border: 1px solid rgba(255, 250, 242, 0.22);
        border-radius: 6px;
        padding: 0 14px;
        font-weight: 600;
        white-space: nowrap;
      }

      .hero {
        display: grid;
        min-height: 100svh;
        grid-template-columns: minmax(0, 0.95fr) minmax(430px, 1.05fr);
        gap: 54px;
        align-items: center;
        padding: 112px max(28px, calc((100vw - 1180px) / 2)) 64px;
        background:
          linear-gradient(110deg, rgba(11, 11, 10, 0.98) 0%, rgba(27, 27, 25, 0.92) 48%, rgba(11, 11, 10, 0.82) 100%),
          radial-gradient(circle at 18% 24%, rgba(216, 184, 120, 0.22), transparent 34%),
          var(--ink);
        color: var(--white);
      }

      .hero-copy {
        display: flex;
        max-width: 650px;
        flex-direction: column;
        justify-content: center;
        padding: 30px 0 18px;
      }

      .eyebrow {
        margin: 0 0 18px;
        color: var(--wine);
        font-size: 14px;
        font-weight: 700;
      }

      .hero .eyebrow {
        color: var(--brass);
      }

      h1,
      h2,
      h3,
      p {
        margin-top: 0;
      }

      h1,
      h2 {
        font-family: var(--font-display);
        font-weight: 650;
        line-height: 0.95;
      }

      h1 {
        margin-bottom: 18px;
        font-size: clamp(74px, 8vw, 116px);
      }

      .hero h1 {
        color: var(--white);
      }

      h2 {
        margin-bottom: 18px;
        font-size: 54px;
      }

      h3 {
        margin-bottom: 10px;
        font-size: 23px;
        line-height: 1.15;
      }

      .promise {
        margin-bottom: 22px;
        color: var(--brass);
        font-family: var(--font-display);
        font-size: clamp(34px, 3.1vw, 48px);
        font-weight: 500;
        line-height: 1.06;
      }

      .intro {
        max-width: 520px;
        margin-bottom: 30px;
        color: rgba(255, 250, 242, 0.74);
        font-size: 18px;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
      }

      .button {
        display: inline-flex;
        min-height: 50px;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        padding: 0 20px;
        border: 1px solid var(--ink);
        font-weight: 700;
        transition: transform 160ms ease, background 160ms ease, color 160ms ease;
      }

      .button:hover {
        transform: translateY(-2px);
      }

      a:focus-visible,
      button:focus-visible,
      input:focus-visible,
      select:focus-visible,
      textarea:focus-visible {
        outline: 2px solid var(--brass);
        outline-offset: 4px;
      }

      .button.primary {
        border-color: var(--brass);
        background: var(--brass);
        color: var(--ink);
      }

      .button.secondary {
        background: transparent;
        color: inherit;
      }

      .hero .button.secondary {
        border-color: rgba(255, 250, 242, 0.42);
        color: var(--white);
      }

      .hero-visual {
        position: relative;
        height: clamp(560px, 72svh, 720px);
        min-height: 0;
        align-self: center;
        overflow: hidden;
        border: 1px solid rgba(216, 184, 120, 0.2);
        border-radius: 8px;
        box-shadow: var(--shadow);
      }

      .hero-visual::before {
        position: absolute;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        content: "";
        background: linear-gradient(
          90deg,
          rgba(8, 8, 8, 1) 0%,
          rgba(8, 8, 8, 0.62) 16%,
          rgba(8, 8, 8, 0.18) 30%,
          rgba(8, 8, 8, 0) 42%
        );
      }

      .hero-visual > img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center top;
        filter: saturate(0.86) contrast(1.04);
      }

      .portrait-note {
        display: none;
        position: absolute;
        right: 22px;
        top: 22px;
        z-index: 2;
        width: min(330px, calc(100% - 44px));
        padding: 18px;
        border: 1px solid rgba(216, 184, 120, 0.34);
        border-radius: 8px;
        background: rgba(11, 11, 10, 0.78);
        color: var(--white);
        backdrop-filter: blur(16px);
      }

      .portrait-note p {
        margin: 0;
        color: rgba(255, 250, 242, 0.82);
        font-size: 14px;
      }

      .portrait-note strong {
        display: block;
        color: var(--white);
      }

      .proof-strip {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        padding: 0 max(28px, calc((100vw - 1180px) / 2));
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
        background: linear-gradient(90deg, var(--ink), var(--charcoal));
        color: var(--white);
      }

      .proof-strip p {
        display: flex;
        min-height: 96px;
        align-items: center;
        gap: 12px;
        margin: 0;
        min-width: 0;
        padding: 0 clamp(18px, 2.4vw, 32px);
        border-right: 1px solid rgba(255, 250, 242, 0.14);
        font-weight: 600;
        line-height: 1.25;
        text-wrap: balance;
      }

      .proof-strip p:first-child {
        padding-left: 0;
      }

      .proof-strip p:last-child {
        padding-right: 0;
        border-right: 0;
      }

      .proof-strip span {
        width: 9px;
        height: 9px;
        flex: 0 0 auto;
        border-radius: 999px;
        background: var(--brass);
      }

      .city-panorama {
        position: relative;
        min-height: clamp(118px, 13vw, 178px);
        overflow: hidden;
        border-top: 1px solid rgba(255, 250, 242, 0.08);
        background: var(--city-panorama-image) center 66% / 100% auto no-repeat;
      }

      .city-panorama::after {
        position: absolute;
        right: 0;
        left: 0;
        z-index: 1;
        content: "";
        pointer-events: none;
      }

      .city-panorama::after {
        bottom: -22px;
        height: 42%;
        background: linear-gradient(
          180deg,
          rgba(246, 241, 232, 0),
          rgba(246, 241, 232, 0.22) 36%,
          rgba(246, 241, 232, 0.68) 68%,
          var(--paper) 88%,
          var(--paper)
        );
      }

      .backing {
        display: grid;
        grid-template-columns: minmax(0, 0.86fr) minmax(0, 1.14fr);
        gap: 70px;
        background: var(--paper);
      }

      .backing-lead {
        align-self: start;
      }

      .backing-lead p:not(.eyebrow) {
        max-width: 600px;
        margin: 0;
        color: var(--muted);
        font-size: 18px;
      }

      .backing-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
      }

      .backing-item {
        min-height: 238px;
        padding: 24px;
        border: 1px solid rgba(11, 11, 10, 0.16);
        border-radius: 8px;
        background: rgba(255, 250, 242, 0.62);
      }

      .backing-item h3 {
        font-family: var(--font-display);
        font-size: clamp(27px, 2.5vw, 34px);
        font-weight: 650;
      }

      .backing-item p {
        margin: 0;
        color: var(--muted);
      }

      .track-record {
        display: grid;
        grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
        gap: 62px;
        background: var(--white);
      }

      .track-copy {
        max-width: 620px;
      }

      .track-copy > p:not(.eyebrow),
      .positioning-panel p,
      .sale-time > p {
        color: var(--muted);
      }

      .stat-grid {
        display: grid;
        gap: 0;
        align-self: start;
        border-top: 1px solid var(--line);
      }

      .stat-item {
        display: grid;
        grid-template-columns: 0.42fr 1fr;
        gap: 28px;
        padding: 25px 0;
        border-bottom: 1px solid var(--line);
      }

      .stat-item strong {
        color: var(--wine);
        font-family: var(--font-display);
        font-size: clamp(42px, 4vw, 68px);
        font-weight: 650;
        line-height: 0.92;
      }

      .stat-item span {
        align-self: center;
        color: var(--ink);
        font-size: 18px;
        font-weight: 700;
        line-height: 1.25;
      }

      .positioning-panel {
        grid-column: 1 / -1;
        display: grid;
        grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
        gap: 62px;
        padding-top: 34px;
        border-top: 1px solid var(--line);
      }

      .positioning-panel h3 {
        max-width: 760px;
        margin: 0;
        font-family: var(--font-display);
        font-size: clamp(36px, 4vw, 58px);
        font-weight: 650;
        line-height: 0.98;
      }

      .positioning-panel p {
        max-width: 520px;
        margin: 0;
        align-self: end;
        font-size: 18px;
      }

      .section {
        padding: 110px max(28px, calc((100vw - 1180px) / 2));
      }

      .split {
        display: grid;
        grid-template-columns: 0.8fr 1.2fr;
        gap: 70px;
      }

      .section-heading {
        max-width: 700px;
      }

      .section-heading p:not(.eyebrow),
      .contact-copy p,
      .principle-lead + .principle-list p {
        color: var(--muted);
      }

      .centered {
        max-width: 760px;
        margin: 0 auto 42px;
        text-align: center;
      }

      .service-list {
        display: grid;
        gap: 0;
        border-top: 1px solid var(--line);
      }

      .service {
        display: grid;
        grid-template-columns: 0.7fr 1fr;
        gap: 32px;
        padding: 28px 0;
        border-bottom: 1px solid var(--line);
      }

      .service p {
        margin: 0;
        color: var(--muted);
      }

      .process-section {
        background: var(--paper-strong);
      }

      .process-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
      }

      .process-item {
        min-height: 320px;
        padding: 28px;
        border: 1px solid rgba(30, 28, 25, 0.18);
        border-radius: 8px;
        background: rgba(255, 250, 242, 0.45);
      }

      .process-item span {
        display: block;
        margin-bottom: 70px;
        color: var(--wine);
        font-family: var(--font-display);
        font-size: 42px;
      }

      .process-item p {
        color: var(--muted);
      }

      .image-band {
        min-height: 760px;
        display: flex;
        align-items: flex-end;
        padding: 70px max(28px, calc((100vw - 1180px) / 2));
        color: var(--white);
        background:
          linear-gradient(90deg, rgba(30, 28, 25, 0.78) 0%, rgba(30, 28, 25, 0.52) 42%, rgba(30, 28, 25, 0.2) 74%),
          linear-gradient(180deg, rgba(30, 28, 25, 0.04), rgba(30, 28, 25, 0.58)),
          var(--band-image) 60% 10%/cover;
      }

      .image-band div {
        width: min(100%, 920px);
        max-width: none;
      }

      .image-band .eyebrow {
        color: #e7c385;
      }

      .image-band h2 {
        margin: 0;
        max-width: min(920px, 66vw);
        font-size: clamp(46px, 5.2vw, 76px);
        line-height: 0.96;
        text-wrap: balance;
      }

      .principles {
        display: grid;
        grid-template-columns: 0.9fr 1.1fr;
        gap: 70px;
        background: var(--white);
      }

      .principle-list {
        display: grid;
        gap: 26px;
      }

      .principle-list article {
        padding-bottom: 26px;
        border-bottom: 1px solid var(--line);
      }

      .principle-list p {
        margin: 0;
      }

      .sale-time {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(340px, 0.72fr);
        gap: 72px;
        align-items: end;
        background: var(--paper-strong);
      }

      .sale-time h2 {
        max-width: 880px;
        margin-bottom: 0;
      }

      .sale-time > p {
        margin: 0;
        font-size: 18px;
      }

      .listings {
        overflow: hidden;
        background: var(--paper);
      }

      .listing-groups {
        display: grid;
        gap: 54px;
        margin-top: 48px;
      }

      .listing-group {
        display: grid;
        gap: 18px;
      }

      .listing-group-heading {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 18px;
        border-bottom: 1px solid var(--line);
        padding-bottom: 14px;
      }

      .listing-group-heading .eyebrow {
        margin-bottom: 0;
      }

      .listing-section-title {
        margin: 0;
        font-family: var(--font-display);
        font-size: clamp(30px, 3vw, 42px);
        font-weight: 650;
        line-height: 0.98;
      }

      .listing-group-heading > div:first-child {
        display: grid;
        gap: 6px;
      }

      .listing-group-heading span {
        color: var(--muted);
        font-size: 14px;
        font-weight: 700;
      }

      .carousel-controls {
        display: flex;
        gap: 8px;
      }

      .carousel-button {
        display: inline-grid;
        width: 44px;
        height: 44px;
        place-items: center;
        border: 1px solid rgba(11, 11, 10, 0.22);
        border-radius: 999px;
        background: rgba(255, 250, 242, 0.72);
        color: var(--ink);
        cursor: pointer;
        font: inherit;
        font-size: 28px;
        line-height: 1;
        transition: background 160ms ease, border-color 160ms ease, transform 160ms ease;
      }

      .carousel-button:hover {
        border-color: var(--brass-muted);
        background: var(--brass);
        transform: translateY(-1px);
      }

      .listing-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
      }

      .listing-carousel {
        display: flex;
        gap: 18px;
        overflow-x: auto;
        padding: 2px 0 16px;
        scroll-behavior: smooth;
        scroll-padding-inline: 1px;
        scroll-snap-type: x mandatory;
        scrollbar-width: none;
      }

      .listing-carousel::-webkit-scrollbar {
        display: none;
      }

      .listing-carousel .listing {
        flex: 0 0 clamp(330px, 32vw, 390px);
        scroll-snap-align: start;
      }

      .listing {
        overflow: hidden;
        min-width: 0;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--white);
        transition: border-color 180ms ease, transform 180ms ease, box-shadow 180ms ease;
      }

      .listing a {
        display: grid;
        height: 100%;
      }

      .listing:hover {
        border-color: rgba(154, 92, 50, 0.42);
        box-shadow: 0 18px 44px rgba(11, 11, 10, 0.11);
        transform: translateY(-2px);
      }

      .listing img {
        width: 100%;
        aspect-ratio: 4 / 3;
        object-fit: cover;
        transition: transform 240ms ease;
      }

      .listing:hover img {
        transform: scale(1.03);
      }

      .listing a > div {
        display: grid;
        align-content: start;
        padding: 20px;
      }

      .listing p {
        margin-bottom: 12px;
        color: var(--wine);
        font-size: 13px;
        font-weight: 700;
      }

      .listing dl {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin: 18px 0;
      }

      .listing dt {
        color: var(--muted);
        font-size: 13px;
      }

      .listing dd {
        margin: 0;
        font-weight: 700;
      }

      .listing span {
        display: block;
        color: var(--muted);
        font-size: 14px;
      }

      .listing strong {
        display: inline-flex;
        margin-top: 18px;
        color: var(--wine);
        font-weight: 800;
        text-decoration: underline;
        text-underline-offset: 5px;
      }

      .listing.sold {
        background: rgba(255, 250, 242, 0.62);
      }

      .listing-empty {
        display: grid;
        min-height: 190px;
        grid-column: 1 / -1;
        align-content: center;
        gap: 8px;
        border: 1px dashed rgba(11, 11, 10, 0.22);
        border-radius: 8px;
        padding: 26px;
        background: rgba(255, 250, 242, 0.44);
      }

      .listing-empty p {
        margin: 0;
        color: var(--ink);
        font-size: 22px;
        font-weight: 800;
        line-height: 1.15;
      }

      .listing-empty span {
        color: var(--muted);
      }

      .listing-empty .button {
        justify-self: start;
        margin-top: 12px;
      }

      .consultation-cta {
        display: grid;
        grid-template-columns: minmax(0, 0.92fr) minmax(320px, 0.64fr);
        gap: 56px;
        align-items: end;
        background:
          linear-gradient(110deg, rgba(11, 11, 10, 0.96), rgba(27, 27, 25, 0.9)),
          var(--ink);
        color: var(--white);
      }

      .consultation-cta .eyebrow {
        color: var(--brass);
      }

      .consultation-cta h2 {
        max-width: 860px;
        margin-bottom: 0;
      }

      .consultation-card {
        display: grid;
        gap: 18px;
        border: 1px solid rgba(255, 250, 242, 0.16);
        border-radius: 8px;
        padding: clamp(22px, 3vw, 32px);
        background: rgba(255, 250, 242, 0.07);
      }

      .consultation-card p {
        margin: 0;
        color: rgba(255, 250, 242, 0.72);
      }

      .contact-section {
        display: grid;
        grid-template-columns: 0.9fr 1.1fr;
        gap: 70px;
        padding: 110px max(28px, calc((100vw - 1180px) / 2));
        background: var(--ink);
        color: var(--white);
      }

      .contact-copy {
        align-self: start;
        position: sticky;
        top: 120px;
      }

      .contact-copy .eyebrow {
        color: #e7c385;
      }

      .contact-copy p {
        color: rgba(255, 250, 242, 0.72);
      }

      .direct-contact {
        display: grid;
        gap: 10px;
        margin-top: 32px;
        max-width: 420px;
      }

      .direct-contact p {
        margin: 0 0 4px;
        color: #e7c385;
        font-size: 13px;
        font-weight: 800;
      }

      .direct-contact a {
        display: grid;
        gap: 2px;
        border: 1px solid rgba(255, 250, 242, 0.14);
        border-radius: 8px;
        padding: 12px 14px;
        background: rgba(255, 250, 242, 0.05);
      }

      .direct-contact span {
        color: rgba(255, 250, 242, 0.58);
        font-size: 12px;
        font-weight: 800;
      }

      .direct-contact strong {
        color: rgba(255, 250, 242, 0.9);
        font-size: 15px;
        font-weight: 750;
      }

      .booking-panel {
        display: grid;
        align-self: start;
        gap: 18px;
        border: 1px solid rgba(255, 250, 242, 0.18);
        border-radius: 8px;
        padding: clamp(26px, 4vw, 42px);
        background: rgba(255, 250, 242, 0.07);
      }

      .booking-panel .eyebrow,
      .booking-panel h3,
      .booking-panel p {
        margin: 0;
      }

      .booking-panel .eyebrow {
        color: #e7c385;
      }

      .booking-panel h3 {
        max-width: 520px;
        font-family: var(--font-display);
        font-size: clamp(36px, 4vw, 58px);
        font-weight: 650;
        line-height: 0.98;
      }

      .booking-panel p:not(.eyebrow) {
        max-width: 460px;
        color: rgba(255, 250, 242, 0.7);
        font-size: 17px;
      }

      .booking-panel .button {
        width: 100%;
        margin-top: 6px;
      }

      .contact-form {
        display: grid;
        gap: 16px;
        margin-top: 4px;
      }

      .form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
      }

      .contact-form label {
        display: grid;
        gap: 7px;
      }

      .contact-form label.full {
        grid-column: 1 / -1;
      }

      .contact-form span {
        color: rgba(255, 250, 242, 0.62);
        font-size: 12px;
        font-weight: 800;
      }

      .contact-form input,
      .contact-form select,
      .contact-form textarea {
        width: 100%;
        border: 1px solid rgba(255, 250, 242, 0.16);
        border-radius: 6px;
        background: rgba(11, 11, 10, 0.28);
        color: var(--white);
        font: inherit;
      }

      .contact-form input,
      .contact-form select {
        min-height: 48px;
        padding: 0 13px;
      }

      .contact-form select {
        appearance: none;
        background-image:
          linear-gradient(45deg, transparent 50%, rgba(255, 250, 242, 0.72) 50%),
          linear-gradient(135deg, rgba(255, 250, 242, 0.72) 50%, transparent 50%);
        background-position:
          calc(100% - 18px) 20px,
          calc(100% - 13px) 20px;
        background-repeat: no-repeat;
        background-size: 5px 5px, 5px 5px;
      }

      .contact-form textarea {
        min-height: 118px;
        padding: 12px 13px;
        resize: vertical;
      }

      .contact-form input::placeholder,
      .contact-form textarea::placeholder {
        color: rgba(255, 250, 242, 0.36);
      }

      .contact-form input:focus,
      .contact-form select:focus,
      .contact-form textarea:focus {
        border-color: rgba(216, 184, 120, 0.72);
        outline: none;
      }

      footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        padding: 26px max(28px, calc((100vw - 1180px) / 2)) 110px;
        background: #0b0b0a;
        color: rgba(255, 250, 242, 0.72);
      }

      footer p {
        margin: 0;
      }

      .footer-brand {
        display: flex;
        align-items: center;
        gap: 16px;
      }

      .footer-links {
        display: grid;
        justify-items: end;
        gap: 8px;
      }

      .social-icon {
        display: inline-grid;
        width: 38px;
        height: 38px;
        place-items: center;
        border: 1px solid rgba(255, 250, 242, 0.2);
        border-radius: 999px;
        color: rgba(255, 250, 242, 0.78);
        transition: border-color 160ms ease, color 160ms ease, transform 160ms ease;
      }

      .social-icon svg {
        width: 19px;
        height: 19px;
        fill: none;
        stroke: currentColor;
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-width: 1.8;
      }

      .social-icon:hover {
        border-color: var(--brass);
        color: var(--brass);
        transform: translateY(-1px);
      }

      .social-icon.is-disabled {
        cursor: default;
        opacity: 0.42;
        transform: none;
      }

      .social-icon.is-disabled:hover {
        border-color: rgba(255, 250, 242, 0.2);
        color: rgba(255, 250, 242, 0.78);
      }

      .footer-brand img {
        width: 118px;
        height: 52px;
        object-fit: contain;
      }

      .footer-brand p {
        color: var(--white);
        font-family: var(--font-display);
        font-size: 24px;
        font-weight: 650;
      }

      .mobile-cta {
        display: none;
      }

      [data-reveal] {
        opacity: 1;
        transform: none;
        transition: opacity 700ms ease, transform 700ms ease;
      }

      :global(html.js) [data-reveal] {
        opacity: 0;
        transform: translateY(18px);
      }

      :global(html.js) [data-reveal].is-visible,
      [data-reveal].is-visible {
        opacity: 1;
        transform: translateY(0);
      }

      :global(html.js) .hero [data-reveal] {
        opacity: 1;
        transform: none;
        transition: none;
      }

      @media (prefers-reduced-motion: no-preference) {
        :global(html.js) .hero-visual {
          animation: heroVisualIn 900ms cubic-bezier(0.2, 0.75, 0.24, 1) 120ms both;
        }

        :global(html.js) .hero-visual > img {
          animation: heroImageSettle 1400ms cubic-bezier(0.2, 0.75, 0.24, 1) 120ms both;
          transform-origin: center top;
        }

        :global(html.js) .proof-strip p {
          transition-delay: 0ms;
          transition-duration: 620ms;
          transition-timing-function: cubic-bezier(0.2, 0.75, 0.24, 1);
        }

        :global(html.js) .proof-strip p:nth-child(2) {
          transition-delay: 90ms;
        }

        :global(html.js) .proof-strip p:nth-child(3) {
          transition-delay: 180ms;
        }
      }

      @keyframes heroVisualIn {
        from {
          opacity: 0;
          transform: translateY(18px) scale(0.985);
        }

        to {
          opacity: 1;
          transform: translateY(0) scale(1);
        }
      }

      @keyframes heroImageSettle {
        from {
          transform: scale(1.035);
        }

        to {
          transform: scale(1);
        }
      }

      @media (max-width: 980px) {
        .site-header {
          position: absolute;
          top: 12px;
        }

        nav {
          display: none;
        }

        .header-phone {
          min-height: 38px;
          padding: 0 12px;
          font-size: 14px;
        }

        .hero,
        .backing,
        .split,
        .track-record,
        .positioning-panel,
        .principles,
        .sale-time,
        .consultation-cta,
        .contact-section {
          grid-template-columns: 1fr;
        }

        .hero {
          gap: 26px;
          padding-top: 102px;
        }

        .hero-copy,
        .hero-visual {
          grid-column: 1;
        }

        .hero-copy {
          max-width: none;
          padding: 18px 0 0;
        }

        h1 {
          font-size: 62px;
        }

        h2 {
          font-size: 42px;
        }

        .promise {
          font-size: 31px;
        }

        .hero-visual {
          height: clamp(430px, 62svh, 560px);
        }

        .proof-strip,
        .process-grid {
          grid-template-columns: 1fr;
        }

        .proof-strip {
          padding: 0 18px;
        }

        .proof-strip p {
          min-height: 74px;
          padding: 0;
          border-right: 0;
          border-bottom: 1px solid rgba(255, 250, 242, 0.14);
        }

        .city-panorama {
          min-height: 138px;
          background-position: center 66%;
        }

        .service {
          grid-template-columns: 1fr;
          gap: 10px;
        }

        .backing {
          gap: 38px;
        }

        .track-record,
        .positioning-panel,
        .sale-time {
          gap: 34px;
        }

        .listing-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .listing-carousel .listing {
          flex-basis: min(420px, 58vw);
        }

        .positioning-panel p {
          max-width: none;
          align-self: start;
        }

        .contact-copy {
          position: static;
        }

        .mobile-cta.is-visible {
          opacity: 1;
          pointer-events: auto;
          transform: translateY(0);
        }
      }

      @media (max-width: 620px) {
        .site-header {
          width: calc(100% - 20px);
          min-height: 58px;
          gap: 10px;
        }

        .brand-label span {
          font-size: 21px;
        }

        .brand-label {
          display: none;
        }

        .hero,
        .section,
        .contact-section {
          padding-left: 18px;
          padding-right: 18px;
        }

        .hero {
          min-height: auto;
          padding-top: 96px;
          padding-bottom: 40px;
        }

        h1 {
          font-size: 48px;
        }

        h2 {
          font-size: 34px;
          line-height: 1;
        }

        .promise {
          font-size: 28px;
        }

        .intro {
          font-size: 16px;
        }

        .stat-item {
          grid-template-columns: 1fr;
          gap: 10px;
        }

        .stat-item strong {
          font-size: 46px;
        }

        .positioning-panel h3 {
          font-size: 34px;
        }

        .hero-actions,
        footer {
          grid-template-columns: 1fr;
        }

        .hero-actions {
          display: grid;
        }

        .button {
          width: 100%;
        }

        .hero-visual {
          height: 390px;
        }

        .portrait-note {
          right: 12px;
          top: auto;
          bottom: 12px;
          width: calc(100% - 24px);
          padding: 14px;
        }

        .section,
        .contact-section {
          padding-top: 72px;
          padding-bottom: 72px;
        }

        .city-panorama {
          min-height: 116px;
          background-position: center center;
          background-size: auto 100%;
        }

        .process-item {
          min-height: 260px;
        }

        .process-item span {
          margin-bottom: 42px;
        }

        .image-band {
          min-height: 620px;
          padding: 48px 18px;
          background:
            linear-gradient(180deg, rgba(30, 28, 25, 0.1), rgba(30, 28, 25, 0.72)),
            var(--band-image) 44% 8%/cover;
        }

        .image-band div {
          width: min(100%, 700px);
        }

        .image-band h2 {
          max-width: 100%;
          font-size: clamp(38px, 12vw, 58px);
          line-height: 0.96;
        }

        .listing-grid {
          grid-template-columns: 1fr;
        }

        .backing-grid {
          grid-template-columns: 1fr;
        }

        .backing-item {
          min-height: 0;
        }

        .listing-group-heading {
          display: grid;
          align-items: start;
          gap: 6px;
        }

        .carousel-controls {
          justify-self: start;
        }

        .carousel-button {
          width: 42px;
          height: 42px;
        }

        .listing-carousel {
          margin-right: -18px;
          padding-right: 18px;
        }

        .listing-carousel .listing {
          flex-basis: min(84vw, 340px);
        }

        .listing dl {
          grid-template-columns: 1fr;
        }

        .booking-panel .button {
          width: 100%;
        }

        .form-grid {
          grid-template-columns: 1fr;
        }

        .mobile-cta {
          position: fixed;
          right: 18px;
          bottom: 16px;
          left: 18px;
          z-index: 60;
          display: inline-flex;
          min-height: 52px;
          align-items: center;
          justify-content: center;
          border: 1px solid rgba(11, 11, 10, 0.16);
          border-radius: 6px;
          background: var(--brass);
          color: var(--ink);
          box-shadow: 0 18px 36px rgba(11, 11, 10, 0.22);
          font-weight: 800;
          opacity: 0;
          pointer-events: none;
          transform: translateY(12px);
          transition: opacity 180ms ease, transform 180ms ease;
        }

        footer {
          display: grid;
          padding-bottom: 150px;
        }

        .footer-links {
          justify-items: start;
        }

        .brand-mark {
          width: 82px;
        }

        .header-phone {
          padding: 0 10px;
          font-size: 13px;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }

        *,
        *::before,
        *::after {
          transition-duration: 0.01ms !important;
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
        }

        [data-reveal] {
          opacity: 1;
          transform: none;
        }
      }
    </style>
  </body>
</html>
