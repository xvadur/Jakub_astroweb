      }

      .section {
        padding: 110px max(28px, calc((100vw - 1180px) / 2));
      }

      .split {
        display: grid;
        grid-template-columns: 0.8fr 1.2fr;
        gap: 70px;
      }

      .section-heading {
        max-width: 700px;
      }

      .section-heading p:not(.eyebrow),
      .contact-copy p,
      .principle-lead + .principle-list p {
        color: var(--muted);
      }

      .centered {
        max-width: 760px;
        margin: 0 auto 42px;
        text-align: center;
      }

      .service-list {
        display: grid;
        gap: 0;
        border-top: 1px solid var(--line);
      }

      .service {
        display: grid;
        grid-template-columns: 0.7fr 1fr;
        gap: 32px;
        padding: 28px 0;
        border-bottom: 1px solid var(--line);
      }

      .service p {
        margin: 0;
        color: var(--muted);
      }

      .process-section {
        background: var(--paper-strong);
      }

      .process-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
      }

      .process-item {
        min-height: 320px;
        padding: 28px;
        border: 1px solid rgba(30, 28, 25, 0.18);
        border-radius: 8px;
        background: rgba(255, 250, 242, 0.45);
      }

      .process-item span {
        display: block;
        margin-bottom: 70px;
        color: var(--wine);
        font-family: var(--font-display);
        font-size: 42px;
      }

      .process-item p {
        color: var(--muted);
      }

      .image-band {
        min-height: 760px;
        display: flex;
        align-items: flex-end;
        padding: 70px max(28px, calc((100vw - 1180px) / 2));
        color: var(--white);
        background:
          linear-gradient(90deg, rgba(30, 28, 25, 0.78) 0%, rgba(30, 28, 25, 0.52) 42%, rgba(30, 28, 25, 0.2) 74%),
          linear-gradient(180deg, rgba(30, 28, 25, 0.04), rgba(30, 28, 25, 0.58)),
          var(--band-image) 60% 10%/cover;
      }

      .image-band div {
        width: min(100%, 920px);
        max-width: none;
      }

      .image-band .eyebrow {
        color: #e7c385;
      }

      .image-band h2 {
        margin: 0;
        max-width: min(920px, 66vw);
        font-size: clamp(46px, 5.2vw, 76px);
        line-height: 0.96;
        text-wrap: balance;
      }

      .principles {
        display: grid;
        grid-template-columns: 0.9fr 1.1fr;
        gap: 70px;
        background: var(--white);
      }

      .principle-list {
        display: grid;
        gap: 26px;
      }

      .principle-list article {
        padding-bottom: 26px;
        border-bottom: 1px solid var(--line);
      }

      .principle-list p {
        margin: 0;
      }

      .sale-time {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(340px, 0.72fr);
        gap: 72px;
        align-items: end;
        background: var(--paper-strong);
      }

      .sale-time h2 {
        max-width: 880px;
        margin-bottom: 0;
      }

      .sale-time > p {
        margin: 0;
        font-size: 18px;
      }

      .listings {
        overflow: hidden;
        background: var(--paper);
      }

      .listing-groups {
        display: grid;
        gap: 54px;
        margin-top: 48px;
      }

      .listing-group {
        display: grid;
        gap: 18px;
      }

      .listing-group-heading {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 18px;
        border-bottom: 1px solid var(--line);
        padding-bottom: 14px;
      }

      .listing-group-heading .eyebrow {
        margin-bottom: 0;
      }

      .listing-section-title {
        margin: 0;
        font-family: var(--font-display);
        font-size: clamp(30px, 3vw, 42px);
        font-weight: 650;
        line-height: 0.98;
      }

      .listing-group-heading > div:first-child {
        display: grid;
        gap: 6px;
      }

      .listing-group-heading span {
        color: var(--muted);
        font-size: 14px;
        font-weight: 700;
      }

      .carousel-controls {
        display: flex;
        gap: 8px;
      }

      .carousel-button {
        display: inline-grid;
        width: 44px;
        height: 44px;
        place-items: center;
        border: 1px solid rgba(11, 11, 10, 0.22);
        border-radius: 999px;
        background: rgba(255, 250, 242, 0.72);
        color: var(--ink);
        cursor: pointer;
        font: inherit;
        font-size: 28px;
        line-height: 1;
        transition: background 160ms ease, border-color 160ms ease, transform 160ms ease;
      }

      .carousel-button:hover {
        border-color: var(--brass-muted);
        background: var(--brass);
        transform: translateY(-1px);
      }

      .listing-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
      }

      .listing-carousel {
        display: flex;
        gap: 18px;
        overflow-x: auto;
        padding: 2px 0 16px;
        scroll-behavior: smooth;
        scroll-padding-inline: 1px;
        scroll-snap-type: x mandatory;
        scrollbar-width: none;
      }

      .listing-carousel::-webkit-scrollbar {
        display: none;
      }

      .listing-carousel .listing {
        flex: 0 0 clamp(330px, 32vw, 390px);
        scroll-snap-align: start;
      }

      .listing {
        overflow: hidden;
        min-width: 0;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--white);
        transition: border-color 180ms ease, transform 180ms ease, box-shadow 180ms ease;
      }

      .listing a {
        display: grid;
        height: 100%;
      }

      .listing:hover {
        border-color: rgba(154, 92, 50, 0.42);
        box-shadow: 0 18px 44px rgba(11, 11, 10, 0.11);
        transform: translateY(-2px);
      }

      .listing img {
        width: 100%;
        aspect-ratio: 4 / 3;
        object-fit: cover;
        transition: transform 240ms ease;
      }

      .listing:hover img {
        transform: scale(1.03);
      }

      .listing a > div {
        display: grid;
        align-content: start;
        padding: 20px;
      }

      .listing p {
        margin-bottom: 12px;
        color: var(--wine);
        font-size: 13px;
        font-weight: 700;
      }

      .listing dl {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin: 18px 0;
      }

      .listing dt {
        color: var(--muted);
        font-size: 13px;
      }

      .listing dd {
        margin: 0;
        font-weight: 700;
      }

      .listing span {
        display: block;
        color: var(--muted);
        font-size: 14px;
      }

      .listing strong {
        display: inline-flex;
        margin-top: 18px;
        color: var(--wine);
        font-weight: 800;
        text-decoration: underline;
        text-underline-offset: 5px;
      }

      .listing.sold {
        background: rgba(255, 250, 242, 0.62);
      }

      .listing-empty {
        display: grid;
        min-height: 190px;
        grid-column: 1 / -1;
        align-content: center;
        gap: 8px;
        border: 1px dashed rgba(11, 11, 10, 0.22);
        border-radius: 8px;
        padding: 26px;
        background: rgba(255, 250, 242, 0.44);
      }

      .listing-empty p {
        margin: 0;
        color: var(--ink);
        font-size: 22px;
        font-weight: 800;
        line-height: 1.15;
      }

      .listing-empty span {
        color: var(--muted);
      }

      .listing-empty .button {
        justify-self: start;
        margin-top: 12px;
      }

      .booking-funnel {
        display: grid;
        grid-template-columns: minmax(0, 0.86fr) minmax(0, 1.14fr);
        gap: 70px;
        align-items: start;
        padding: 110px max(28px, calc((100vw - 1180px) / 2));
        background:
          linear-gradient(135deg, rgba(11, 11, 10, 0.96), rgba(31, 34, 31, 0.94)),
          var(--ink);
        color: var(--white);
      }

      .funnel-copy {
        position: sticky;
        top: 120px;
        display: grid;
        gap: 18px;
      }

      .funnel-copy .eyebrow {
        margin: 0;
        color: var(--brass);
      }

      .funnel-copy h2 {
        margin: 0;
        max-width: 680px;
      }

      .funnel-copy > p {
        max-width: 560px;
        margin: 0;
        color: rgba(255, 250, 242, 0.72);
        font-size: 18px;
      }

      .funnel-copy ul {
        display: grid;
        gap: 10px;
        max-width: 520px;
        margin: 10px 0 0;
        padding: 0;
        list-style: none;
      }

      .funnel-copy li {
        position: relative;
        min-height: 42px;
        padding: 10px 12px 10px 34px;
        border: 1px solid rgba(255, 250, 242, 0.14);
        border-radius: 8px;
        background: rgba(255, 250, 242, 0.05);
        color: rgba(255, 250, 242, 0.84);
        font-weight: 700;
      }

      .funnel-copy li::before {
        position: absolute;
        top: 17px;
        left: 14px;
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: var(--brass);
        content: "";
      }

      .funnel-card {
        display: grid;
        gap: 18px;
        border: 1px solid rgba(255, 250, 242, 0.18);
        border-radius: 8px;
        padding: clamp(22px, 4vw, 38px);
        background: rgba(255, 250, 242, 0.08);
        box-shadow: 0 24px 70px rgba(0, 0, 0, 0.24);
      }

      .funnel-progress {
        display: grid;
        gap: 10px;
      }

      .funnel-progress span {
        color: var(--brass);
        font-size: 13px;
        font-weight: 900;
      }

      .funnel-progress div {
        height: 8px;
        overflow: hidden;
        border-radius: 999px;
        background: rgba(255, 250, 242, 0.12);
      }

      .funnel-progress i {
        display: block;
        width: 25%;
        height: 100%;
        border-radius: inherit;
        background: var(--brass);
        transition: width 180ms ease;
      }

      .funnel-error {
        min-height: 22px;
        margin: 0;
        color: #ffd38c;
        font-size: 14px;
        font-weight: 800;
      }

      .funnel-step {
        display: grid;
        gap: 16px;
      }

      .funnel-step[hidden] {
        display: none;
      }

      .step-kicker,
      .funnel-step > p:not(.step-kicker) {
        margin: 0;
      }

      .step-kicker {
        color: var(--brass);
        font-size: 13px;
        font-weight: 900;
      }

      .funnel-step h3 {
        margin: 0;
        max-width: 620px;
        font-family: var(--font-display);
        font-size: clamp(34px, 3.8vw, 52px);
        font-weight: 650;
        line-height: 0.98;
      }

      .funnel-step > p:not(.step-kicker) {
        max-width: 540px;
        color: rgba(255, 250, 242, 0.72);
      }

      .choice-grid,
      .slot-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
      }

      .choice-grid.compact {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .choice-button,
      .slot-button {
        min-height: 54px;
        border: 1px solid rgba(255, 250, 242, 0.18);
        border-radius: 8px;
        padding: 12px 14px;
        background: rgba(11, 11, 10, 0.24);
        color: rgba(255, 250, 242, 0.86);
        cursor: pointer;
        font: inherit;
        font-weight: 800;
        line-height: 1.18;
        text-align: left;
        transition: background 160ms ease, border-color 160ms ease, color 160ms ease, transform 160ms ease;
      }

      .slot-button {
        display: grid;
        min-height: 58px;
        place-items: center;
        text-align: center;
        font-size: 19px;
      }

      .choice-button:hover,
      .slot-button:hover,
      .choice-button.is-selected,
      .slot-button.is-selected {
        border-color: rgba(216, 184, 120, 0.78);
        background: rgba(216, 184, 120, 0.16);
        color: var(--white);
        transform: translateY(-1px);
      }

      .funnel-fields {
        display: grid;
        gap: 12px;
      }

      .funnel-fields.two {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .funnel-fields label {
        display: grid;
        gap: 7px;
      }

      .funnel-fields label.full {
        grid-column: 1 / -1;
      }

      .funnel-fields span {
        color: rgba(255, 250, 242, 0.64);
        font-size: 12px;
        font-weight: 850;
      }

      .funnel-fields input,
      .funnel-fields select,
      .funnel-fields textarea {
        width: 100%;
        border: 1px solid rgba(255, 250, 242, 0.16);
        border-radius: 6px;
        background: rgba(11, 11, 10, 0.28);
        color: var(--white);
        color-scheme: dark;
        font: inherit;
      }

      .funnel-fields input,
      .funnel-fields select {
        min-height: 48px;
        padding: 0 13px;
      }

      .funnel-fields textarea {
        min-height: 118px;
        padding: 12px 13px;
        resize: vertical;
      }

      .funnel-fields input::placeholder,
      .funnel-fields textarea::placeholder {
        color: rgba(255, 250, 242, 0.36);
      }

      .funnel-fields input:focus,
      .funnel-fields select:focus,
      .funnel-fields textarea:focus {
        border-color: rgba(216, 184, 120, 0.72);
        outline: none;
      }

      .funnel-summary {
        min-height: 24px;
        color: rgba(255, 250, 242, 0.66);
        font-size: 13px;
        font-weight: 750;
      }

      .funnel-actions {
        display: flex;
        gap: 10px;
        justify-content: space-between;
      }

      .funnel-actions .button {
        min-width: 150px;
        border-color: rgba(255, 250, 242, 0.26);
        color: var(--white);
        cursor: pointer;
        font: inherit;
      }

      .funnel-actions .button.primary {
        border-color: var(--brass);
        color: var(--ink);
      }

      .funnel-actions .button:disabled {
        cursor: not-allowed;
        opacity: 0.42;
        transform: none;
      }

      .contact-section {
        display: grid;
        grid-template-columns: 0.9fr 1.1fr;
        gap: 70px;
        padding: 110px max(28px, calc((100vw - 1180px) / 2));
        background: var(--ink);
        color: var(--white);
      }

      .contact-copy {
        align-self: start;
        position: sticky;
        top: 120px;
      }

      .contact-copy .eyebrow {
        color: #e7c385;
      }

      .contact-copy p {
        color: rgba(255, 250, 242, 0.72);
      }

      .direct-contact {
        display: grid;
        gap: 10px;
        margin-top: 32px;
        max-width: 420px;
      }

      .direct-contact p {
        margin: 0 0 4px;
        color: #e7c385;
        font-size: 13px;
        font-weight: 800;
      }

      .direct-contact a {
        display: grid;
        gap: 2px;
        border: 1px solid rgba(255, 250, 242, 0.14);
        border-radius: 8px;
        padding: 12px 14px;
        background: rgba(255, 250, 242, 0.05);
      }

      .direct-contact span {
        color: rgba(255, 250, 242, 0.58);
        font-size: 12px;
        font-weight: 800;
      }

      .direct-contact strong {
        color: rgba(255, 250, 242, 0.9);
        font-size: 15px;
        font-weight: 750;
      }

      .booking-panel {
        display: grid;
        align-self: start;
        gap: 18px;
        border: 1px solid rgba(255, 250, 242, 0.18);
        border-radius: 8px;
        padding: clamp(26px, 4vw, 42px);
        background: rgba(255, 250, 242, 0.07);
      }

      .booking-panel .eyebrow,
      .booking-panel h3,
      .booking-panel p {
        margin: 0;
      }

      .booking-panel .eyebrow {
        color: #e7c385;
      }

      .booking-panel h3 {
        max-width: 520px;
        font-family: var(--font-display);
        font-size: clamp(36px, 4vw, 58px);
        font-weight: 650;
        line-height: 0.98;
      }

      .booking-panel p:not(.eyebrow) {
        max-width: 460px;
        color: rgba(255, 250, 242, 0.7);
        font-size: 17px;
      }

      .booking-panel .button {
        width: 100%;
        margin-top: 6px;
      }

      .contact-form {
        display: grid;
        gap: 16px;
        margin-top: 4px;
      }

      .form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
      }

      .contact-form label {
        display: grid;
        gap: 7px;
      }

      .contact-form label.full {
        grid-column: 1 / -1;
      }

      .contact-form span {
        color: rgba(255, 250, 242, 0.62);
        font-size: 12px;
        font-weight: 800;
      }

      .contact-form input,
      .contact-form select,
      .contact-form textarea {
        width: 100%;
        border: 1px solid rgba(255, 250, 242, 0.16);
        border-radius: 6px;
        background: rgba(11, 11, 10, 0.28);
        color: var(--white);
        font: inherit;
      }

      .contact-form input,
      .contact-form select {
        min-height: 48px;
        padding: 0 13px;
      }

      .contact-form select {
        appearance: none;
        background-image:
          linear-gradient(45deg, transparent 50%, rgba(255, 250, 242, 0.72) 50%),
          linear-gradient(135deg, rgba(255, 250, 242, 0.72) 50%, transparent 50%);
        background-position:
          calc(100% - 18px) 20px,
          calc(100% - 13px) 20px;
        background-repeat: no-repeat;
        background-size: 5px 5px, 5px 5px;
      }

      .contact-form textarea {
        min-height: 118px;
        padding: 12px 13px;
        resize: vertical;
      }

      .contact-form input::placeholder,
      .contact-form textarea::placeholder {
        color: rgba(255, 250, 242, 0.36);
      }

      .contact-form input:focus,
      .contact-form select:focus,
      .contact-form textarea:focus {
        border-color: rgba(216, 184, 120, 0.72);
        outline: none;
      }

      footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        padding: 26px max(28px, calc((100vw - 1180px) / 2)) 110px;
        background: #0b0b0a;
        color: rgba(255, 250, 242, 0.72);
      }

      footer p {
        margin: 0;
      }

      .footer-brand {
        display: flex;
        align-items: center;
        gap: 16px;
      }

      .footer-links {
        display: grid;
        justify-items: end;
        gap: 8px;
      }

      .social-icon {
        display: inline-grid;
        width: 38px;
        height: 38px;
        place-items: center;
        border: 1px solid rgba(255, 250, 242, 0.2);
        border-radius: 999px;
        color: rgba(255, 250, 242, 0.78);
        transition: border-color 160ms ease, color 160ms ease, transform 160ms ease;
      }

      .social-icon svg {
        width: 19px;
        height: 19px;
        fill: none;
        stroke: currentColor;
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-width: 1.8;
      }

      .social-icon:hover {
        border-color: var(--brass);
        color: var(--brass);
        transform: translateY(-1px);
      }

      .social-icon.is-disabled {
        cursor: default;
        opacity: 0.42;
        transform: none;
      }

      .social-icon.is-disabled:hover {
        border-color: rgba(255, 250, 242, 0.2);
        color: rgba(255, 250, 242, 0.78);
      }

      .footer-brand img {
        width: 118px;
        height: 52px;
        object-fit: contain;
      }

      .footer-brand p {
        color: var(--white);
        font-family: var(--font-display);
        font-size: 24px;
        font-weight: 650;
      }

      .mobile-cta {
        display: none;
      }

      [data-reveal] {
        opacity: 1;
        transform: none;
        transition: opacity 700ms ease, transform 700ms ease;
      }

      :global(html.js) [data-reveal] {
        opacity: 0;
        transform: translateY(18px);
      }

      :global(html.js) [data-reveal].is-visible,
      [data-reveal].is-visible {
        opacity: 1;
        transform: translateY(0);
      }

      :global(html.js) .hero [data-reveal] {
        opacity: 1;
        transform: none;
        transition: none;
      }

      @media (prefers-reduced-motion: no-preference) {
        :global(html.js) .hero-visual {
          animation: heroVisualIn 900ms cubic-bezier(0.2, 0.75, 0.24, 1) 120ms both;
        }

        :global(html.js) .hero-visual > img {
          animation: heroImageSettle 1400ms cubic-bezier(0.2, 0.75, 0.24, 1) 120ms both;
          transform-origin: center top;
        }

        :global(html.js) .proof-strip p {
          transition-delay: 0ms;
          transition-duration: 620ms;
          transition-timing-function: cubic-bezier(0.2, 0.75, 0.24, 1);
        }

        :global(html.js) .proof-strip p:nth-child(2) {
          transition-delay: 90ms;
        }

        :global(html.js) .proof-strip p:nth-child(3) {
          transition-delay: 180ms;
        }
      }

      @keyframes heroVisualIn {
        from {
          opacity: 0;
          transform: translateY(18px) scale(0.985);
        }

        to {
          opacity: 1;
          transform: translateY(0) scale(1);
        }
      }

      @keyframes heroImageSettle {
        from {
          transform: scale(1.035);
        }

        to {
          transform: scale(1);
        }
      }

      @media (max-width: 980px) {
        .site-header {
          position: absolute;
          top: 12px;
        }

        nav {
          display: none;
        }

        .header-phone {
          min-height: 38px;
          padding: 0 12px;
          font-size: 14px;
        }

        .hero,
        .backing,
        .split,
        .track-record,
        .positioning-panel,
        .principles,
        .sale-time,
        .booking-funnel,
        .contact-section {
          grid-template-columns: 1fr;
        }

        .hero {
          gap: 26px;
          padding-top: 102px;
        }

        .hero-copy,
        .hero-visual {
          grid-column: 1;
        }

        .hero-copy {
          max-width: none;
          padding: 18px 0 0;
        }

        h1 {
          font-size: 62px;
        }

        h2 {
          font-size: 42px;
        }

        .promise {
          font-size: 31px;
        }

        .hero-visual {
          height: clamp(430px, 62svh, 560px);
        }

        .proof-strip,
        .process-grid {
          grid-template-columns: 1fr;
        }

        .proof-strip {
          padding: 0 18px;
        }

        .proof-strip p {
          min-height: 74px;
          padding: 0;
          border-right: 0;
          border-bottom: 1px solid rgba(255, 250, 242, 0.14);
        }

        .city-panorama {
          min-height: 138px;
          background-position: center 66%;
        }

        .service {
          grid-template-columns: 1fr;
          gap: 10px;
        }

        .backing {
          gap: 38px;
        }

        .track-record,
        .positioning-panel,
        .sale-time {
          gap: 34px;
        }

        .listing-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .listing-carousel .listing {
          flex-basis: min(420px, 58vw);
        }

        .positioning-panel p {
          max-width: none;
          align-self: start;
        }

        .contact-copy {
          position: static;
        }

        .funnel-copy {
          position: static;
        }

        .mobile-cta.is-visible {
          opacity: 1;
          pointer-events: auto;
          transform: translateY(0);
        }
      }

      @media (max-width: 620px) {
        .site-header {
          width: calc(100% - 20px);
          min-height: 58px;
          gap: 10px;
        }

        .brand-label span {
          font-size: 21px;
        }

        .brand-label {
          display: none;
        }

        .hero,
        .section,
        .booking-funnel,
        .contact-section {
          padding-left: 18px;
          padding-right: 18px;
        }

        .hero {
          min-height: auto;
          padding-top: 96px;
          padding-bottom: 40px;
        }

        h1 {
          font-size: 48px;
        }

        h2 {
          font-size: 34px;
          line-height: 1;
        }

        .promise {
          font-size: 28px;
        }

        .intro {
          font-size: 16px;
        }

        .stat-item {
          grid-template-columns: 1fr;
          gap: 10px;
        }

        .stat-item strong {
          font-size: 46px;
        }

        .positioning-panel h3 {
          font-size: 34px;
        }

        .hero-actions,
        footer {
          grid-template-columns: 1fr;
        }

        .hero-actions {
          display: grid;
        }

        .button {
          width: 100%;
        }

        .hero-visual {
          height: 390px;
        }

        .portrait-note {
          right: 12px;
          top: auto;
          bottom: 12px;
          width: calc(100% - 24px);
          padding: 14px;
        }

        .section,
        .booking-funnel,
        .contact-section {
          padding-top: 72px;
          padding-bottom: 72px;
        }

        .city-panorama {
          min-height: 116px;
          background-position: center center;
          background-size: auto 100%;
        }

        .process-item {
          min-height: 260px;
        }

        .process-item span {
          margin-bottom: 42px;
        }

        .image-band {
          min-height: 620px;
          padding: 48px 18px;
          background:
            linear-gradient(180deg, rgba(30, 28, 25, 0.1), rgba(30, 28, 25, 0.72)),
            var(--band-image) 44% 8%/cover;
        }

        .image-band div {
          width: min(100%, 700px);
        }

        .image-band h2 {
          max-width: 100%;
          font-size: clamp(38px, 12vw, 58px);
          line-height: 0.96;
        }

        .listing-grid {
          grid-template-columns: 1fr;
        }

        .backing-grid {
          grid-template-columns: 1fr;
        }

        .backing-item {
          min-height: 0;
        }

        .listing-group-heading {
          display: grid;
          align-items: start;
          gap: 6px;
        }

        .carousel-controls {
          justify-self: start;
        }

        .carousel-button {
          width: 42px;
          height: 42px;
        }

        .listing-carousel {
          margin-right: -18px;
          padding-right: 18px;
        }

        .listing-carousel .listing {
          flex-basis: min(84vw, 340px);
        }

        .listing dl {
          grid-template-columns: 1fr;
        }

        .booking-panel .button {
          width: 100%;
        }

        .form-grid {
          grid-template-columns: 1fr;
        }

        .choice-grid,
        .choice-grid.compact,
        .slot-grid,
        .funnel-fields.two {
          grid-template-columns: 1fr;
        }

        .funnel-actions {
          display: grid;
        }

        .funnel-actions .button {
          width: 100%;
        }

        .mobile-cta {
          position: fixed;
          right: 18px;
          bottom: 16px;
          left: 18px;
          z-index: 60;
          display: inline-flex;
          min-height: 52px;
          align-items: center;
          justify-content: center;
          border: 1px solid rgba(11, 11, 10, 0.16);
          border-radius: 6px;
          background: var(--brass);
          color: var(--ink);
          box-shadow: 0 18px 36px rgba(11, 11, 10, 0.22);
          font-weight: 800;
          opacity: 0;
          pointer-events: none;
          transform: translateY(12px);
          transition: opacity 180ms ease, transform 180ms ease;
        }

        footer {
          display: grid;
          padding-bottom: 150px;
        }

        .footer-links {
          justify-items: start;
        }

        .brand-mark {
          width: 82px;
        }

        .header-phone {
          padding: 0 10px;
          font-size: 13px;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }

        *,
        *::before,
        *::after {
          transition-duration: 0.01ms !important;
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
        }

        [data-reveal] {
          opacity: 1;
          transform: none;
        }
      }
    </style>
  </body>
</html>
