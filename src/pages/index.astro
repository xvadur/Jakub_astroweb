---
import "../styles/global.css";
import CookieConsent from "../components/CookieConsent.astro";
import { site } from "../data/site";
import { createHomeJsonLd, createPageMeta, serializeJsonLd } from "../data/seo";

const hasInstagram = site.contact.instagram.startsWith("http");
const siteEnv = import.meta.env.PUBLIC_SITE_ENV ?? "production";
const isStaging = siteEnv !== "production";
const pageDescription = `${site.brand} je ${site.role}. ${site.shortPromise} Dohodnite si konzultáciu k predaju, kúpe alebo prenájmu nehnuteľnosti.`;
const pageMeta = createPageMeta({
  title: `${site.brand} | ${site.shortPromise}`,
  description: pageDescription,
  path: "/",
  image: site.heroImage,
});
const availableListings = site.listings.filter((listing) => listing.group === "available");
const soldListings = site.listings.filter((listing) => listing.group === "sold");
const availableListingsLabel =
  availableListings.length === 1
    ? "1 aktuálna ponuka"
    : availableListings.length > 1 && availableListings.length < 5
      ? `${availableListings.length} aktuálne ponuky`
      : availableListings.length > 0
        ? `${availableListings.length} aktuálnych ponúk`
        : "pripravené na doplnenie";
const jsonLd = createHomeJsonLd(pageMeta);
---

<!doctype html>
<html lang="sk">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="icon" type="image/png" href="/favicon.png?v=2" />
    <link rel="icon" href="/favicon.ico?v=2" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content={pageMeta.description}
    />
    <link rel="canonical" href={pageMeta.canonicalUrl} />
    <meta property="og:title" content={pageMeta.title} />
    <meta property="og:description" content={pageMeta.description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageMeta.canonicalUrl} />
    <meta property="og:image" content={pageMeta.imageUrl} />
    <meta property="og:locale" content={site.locale.replace("-", "_")} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageMeta.title} />
    <meta name="twitter:description" content={pageMeta.description} />
    <meta name="twitter:image" content={pageMeta.imageUrl} />
    {isStaging ? <meta name="robots" content="noindex,nofollow,noarchive" /> : null}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Newsreader:opsz,wght@6..72,500;6..72,650;6..72,700&display=swap"
      rel="stylesheet"
    />
    <title>{pageMeta.title}</title>
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
    <script type="application/ld+json" set:html={serializeJsonLd(jsonLd)} />
  </head>
  <body>
    <a class="skip-link" href="#top">Prejsť na obsah</a>
    {isStaging ? <div class="staging-ribbon" aria-hidden="true">STAGING</div> : null}

    <header class="site-header">
      <div class="brand-cluster">
        <a class="brand" href="#top" aria-label={`${site.brand}, úvod`}>
          <img class="brand-mark" src={site.logoImage} alt="" />
          <span class="brand-label">
            <span>{site.brand}</span>
            <small>{site.role}</small>
          </span>
        </a>
        <span class="brand-divider" aria-hidden="true"></span>
        <img class="bosen-logo header-bosen-logo" src={site.bosenGroupLogo} alt="BOSEN Group" />
      </div>
      <nav class="desktop-nav" aria-label="Hlavná navigácia">
        <a href="#servis">Servis</a>
        <a href="#ponuky">Ponuky</a>
        <a href="#proces">Proces</a>
        <a href="/rezervacia/">Konzultácia</a>
      </nav>
      <div class="header-actions">
        <a class="header-phone" href="/rezervacia/">Rezervácia</a>
        <button
          class="menu-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="site-menu"
          data-menu-toggle
        >
          <span>Menu</span>
          <i aria-hidden="true"></i>
        </button>
      </div>
    </header>

    <div class="site-menu" id="site-menu" data-site-menu aria-hidden="true">
      <button class="menu-scrim" type="button" data-menu-close aria-label="Zavrieť menu"></button>
      <aside class="menu-panel" aria-label="Hlavné menu">
        <div class="menu-panel-head">
          <p>Maklérsky systém</p>
          <button type="button" class="menu-close" data-menu-close aria-label="Zavrieť menu">Zavrieť</button>
        </div>
        <nav class="menu-nav" aria-label="Rozšírená navigácia">
          <a href="#servis" data-menu-link><span>01</span>Servis BOSEN</a>
          <a href="#sluzby" data-menu-link><span>02</span>Služby</a>
          <a href="#proces" data-menu-link><span>03</span>Proces</a>
          <a href="#ponuky" data-menu-link><span>04</span>Ponuky</a>
          <a href="/predaj-bytu-bratislava/" data-menu-link><span>05</span>Predaj bytu Bratislava</a>
          <a href="/dashboard/leady/" data-menu-link><span>06</span>Lead cockpit</a>
        </nav>
        <div class="menu-aside">
          <article>
            <span>agent</span>
            <strong>Lead nejde len do inboxu.</strong>
            <p>Rezervácia sa páruje s kalendárom, CRM, Telegram notifikáciou a pracovným follow-upom.</p>
          </article>
          <a class="menu-cta" href="/rezervacia/" data-menu-link>
            Rezervovať konzultáciu
            <span aria-hidden="true">↗</span>
          </a>
        </div>
      </aside>
    </div>

    <main id="top">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-copy" data-reveal>
          <p class="eyebrow">{site.heroStory.eyebrow}</p>
          <h1 id="hero-title">{site.heroStory.title}</h1>
          <p class="hero-lead">{site.heroStory.lead}</p>
          <div class="hero-beats" aria-label="Čo sa dozviete hneď na úvode">
            {
              site.heroStory.beats.map((beat) => (
                <article class="hero-beat">
                  <span>{beat.label}</span>
                  <div>
                    <h2>{beat.title}</h2>
                    <p>{beat.text}</p>
                  </div>
                </article>
              ))
            }
          </div>
          <div class="hero-actions" aria-label="Hlavné akcie">
            <a class="button primary" href="/rezervacia/">Rezervácia konzultácie</a>
            <a class="button secondary" href="#servis">Čo za vás prevezmem</a>
          </div>
        </div>
        <div class="hero-visual" data-reveal>
          <img src={site.heroImage} alt="Portrét realitného makléra Jakuba Olšu" />
          <div class="ai-system-card" aria-label="Ako systém spracuje dopyt">
            <p>AI-assisted workflow</p>
            <strong>Dopyt nezostane visieť v inboxe.</strong>
            <ol>
              {
                site.heroStory.systemSteps.map((step) => (
                  <li>{step}</li>
                ))
              }
            </ol>
          </div>
          <div class="portrait-note">
            <p>
              <strong>Jeden človek na vašej strane.</strong>
              Za mnou je marketing, právo, financovanie a realitné zázemie BOSEN Group.
            </p>
          </div>
        </div>
      </section>

      <section class="proof-strip" aria-label="Čo môžete čakať">
        {
          site.proofPoints.map((point) => (
            <p data-reveal>
              <span></span>
              {point}
            </p>
          ))
        }
      </section>

      <div
        class="city-panorama"
        aria-hidden="true"
        style={`--city-panorama-image: url('${site.cityPanoramaImage}')`}
      ></div>

      <section class="section backing" id="servis" aria-labelledby="backing-title">
        <div class="backing-lead" data-reveal>
          <p class="eyebrow">{site.backing.eyebrow}</p>
          <h2 id="backing-title">{site.backing.title}</h2>
          <p>{site.backing.text}</p>
        </div>
        <div class="backing-grid">
          {
            site.backing.items.map((item) => (
              <article class="backing-item" data-reveal>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section network-proof" aria-labelledby="network-title">
        <div class="network-copy" data-reveal>
          <p class="eyebrow">{site.network.eyebrow}</p>
          <h2 id="network-title">{site.network.title}</h2>
          <p>{site.network.text}</p>
          <a class="button primary" href="/rezervacia/">Prejsť moju situáciu</a>
        </div>
        <div class="network-list">
          {
            site.network.items.map((item) => (
              <article data-reveal>
                <span>{item.kicker}</span>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section split" id="sluzby">
        <div class="section-heading" data-reveal>
          <p class="eyebrow">Čo pre vás prevezmem</p>
          <h2>Nie každá situácia potrebuje rovnaké riešenie. Najprv vyberieme správnu stratégiu.</h2>
          <p>
            Služby nie sú zoznam položiek do ponuky. Sú to rozhodnutia, ktoré majú chrániť cenu, čas a pokoj
            majiteľa od prvého hovoru až po odovzdanie.
          </p>
          <a class="button primary service-cta" href="/rezervacia/">Prejsť moju situáciu</a>
        </div>
        <div class="service-list">
          {
            site.services.map((service) => (
              <article class="service" data-reveal>
                <h3>{service.title}</h3>
                <p>{service.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section process-section" id="proces">
        <div class="section-heading centered" data-reveal>
          <p class="eyebrow">Ako prebieha spolupráca</p>
          <h2>Rezervácia nie je koniec formulára. Je to začiatok riadeného procesu.</h2>
          <p>
            Toto je pracovný priebeh, ktorý ešte doladíme podľa Jakubovej presnej praxe. Už teraz však ukazuje,
            čo sa má stať po odoslaní konzultácie.
          </p>
        </div>
        <div class="process-grid">
          {
            site.process.map((item) => (
              <article class="process-item" data-reveal>
                <span>{item.step}</span>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))
          }
        </div>
        <div class="process-cta" data-reveal>
          <p>Ak chcete vedieť, ktorý z týchto krokov je pri vašej nehnuteľnosti najdôležitejší, začnime krátkym hovorom.</p>
          <a class="button primary" href="/rezervacia/">Rezervácia konzultácie</a>
        </div>
      </section>

      <section class="section trust-standards" aria-labelledby="trust-standards-title">
        <div class="trust-copy" data-reveal>
          <p class="eyebrow">{site.trustStandards.eyebrow}</p>
          <h2 id="trust-standards-title">{site.trustStandards.title}</h2>
          <p>{site.trustStandards.text}</p>
        </div>
        <div class="trust-list">
          {
            site.trustStandards.items.map((item) => (
              <article data-reveal>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section track-record" aria-labelledby="track-record-title">
        <div class="track-copy" data-reveal>
          <p class="eyebrow">{site.trackRecord.eyebrow}</p>
          <h2 id="track-record-title">{site.trackRecord.title}</h2>
          <p>{site.trackRecord.text}</p>
        </div>
        <div class="stat-grid" aria-label="Moje výsledky">
          {
            site.trackRecord.stats.map((stat) => (
              <article class="stat-item" data-reveal>
                <strong>{stat.value}</strong>
                <span>{stat.label}</span>
              </article>
            ))
          }
        </div>
        <article class="positioning-panel" data-reveal>
          <h3>{site.positioning.title}</h3>
          <p>{site.positioning.text}</p>
        </article>
      </section>

      <section class="section listings" id="ponuky">
        <div class="section-heading" data-reveal>
          <p class="eyebrow">{site.listingsIntro.eyebrow}</p>
          <h2>{site.listingsIntro.title}</h2>
          <p>{site.listingsIntro.text}</p>
        </div>
        <div class="listing-groups">
          <div class="listing-group available-listings" data-reveal>
            <div class="listing-group-heading">
              <div>
                <h3 class="listing-section-title">Aktuálne ponúkané nehnuteľnosti</h3>
                <span>{availableListingsLabel}</span>
              </div>
            </div>
            {
              availableListings.length > 0 ? (
                <div class="listing-grid">
                  {
                    availableListings.map((listing) => (
                      <article class="listing">
                        <a href={listing.href} aria-label={`Detail: ${listing.title}`}>
                          <img src={listing.image} alt="" loading="lazy" />
                          <div>
                            <p>{listing.status}</p>
                            <h3>{listing.title}</h3>
                            <dl>
                              <div>
                                <dt>Lokalita</dt>
                                <dd>{listing.place}</dd>
                              </div>
                              <div>
                                <dt>Cena</dt>
                                <dd>{listing.price}</dd>
                              </div>
                            </dl>
                            <span>{listing.note}</span>
                            <strong>{listing.cta}</strong>
                          </div>
                        </a>
                      </article>
                    ))
                  }
                </div>
              ) : (
                <article class="listing-empty">
                  <p>Aktuálne nie je zverejnený žiadny byt v ponuke.</p>
                  <span>Ak hľadáte konkrétny byt alebo chcete vedieť, čo sa pripravuje, najrýchlejšie je ozvať sa priamo.</span>
                  <a class="button primary" href="/rezervacia/">Rezervácia konzultácie</a>
                </article>
              )
            }
          </div>

          <div class="listing-group sold-listings" data-reveal>
            <div class="listing-group-heading">
              <div>
                <h3 class="listing-section-title">Referenčné predaje</h3>
                <span>{soldListings.length} referenčných predajov</span>
              </div>
              <div class="carousel-controls" aria-label="Ovládanie referencií">
                <button type="button" class="carousel-button" data-carousel-prev aria-label="Predchádzajúca referencia">
                  ‹
                </button>
                <button type="button" class="carousel-button" data-carousel-next aria-label="Ďalšia referencia">
                  ›
                </button>
              </div>
            </div>
            <div class="listing-carousel" data-carousel-track>
              {
                soldListings.map((listing) => (
                  <article class="listing sold">
                    <a href={listing.href} aria-label={`Detail: ${listing.title}`}>
                      <img src={listing.image} alt="" loading="lazy" />
                      <div>
                        <p>{listing.status}</p>
                        <h3>{listing.title}</h3>
                        <dl>
                          <div>
                            <dt>Lokalita</dt>
                            <dd>{listing.place}</dd>
                          </div>
                          <div>
                            <dt>Výsledok</dt>
                            <dd>{listing.price}</dd>
                          </div>
                        </dl>
                        <span>{listing.note}</span>
                        <strong>{listing.cta}</strong>
                      </div>
                    </a>
                  </article>
                ))
              }
            </div>
          </div>
        </div>
      </section>

      <section
        class="image-band"
        aria-label="Poznámka k práci realitného makléra"
        style={`--band-image: url('${site.handshakeImage}')`}
      >
        <div data-reveal>
          <p class="eyebrow">Môj spôsob práce</p>
          <h2>Najprv sa pozriem na realitu. Potom až na inzerát.</h2>
        </div>
      </section>

      <section class="section principles">
        <div class="principle-lead" data-reveal>
          <p class="eyebrow">Ako pracujem</p>
          <h2>Od prvého stretnutia musí byť jasné, čo robím a prečo.</h2>
        </div>
        <div class="principle-list">
          {
            site.principles.map((item) => (
              <article data-reveal>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section sale-time" aria-labelledby="sale-time-title">
        <div data-reveal>
          <p class="eyebrow">{site.saleTime.eyebrow}</p>
          <h2 id="sale-time-title">{site.saleTime.title}</h2>
        </div>
        <p data-reveal>{site.saleTime.text}</p>
      </section>

      <section class="section consultation-cta" aria-labelledby="consultation-title">
        <div data-reveal>
          <p class="eyebrow">Rezervácia konzultácie</p>
          <h2 id="consultation-title">Ak chcete riešiť predaj vážne, začnime krátkym hovorom.</h2>
        </div>
        <div class="consultation-card" data-reveal>
          <p>
            Pred hovorom si vyberiete zámer, typ nehnuteľnosti a preferovaný termín. Jakub tak neprichádza
            do rozhovoru naslepo a vy nestrácate čas všeobecnými otázkami.
          </p>
          <a class="button primary" href="/rezervacia/">Rezervácia konzultácie</a>
        </div>
      </section>

    </main>

    <a class="mobile-cta" href="/rezervacia/">Rezervácia konzultácie</a>

    <footer>
      <div class="footer-brand">
        <img src={site.logoImage} alt="" />
        <img class="bosen-logo footer-bosen-logo" src={site.bosenGroupLogo} alt="BOSEN Group" />
        {
          hasInstagram ? (
            <a
              class="social-icon"
              href={site.contact.instagram}
              target="_blank"
              rel="noreferrer"
              aria-label={site.contact.instagramLabel}
              title={site.contact.instagramLabel}
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="5" />
                <circle cx="12" cy="12" r="4" />
                <circle cx="17.5" cy="6.5" r="1.2" />
              </svg>
            </a>
          ) : (
            <span
              class="social-icon is-disabled"
              aria-label="Instagram doplniť pred spustením"
              title="Instagram doplniť pred spustením"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="5" />
                <circle cx="12" cy="12" r="4" />
                <circle cx="17.5" cy="6.5" r="1.2" />
              </svg>
            </span>
          )
        }
        <p>{site.brand}</p>
      </div>
      <p>{site.shortPromise}</p>
      <div class="footer-links">
        <a href="#ponuky">Pozrieť ponuky</a>
        <a href="/ochrana-osobnych-udajov/">Ochrana údajov a cookies</a>
        <button type="button" data-cookie-consent-manage>Spravovať cookies</button>
      </div>
    </footer>

    <script>
      const revealItems = document.querySelectorAll("[data-reveal]");

      if ("IntersectionObserver" in window) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12 },
        );

        revealItems.forEach((item) => {
          const rect = item.getBoundingClientRect();

          if (rect.top < window.innerHeight * 0.9) {
            item.classList.add("is-visible");
            return;
          }

          observer.observe(item);
        });
      } else {
        revealItems.forEach((item) => item.classList.add("is-visible"));
      }

      const carouselTrack = document.querySelector("[data-carousel-track]");
      const carouselPrev = document.querySelector("[data-carousel-prev]");
      const carouselNext = document.querySelector("[data-carousel-next]");

      const scrollCarousel = (direction) => {
        if (!carouselTrack) return;

        const firstCard = carouselTrack.querySelector(".listing");
        const cardWidth = firstCard?.getBoundingClientRect().width ?? 320;
        const gap = Number.parseFloat(getComputedStyle(carouselTrack).columnGap || "18");
        const maxScroll = carouselTrack.scrollWidth - carouselTrack.clientWidth;
        const nearStart = carouselTrack.scrollLeft <= 4;
        const nearEnd = carouselTrack.scrollLeft >= maxScroll - 4;

        if (direction > 0 && nearEnd) {
          carouselTrack.scrollTo({ left: 0, behavior: "smooth" });
          return;
        }

        if (direction < 0 && nearStart) {
          carouselTrack.scrollTo({ left: maxScroll, behavior: "smooth" });
          return;
        }

        carouselTrack.scrollBy({ left: direction * (cardWidth + gap), behavior: "smooth" });
      };

      carouselPrev?.addEventListener("click", () => scrollCarousel(-1));
      carouselNext?.addEventListener("click", () => scrollCarousel(1));

      const menuToggle = document.querySelector("[data-menu-toggle]");
      const siteMenu = document.querySelector("[data-site-menu]");
      const menuCloseControls = document.querySelectorAll("[data-menu-close], [data-menu-link]");

      const setMenuOpen = (isOpen) => {
        menuToggle?.setAttribute("aria-expanded", String(isOpen));
        siteMenu?.setAttribute("aria-hidden", String(!isOpen));
        siteMenu?.classList.toggle("is-open", isOpen);
        document.body.classList.toggle("menu-open", isOpen);
      };

      menuToggle?.addEventListener("click", () => {
        setMenuOpen(menuToggle.getAttribute("aria-expanded") !== "true");
      });

      menuCloseControls.forEach((control) => {
        control.addEventListener("click", () => setMenuOpen(false));
      });

      window.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          setMenuOpen(false);
        }
      });

      const mobileCta = document.querySelector(".mobile-cta");
      const toggleMobileCta = () => {
        mobileCta?.classList.toggle("is-visible", window.scrollY > 520);
      };

      toggleMobileCta();
      window.addEventListener("scroll", toggleMobileCta, { passive: true });

    </script>

    <style>
      :root {
        --paper: #f6f1e8;
        --paper-strong: #e9dfcf;
        --ink: #0b0b0a;
        --charcoal: #1b1b19;
        --muted: #6f6a62;
        --olive: #8a8d91;
        --wine: #9a5c32;
        --brass: #d8b878;
        --brass-muted: #b8945b;
        --white: #fffaf2;
        --line: rgba(11, 11, 10, 0.16);
        --shadow: 0 24px 70px rgba(11, 11, 10, 0.2);
        --font-body: "Instrument Sans", system-ui, sans-serif;
        --font-display: "Newsreader", Georgia, serif;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
        scroll-padding-top: 110px;
        overflow-x: hidden;
      }

      body {
        margin: 0;
        background: var(--paper);
        color: var(--ink);
        font-family: var(--font-body);
        line-height: 1.5;
        overflow-x: clip;
      }

      body.menu-open {
        overflow: hidden;
      }

      body.menu-open .mobile-cta {
        opacity: 0;
        pointer-events: none;
        transform: translateY(18px);
      }

      body::after {
        position: fixed;
        inset: 0;
        z-index: 999;
        pointer-events: none;
        content: "";
        opacity: 0.04;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 180 180' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.45'/%3E%3C/svg%3E");
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        display: block;
        max-width: 100%;
      }

      .skip-link {
        position: fixed;
        top: 12px;
        left: 12px;
        z-index: 1000;
        transform: translateY(-140%);
        padding: 10px 14px;
        background: var(--ink);
        color: var(--white);
        border-radius: 4px;
      }

      .skip-link:focus {
        transform: translateY(0);
      }

      .staging-ribbon {
        position: fixed;
        right: 18px;
        bottom: 18px;
        z-index: 1200;
        border: 1px solid rgba(11, 11, 10, 0.16);
        border-radius: 999px;
        padding: 8px 12px;
        background: #f3cf74;
        color: var(--ink);
        box-shadow: 0 12px 30px rgba(11, 11, 10, 0.22);
        font-size: 12px;
        font-weight: 900;
        letter-spacing: 0;
      }

      .site-header {
        position: fixed;
        top: 20px;
        left: 50%;
        z-index: 80;
        display: flex;
        width: min(1220px, calc(100% - 32px));
        min-height: 68px;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        padding: 8px 10px 8px 18px;
        border: 1px solid rgba(255, 250, 242, 0.16);
        border-radius: 999px;
        background: rgba(11, 11, 10, 0.72);
        color: var(--white);
        transform: translateX(-50%);
        box-shadow:
          inset 0 1px 0 rgba(255, 250, 242, 0.12),
          0 18px 60px rgba(0, 0, 0, 0.26);
        backdrop-filter: blur(22px);
      }

      .brand {
        display: flex;
        min-width: 0;
        align-items: center;
        gap: 12px;
      }

      .brand-cluster {
        display: flex;
        min-width: 0;
        align-items: center;
        gap: 13px;
      }

      .brand-divider {
        width: 1px;
        height: 34px;
        background: rgba(255, 250, 242, 0.2);
      }

      .bosen-logo {
        display: block;
        object-fit: contain;
        object-position: center;
        mix-blend-mode: screen;
      }

      .header-bosen-logo {
        width: 164px;
        height: 36px;
        opacity: 0.9;
      }

      .brand-mark {
        width: 118px;
        height: 42px;
        object-fit: contain;
        object-position: center;
      }

      .brand-label {
        display: grid;
        gap: 0;
      }

      .brand-label span {
        font-family: var(--font-display);
        font-size: 24px;
        font-weight: 650;
        line-height: 1;
      }

      .brand-label small {
        color: rgba(255, 250, 242, 0.72);
        font-size: 13px;
      }

      .desktop-nav {
        display: flex;
        gap: clamp(18px, 2vw, 30px);
        color: rgba(255, 250, 242, 0.8);
        font-size: 15.5px;
        font-weight: 650;
      }

      .desktop-nav a,
      .header-phone,
      .menu-toggle,
      footer a {
        text-decoration-line: underline;
        text-decoration-color: transparent;
        text-decoration-thickness: 1px;
        text-underline-offset: 5px;
        transition:
          text-decoration-color 240ms cubic-bezier(0.32, 0.72, 0, 1),
          color 240ms cubic-bezier(0.32, 0.72, 0, 1),
          transform 240ms cubic-bezier(0.32, 0.72, 0, 1);
      }

      .desktop-nav a:hover,
      .header-phone:hover,
      footer a:hover {
        color: var(--brass);
        text-decoration-color: currentColor;
      }

      .header-actions {
        display: flex;
        flex: 0 0 auto;
        align-items: center;
        gap: 8px;
      }

      .header-phone {
        display: inline-flex;
        min-height: 48px;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(255, 250, 242, 0.22);
        border-radius: 999px;
        padding: 0 18px;
        background: rgba(255, 250, 242, 0.08);
        font-weight: 750;
        white-space: nowrap;
      }

      .menu-toggle {
        display: inline-flex;
        min-height: 48px;
        align-items: center;
        gap: 12px;
        border: 1px solid rgba(216, 184, 120, 0.38);
        border-radius: 999px;
        padding: 0 13px 0 17px;
        background: var(--brass);
        color: var(--ink);
        cursor: pointer;
        font: inherit;
        font-weight: 850;
      }

      .menu-toggle i {
        position: relative;
        display: block;
        width: 22px;
        height: 14px;
      }

      .menu-toggle i::before,
      .menu-toggle i::after {
        position: absolute;
        right: 0;
        width: 22px;
        height: 2px;
        border-radius: 999px;
        background: currentColor;
        content: "";
        transition:
          transform 360ms cubic-bezier(0.32, 0.72, 0, 1),
          top 360ms cubic-bezier(0.32, 0.72, 0, 1);
      }

      .menu-toggle i::before {
        top: 2px;
      }

      .menu-toggle i::after {
        top: 10px;
      }

      .menu-toggle[aria-expanded="true"] i::before {
        top: 6px;
        transform: rotate(45deg);
      }

      .menu-toggle[aria-expanded="true"] i::after {
        top: 6px;
        transform: rotate(-45deg);
      }

      .site-menu {
        position: fixed;
        inset: 0;
        z-index: 70;
        pointer-events: none;
        opacity: 0;
        transition: opacity 360ms cubic-bezier(0.32, 0.72, 0, 1);
      }

      .site-menu.is-open {
        pointer-events: auto;
        opacity: 1;
      }

      .menu-scrim {
        position: absolute;
        inset: 0;
        border: 0;
        background:
          radial-gradient(circle at 18% 18%, rgba(216, 184, 120, 0.17), transparent 32%),
          rgba(5, 5, 5, 0.78);
        cursor: pointer;
        backdrop-filter: blur(18px);
      }

      .menu-panel {
        position: absolute;
        top: 104px;
        right: max(16px, calc((100vw - 1220px) / 2));
        display: grid;
        width: min(720px, calc(100% - 32px));
        max-height: calc(100dvh - 126px);
        overflow: auto;
        grid-template-columns: minmax(0, 1.2fr) minmax(240px, 0.8fr);
        gap: 26px;
        border: 1px solid rgba(255, 250, 242, 0.16);
        border-radius: 28px;
        padding: 24px;
        background:
          linear-gradient(135deg, rgba(18, 18, 15, 0.96), rgba(9, 9, 8, 0.94)),
          var(--ink);
        color: var(--white);
        box-shadow:
          inset 0 1px 0 rgba(255, 250, 242, 0.12),
          0 38px 90px rgba(0, 0, 0, 0.42);
        transform: translateY(18px) scale(0.982);
        transition: transform 520ms cubic-bezier(0.32, 0.72, 0, 1);
      }

      .site-menu.is-open .menu-panel {
        transform: translateY(0) scale(1);
      }

      .menu-panel-head {
        display: flex;
        grid-column: 1 / -1;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        border-bottom: 1px solid rgba(255, 250, 242, 0.12);
        padding-bottom: 18px;
      }

      .menu-panel-head p {
        margin: 0;
        color: var(--brass);
        font-size: 12px;
        font-weight: 850;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }

      .menu-close {
        border: 1px solid rgba(255, 250, 242, 0.18);
        border-radius: 999px;
        padding: 9px 13px;
        background: rgba(255, 250, 242, 0.06);
        color: var(--white);
        cursor: pointer;
        font: inherit;
        font-size: 13px;
        font-weight: 800;
      }

      .menu-nav {
        display: grid;
        gap: 6px;
      }

      .menu-nav a {
        display: grid;
        grid-template-columns: 42px minmax(0, 1fr);
        gap: 14px;
        align-items: center;
        border-radius: 16px;
        padding: 13px 14px;
        color: var(--white);
        font-family: var(--font-display);
        font-size: clamp(28px, 3.2vw, 46px);
        font-weight: 650;
        line-height: 0.95;
        transform: translateY(12px);
        opacity: 0;
        transition:
          opacity 520ms cubic-bezier(0.32, 0.72, 0, 1),
          transform 520ms cubic-bezier(0.32, 0.72, 0, 1),
          background 240ms cubic-bezier(0.32, 0.72, 0, 1);
      }

      .site-menu.is-open .menu-nav a {
        opacity: 1;
        transform: translateY(0);
      }

      .site-menu.is-open .menu-nav a:nth-child(2) {
        transition-delay: 50ms;
      }

      .site-menu.is-open .menu-nav a:nth-child(3) {
        transition-delay: 100ms;
      }

      .site-menu.is-open .menu-nav a:nth-child(4) {
        transition-delay: 150ms;
      }

      .site-menu.is-open .menu-nav a:nth-child(5) {
        transition-delay: 200ms;
      }

      .site-menu.is-open .menu-nav a:nth-child(6) {
        transition-delay: 250ms;
      }

      .menu-nav a:hover {
        background: rgba(255, 250, 242, 0.07);
      }

      .menu-nav span {
        color: var(--brass);
        font-family: var(--font-body);
        font-size: 12px;
        font-weight: 850;
        letter-spacing: 0.14em;
      }

      .menu-aside {
        display: grid;
        align-content: space-between;
        gap: 18px;
      }

      .menu-aside article {
        border: 1px solid rgba(216, 184, 120, 0.22);
        border-radius: 22px;
        padding: 18px;
        background:
          linear-gradient(180deg, rgba(216, 184, 120, 0.12), rgba(255, 250, 242, 0.04));
      }

      .menu-aside span {
        display: block;
        margin-bottom: 10px;
        color: var(--brass);
        font-size: 12px;
        font-weight: 850;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      .menu-aside strong {
        display: block;
        margin-bottom: 10px;
        font-size: 28px;
        line-height: 1;
      }

      .menu-aside p {
        margin: 0;
        color: rgba(255, 250, 242, 0.72);
      }

      .menu-cta {
        display: flex;
        min-height: 58px;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        border-radius: 999px;
        padding: 8px 8px 8px 20px;
        background: var(--brass);
        color: var(--ink);
        font-weight: 850;
      }

      .menu-cta span {
        display: grid;
        width: 42px;
        height: 42px;
        place-items: center;
        border-radius: 50%;
        background: rgba(11, 11, 10, 0.12);
        color: var(--ink);
        margin: 0;
        letter-spacing: 0;
        text-transform: none;
        transition: transform 240ms cubic-bezier(0.32, 0.72, 0, 1);
      }

      .menu-cta:hover span {
        transform: translate(2px, -1px);
      }

      .hero {
        position: relative;
        isolation: isolate;
        display: grid;
        min-height: 100svh;
        grid-template-columns: minmax(380px, 0.95fr) minmax(0, 1.05fr);
        gap: clamp(32px, 5vw, 72px);
        align-items: center;
        padding: 112px max(28px, calc((100vw - 1180px) / 2)) 64px;
        background:
          linear-gradient(108deg, rgba(11, 11, 10, 0.98) 0%, rgba(23, 23, 20, 0.94) 44%, rgba(11, 11, 10, 0.9) 100%),
          radial-gradient(circle at 78% 20%, rgba(216, 184, 120, 0.2), transparent 32%),
          radial-gradient(circle at 12% 74%, rgba(111, 44, 36, 0.24), transparent 34%),
          var(--ink);
        color: var(--white);
      }

      .hero::after {
        position: absolute;
        inset: 0;
        z-index: -1;
        pointer-events: none;
        content: "";
        opacity: 0.18;
        background-image:
          linear-gradient(rgba(255, 250, 242, 0.12) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 250, 242, 0.12) 1px, transparent 1px);
        background-size: 88px 88px;
        mask-image: linear-gradient(90deg, transparent 0%, #000 22%, #000 78%, transparent 100%);
      }

      .hero-copy {
        display: flex;
        max-width: 720px;
        flex-direction: column;
        justify-content: center;
        grid-column: 2;
        grid-row: 1;
        padding: 28px 0 18px;
      }

      .eyebrow {
        margin: 0 0 18px;
        color: var(--wine);
        font-size: 14px;
        font-weight: 700;
      }

      .hero .eyebrow {
        color: var(--brass);
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      h1,
      h2,
      h3,
      p {
        margin-top: 0;
      }

      h1,
      h2 {
        font-family: var(--font-display);
        font-weight: 650;
        line-height: 0.95;
      }

      h1 {
        margin-bottom: 18px;
        font-size: clamp(50px, 5.4vw, 76px);
      }

      .hero h1 {
        color: var(--white);
        max-width: 780px;
        text-wrap: balance;
        letter-spacing: -0.045em;
      }

      h2 {
        margin-bottom: 18px;
        font-size: 54px;
      }

      h3 {
        margin-bottom: 10px;
        font-size: 23px;
        line-height: 1.15;
      }

      .promise {
        margin-bottom: 22px;
        color: var(--brass);
        font-family: var(--font-display);
        font-size: clamp(34px, 3.1vw, 48px);
        font-weight: 500;
        line-height: 1.06;
      }

      .intro {
        max-width: 520px;
        margin-bottom: 30px;
        color: rgba(255, 250, 242, 0.74);
        font-size: 18px;
      }

      .hero-lead {
        max-width: 690px;
        margin-bottom: 28px;
        color: rgba(255, 250, 242, 0.78);
        font-size: clamp(18px, 1.45vw, 22px);
        line-height: 1.48;
      }

      .hero-beats {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
        max-width: 700px;
        margin-bottom: 30px;
      }

      .hero-beat {
        display: grid;
        gap: 10px;
        align-items: start;
        padding: 14px;
        border-top: 1px solid rgba(255, 250, 242, 0.14);
        background: rgba(255, 250, 242, 0.035);
      }

      .hero-beat span {
        color: var(--brass);
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.08em;
      }

      .hero-beat h2 {
        margin-bottom: 5px;
        color: var(--white);
        font-family: var(--font-body);
        font-size: 18px;
        font-weight: 700;
        line-height: 1.2;
      }

      .hero-beat p {
        margin: 0;
        color: rgba(255, 250, 242, 0.68);
        font-size: 15px;
        line-height: 1.45;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
      }

      .button {
        display: inline-flex;
        min-height: 50px;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: 0 22px;
        border: 1px solid var(--ink);
        font-weight: 700;
        transition:
          transform 260ms cubic-bezier(0.32, 0.72, 0, 1),
          background 260ms cubic-bezier(0.32, 0.72, 0, 1),
          color 260ms cubic-bezier(0.32, 0.72, 0, 1);
      }

      .button:hover {
        transform: translateY(-2px) scale(1.01);
      }

      .button:active {
        transform: translateY(0) scale(0.985);
      }

      a:focus-visible,
      button:focus-visible,
      input:focus-visible,
      select:focus-visible,
      textarea:focus-visible {
        outline: 2px solid var(--brass);
        outline-offset: 4px;
      }

      .button.primary {
        border-color: var(--brass);
        background: var(--brass);
        color: var(--ink);
      }

      .button.secondary {
        background: transparent;
        color: inherit;
      }

      .hero .button.secondary {
        border-color: rgba(255, 250, 242, 0.42);
        color: var(--white);
      }

      .hero-visual {
        position: relative;
        grid-column: 1;
        grid-row: 1;
        height: clamp(460px, calc(100svh - 190px), 640px);
        min-height: 0;
        align-self: center;
        overflow: hidden;
        border: 1px solid rgba(255, 250, 242, 0.14);
        border-radius: 30px;
        background: rgba(255, 250, 242, 0.04);
        box-shadow:
          inset 0 1px 0 rgba(255, 250, 242, 0.12),
          0 36px 90px rgba(0, 0, 0, 0.38);
      }

      .hero-visual::before {
        position: absolute;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        content: "";
        background:
          linear-gradient(180deg, rgba(8, 8, 8, 0) 0%, rgba(8, 8, 8, 0.76) 100%),
          linear-gradient(90deg, rgba(8, 8, 8, 0.64) 0%, rgba(8, 8, 8, 0.1) 48%, rgba(8, 8, 8, 0) 100%);
      }

      .hero-visual > img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center top;
        filter: saturate(0.72) contrast(1.08) brightness(0.78);
      }

      .portrait-note {
        display: none;
        position: absolute;
        right: 22px;
        top: 22px;
        z-index: 2;
        width: min(330px, calc(100% - 44px));
        padding: 18px;
        border: 1px solid rgba(216, 184, 120, 0.34);
        border-radius: 8px;
        background: rgba(11, 11, 10, 0.78);
        color: var(--white);
        backdrop-filter: blur(16px);
      }

      .portrait-note p {
        margin: 0;
        color: rgba(255, 250, 242, 0.82);
        font-size: 14px;
      }

      .portrait-note strong {
        display: block;
        color: var(--white);
      }

      .ai-system-card {
        position: absolute;
        left: 22px;
        right: 22px;
        bottom: 22px;
        z-index: 2;
        padding: 18px;
        border: 1px solid rgba(255, 250, 242, 0.2);
        border-radius: 8px;
        background: rgba(11, 11, 10, 0.78);
        color: var(--white);
        backdrop-filter: blur(18px);
      }

      .ai-system-card p {
        margin: 0 0 8px;
        color: var(--brass);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .ai-system-card strong {
        display: block;
        margin-bottom: 14px;
        font-size: clamp(20px, 2vw, 28px);
        line-height: 1.05;
        text-wrap: balance;
      }

      .ai-system-card ol {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .ai-system-card li {
        display: inline-flex;
        align-items: center;
        min-height: 30px;
        border: 1px solid rgba(255, 250, 242, 0.18);
        border-radius: 999px;
        padding: 0 10px;
        color: rgba(255, 250, 242, 0.78);
        font-size: 12px;
        font-weight: 700;
      }

      .proof-strip {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        padding: 0 max(28px, calc((100vw - 1180px) / 2));
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
        background: linear-gradient(90deg, var(--ink), var(--charcoal));
        color: var(--white);
      }

      .proof-strip p {
        display: flex;
        min-height: 96px;
        align-items: center;
        gap: 12px;
        margin: 0;
        min-width: 0;
        padding: 0 clamp(18px, 2.4vw, 32px);
        border-right: 1px solid rgba(255, 250, 242, 0.14);
        font-weight: 600;
        line-height: 1.25;
        text-wrap: balance;
      }

      .proof-strip p:first-child {
        padding-left: 0;
      }

      .proof-strip p:last-child {
        padding-right: 0;
        border-right: 0;
      }

      .proof-strip span {
        width: 9px;
        height: 9px;
        flex: 0 0 auto;
        border-radius: 999px;
        background: var(--brass);
      }

      .city-panorama {
        position: relative;
        min-height: clamp(118px, 13vw, 178px);
        overflow: hidden;
        border-top: 1px solid rgba(255, 250, 242, 0.08);
        background: var(--city-panorama-image) center 66% / 100% auto no-repeat;
      }

      .city-panorama::after {
        position: absolute;
        right: 0;
        left: 0;
        z-index: 1;
        content: "";
        pointer-events: none;
      }

      .city-panorama::after {
        bottom: -22px;
        height: 42%;
        background: linear-gradient(
          180deg,
          rgba(246, 241, 232, 0),
          rgba(246, 241, 232, 0.22) 36%,
          rgba(246, 241, 232, 0.68) 68%,
          var(--paper) 88%,
          var(--paper)
        );
      }

      .backing {
        display: grid;
        grid-template-columns: minmax(0, 0.86fr) minmax(0, 1.14fr);
        gap: 70px;
        background: var(--paper);
      }

      .backing-lead {
        align-self: start;
      }

      .backing-lead p:not(.eyebrow) {
        max-width: 600px;
        margin: 0;
        color: var(--muted);
        font-size: 18px;
      }

      .backing-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
      }

      .backing-item {
        min-height: 238px;
        padding: 24px;
        border: 1px solid rgba(11, 11, 10, 0.16);
        border-radius: 8px;
        background: rgba(255, 250, 242, 0.62);
      }

      .backing-item h3 {
        font-family: var(--font-display);
        font-size: clamp(27px, 2.5vw, 34px);
        font-weight: 650;
      }

      .backing-item p {
        margin: 0;
        color: var(--muted);
      }

      .network-proof {
        display: grid;
        grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
        gap: 72px;
        align-items: start;
        background:
          linear-gradient(110deg, rgba(11, 11, 10, 0.98), rgba(27, 27, 25, 0.94)),
          var(--ink);
        color: var(--white);
      }

      .network-proof .eyebrow {
        color: var(--brass);
      }

      .network-copy {
        position: sticky;
        top: 118px;
      }

      .network-copy h2 {
        max-width: 760px;
      }

      .network-copy > p:not(.eyebrow) {
        max-width: 610px;
        margin-bottom: 28px;
        color: rgba(255, 250, 242, 0.74);
        font-size: 18px;
      }

      .network-list {
        display: grid;
        border-top: 1px solid rgba(255, 250, 242, 0.16);
      }

      .network-list article {
        display: grid;
        grid-template-columns: 0.34fr 0.66fr;
        gap: 24px;
        padding: 28px 0;
        border-bottom: 1px solid rgba(255, 250, 242, 0.16);
      }

      .network-list span {
        color: var(--brass);
        font-size: 13px;
        font-weight: 900;
        text-transform: uppercase;
      }

      .network-list h3 {
        margin: 0 0 10px;
        color: var(--white);
        font-family: var(--font-display);
        font-size: clamp(30px, 3vw, 44px);
        font-weight: 650;
      }

      .network-list p {
        margin: 0;
        color: rgba(255, 250, 242, 0.68);
      }

      .track-record {
        display: grid;
        grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
        gap: 62px;
        background: var(--white);
      }

      .track-copy {
        max-width: 620px;
      }

      .track-copy > p:not(.eyebrow),
      .positioning-panel p,
      .sale-time > p {
        color: var(--muted);
      }

      .stat-grid {
        display: grid;
        gap: 0;
        align-self: start;
        border-top: 1px solid var(--line);
      }

      .stat-item {
        display: grid;
        grid-template-columns: 0.42fr 1fr;
        gap: 28px;
        padding: 25px 0;
        border-bottom: 1px solid var(--line);
      }

      .stat-item strong {
        color: var(--wine);
        font-family: var(--font-display);
        font-size: clamp(42px, 4vw, 68px);
        font-weight: 650;
        line-height: 0.92;
      }

      .stat-item span {
        align-self: center;
        color: var(--ink);
        font-size: 18px;
        font-weight: 700;
        line-height: 1.25;
      }

      .positioning-panel {
        grid-column: 1 / -1;
        display: grid;
        grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
        gap: 62px;
        padding-top: 34px;
        border-top: 1px solid var(--line);
      }

      .positioning-panel h3 {
        max-width: 760px;
        margin: 0;
        font-family: var(--font-display);
        font-size: clamp(36px, 4vw, 58px);
        font-weight: 650;
        line-height: 0.98;
      }

      .positioning-panel p {
        max-width: 520px;
        margin: 0;
        align-self: end;
        font-size: 18px;
      }

      .section {
        padding: 110px max(28px, calc((100vw - 1180px) / 2));
      }

      section[id] {
        scroll-margin-top: 110px;
      }

      .split {
        display: grid;
        grid-template-columns: 0.8fr 1.2fr;
        gap: 70px;
      }

      .section-heading {
        max-width: 700px;
      }

      .section-heading p:not(.eyebrow),
      .principle-lead + .principle-list p {
        color: var(--muted);
      }

      .centered {
        max-width: 760px;
        margin: 0 auto 42px;
        text-align: center;
      }

      .service-list {
        display: grid;
        gap: 0;
        border-top: 1px solid var(--line);
      }

      .service-cta {
        margin-top: 18px;
      }

      .service {
        display: grid;
        grid-template-columns: 0.7fr 1fr;
        gap: 32px;
        padding: 28px 0;
        border-bottom: 1px solid var(--line);
      }

      .service p {
        margin: 0;
        color: var(--muted);
      }

      .process-section {
        background: var(--paper-strong);
      }

      .process-section .section-heading p:not(.eyebrow) {
        max-width: 680px;
        margin-right: auto;
        margin-left: auto;
      }

      .process-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 18px;
      }

      .process-item {
        min-height: 292px;
        padding: 28px;
        border: 1px solid rgba(30, 28, 25, 0.18);
        border-radius: 8px;
        background: rgba(255, 250, 242, 0.45);
      }

      .process-item span {
        display: block;
        margin-bottom: 44px;
        color: var(--wine);
        font-family: var(--font-display);
        font-size: 42px;
      }

      .process-item p {
        color: var(--muted);
      }

      .process-cta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        margin-top: 28px;
        border-top: 1px solid rgba(30, 28, 25, 0.16);
        padding-top: 24px;
      }

      .process-cta p {
        max-width: 680px;
        margin: 0;
        color: var(--muted);
        font-size: 18px;
      }

      .trust-standards {
        display: grid;
        grid-template-columns: minmax(0, 0.9fr) minmax(360px, 1.1fr);
        gap: 70px;
        background: var(--charcoal);
        color: var(--white);
      }

      .trust-standards .eyebrow {
        color: var(--brass);
      }

      .trust-copy {
        position: sticky;
        top: 120px;
        align-self: start;
      }

      .trust-copy h2 {
        max-width: 760px;
      }

      .trust-copy p:not(.eyebrow),
      .trust-list p {
        color: rgba(255, 250, 242, 0.68);
      }

      .trust-list {
        display: grid;
        gap: 0;
        border-top: 1px solid rgba(255, 250, 242, 0.16);
      }

      .trust-list article {
        display: grid;
        grid-template-columns: minmax(170px, 0.5fr) 1fr;
        gap: 26px;
        padding: 26px 0;
        border-bottom: 1px solid rgba(255, 250, 242, 0.16);
      }

      .trust-list h3 {
        margin-bottom: 0;
      }

      .trust-list p {
        margin: 0;
      }

      .image-band {
        min-height: 760px;
        display: flex;
        align-items: flex-end;
        padding: 70px max(28px, calc((100vw - 1180px) / 2));
        color: var(--white);
        background:
          linear-gradient(90deg, rgba(30, 28, 25, 0.78) 0%, rgba(30, 28, 25, 0.52) 42%, rgba(30, 28, 25, 0.2) 74%),
          linear-gradient(180deg, rgba(30, 28, 25, 0.04), rgba(30, 28, 25, 0.58)),
          var(--band-image) 60% 10%/cover;
      }

      .image-band div {
        width: min(100%, 920px);
        max-width: none;
      }

      .image-band .eyebrow {
        color: #e7c385;
      }

      .image-band h2 {
        margin: 0;
        max-width: min(920px, 66vw);
        font-size: clamp(46px, 5.2vw, 76px);
        line-height: 0.96;
        text-wrap: balance;
      }

      .principles {
        display: grid;
        grid-template-columns: 0.9fr 1.1fr;
        gap: 70px;
        background: var(--white);
      }

      .principle-list {
        display: grid;
        gap: 26px;
      }

      .principle-list article {
        padding-bottom: 26px;
        border-bottom: 1px solid var(--line);
      }

      .principle-list p {
        margin: 0;
      }

      .sale-time {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(340px, 0.72fr);
        gap: 72px;
        align-items: end;
        background: var(--paper-strong);
      }

      .sale-time h2 {
        max-width: 880px;
        margin-bottom: 0;
      }

      .sale-time > p {
        margin: 0;
        font-size: 18px;
      }

      .listings {
        overflow: hidden;
        background: var(--paper);
      }

      .listing-groups {
        display: grid;
        gap: 54px;
        margin-top: 48px;
      }

      .listing-group {
        display: grid;
        gap: 18px;
      }

      .listing-group-heading {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 18px;
        border-bottom: 1px solid var(--line);
        padding-bottom: 14px;
      }

      .listing-group-heading .eyebrow {
        margin-bottom: 0;
      }

      .listing-section-title {
        margin: 0;
        font-family: var(--font-display);
        font-size: clamp(30px, 3vw, 42px);
        font-weight: 650;
        line-height: 0.98;
      }

      .listing-group-heading > div:first-child {
        display: grid;
        gap: 6px;
      }

      .listing-group-heading span {
        color: var(--muted);
        font-size: 14px;
        font-weight: 700;
      }

      .carousel-controls {
        display: flex;
        gap: 8px;
      }

      .carousel-button {
        display: inline-grid;
        width: 44px;
        height: 44px;
        place-items: center;
        border: 1px solid rgba(11, 11, 10, 0.22);
        border-radius: 999px;
        background: rgba(255, 250, 242, 0.72);
        color: var(--ink);
        cursor: pointer;
        font: inherit;
        font-size: 28px;
        line-height: 1;
        transition: background 160ms ease, border-color 160ms ease, transform 160ms ease;
      }

      .carousel-button:hover {
        border-color: var(--brass-muted);
        background: var(--brass);
        transform: translateY(-1px);
      }

      .listing-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
      }

      .listing-carousel {
        display: flex;
        gap: 18px;
        overflow-x: auto;
        padding: 2px 0 16px;
        scroll-behavior: smooth;
        scroll-padding-inline: 1px;
        scroll-snap-type: x mandatory;
        scrollbar-width: none;
      }

      .listing-carousel::-webkit-scrollbar {
        display: none;
      }

      .listing-carousel .listing {
        flex: 0 0 clamp(330px, 32vw, 390px);
        scroll-snap-align: start;
      }

      .listing {
        overflow: hidden;
        min-width: 0;
        border: 1px solid var(--line);
        border-radius: 8px;
        background: var(--white);
        transition: border-color 180ms ease, transform 180ms ease, box-shadow 180ms ease;
      }

      .listing a {
        display: grid;
        height: 100%;
      }

      .listing:hover {
        border-color: rgba(154, 92, 50, 0.42);
        box-shadow: 0 18px 44px rgba(11, 11, 10, 0.11);
        transform: translateY(-2px);
      }

      .listing img {
        width: 100%;
        aspect-ratio: 4 / 3;
        object-fit: cover;
        transition: transform 240ms ease;
      }

      .listing:hover img {
        transform: scale(1.03);
      }

      .listing a > div {
        display: grid;
        align-content: start;
        padding: 20px;
      }

      .listing p {
        margin-bottom: 12px;
        color: var(--wine);
        font-size: 13px;
        font-weight: 700;
      }

      .listing dl {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin: 18px 0;
      }

      .listing dt {
        color: var(--muted);
        font-size: 13px;
      }

      .listing dd {
        margin: 0;
        font-weight: 700;
      }

      .listing span {
        display: block;
        color: var(--muted);
        font-size: 14px;
      }

      .listing strong {
        display: inline-flex;
        margin-top: 18px;
        color: var(--wine);
        font-weight: 800;
        text-decoration: underline;
        text-underline-offset: 5px;
      }

      .listing.sold {
        background: rgba(255, 250, 242, 0.62);
      }

      .listing-empty {
        display: grid;
        min-height: 190px;
        grid-column: 1 / -1;
        align-content: center;
        gap: 8px;
        border: 1px dashed rgba(11, 11, 10, 0.22);
        border-radius: 8px;
        padding: 26px;
        background: rgba(255, 250, 242, 0.44);
      }

      .listing-empty p {
        margin: 0;
        color: var(--ink);
        font-size: 22px;
        font-weight: 800;
        line-height: 1.15;
      }

      .listing-empty span {
        color: var(--muted);
      }

      .listing-empty .button {
        justify-self: start;
        margin-top: 12px;
      }

      .consultation-cta {
        display: grid;
        grid-template-columns: minmax(0, 0.92fr) minmax(320px, 0.64fr);
        gap: 56px;
        align-items: end;
        background:
          linear-gradient(110deg, rgba(11, 11, 10, 0.96), rgba(27, 27, 25, 0.9)),
          var(--ink);
        color: var(--white);
      }

      .consultation-cta .eyebrow {
        color: var(--brass);
      }

      .consultation-cta h2 {
        max-width: 860px;
        margin-bottom: 0;
      }

      .consultation-card {
        display: grid;
        gap: 18px;
        border: 1px solid rgba(255, 250, 242, 0.16);
        border-radius: 8px;
        padding: clamp(22px, 3vw, 32px);
        background: rgba(255, 250, 242, 0.07);
      }

      .consultation-card p {
        margin: 0;
        color: rgba(255, 250, 242, 0.72);
      }

      footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        padding: 26px max(28px, calc((100vw - 1180px) / 2)) 110px;
        background: #0b0b0a;
        color: rgba(255, 250, 242, 0.72);
      }

      footer p {
        margin: 0;
      }

      .footer-brand {
        display: flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
      }

      .footer-links {
        display: grid;
        justify-items: end;
        gap: 8px;
      }

      .social-icon {
        display: inline-grid;
        width: 38px;
        height: 38px;
        place-items: center;
        border: 1px solid rgba(255, 250, 242, 0.2);
        border-radius: 999px;
        color: rgba(255, 250, 242, 0.78);
        transition: border-color 160ms ease, color 160ms ease, transform 160ms ease;
      }

      .social-icon svg {
        width: 19px;
        height: 19px;
        fill: none;
        stroke: currentColor;
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-width: 1.8;
      }

      .social-icon:hover {
        border-color: var(--brass);
        color: var(--brass);
        transform: translateY(-1px);
      }

      .social-icon.is-disabled {
        cursor: default;
        opacity: 0.42;
        transform: none;
      }

      .social-icon.is-disabled:hover {
        border-color: rgba(255, 250, 242, 0.2);
        color: rgba(255, 250, 242, 0.78);
      }

      .footer-brand img {
        width: 118px;
        height: 52px;
        object-fit: contain;
      }

      .footer-brand .footer-bosen-logo {
        width: 170px;
        height: 42px;
        opacity: 0.88;
      }

      .footer-brand p {
        color: var(--white);
        font-family: var(--font-display);
        font-size: 24px;
        font-weight: 650;
      }

      .mobile-cta {
        display: none;
      }

      [data-reveal] {
        opacity: 1;
        transform: none;
        transition: opacity 700ms ease, transform 700ms ease;
      }

      :global(html.js) [data-reveal] {
        opacity: 0;
        transform: translateY(18px);
      }

      :global(html.js) [data-reveal].is-visible,
      [data-reveal].is-visible {
        opacity: 1;
        transform: translateY(0);
      }

      :global(html.js) .hero [data-reveal] {
        opacity: 1;
        transform: none;
        transition: none;
      }

      @media (prefers-reduced-motion: no-preference) {
        :global(html.js) .hero-visual {
          animation: heroVisualIn 900ms cubic-bezier(0.2, 0.75, 0.24, 1) 120ms both;
        }

        :global(html.js) .hero-visual > img {
          animation: heroImageSettle 1400ms cubic-bezier(0.2, 0.75, 0.24, 1) 120ms both;
          transform-origin: center top;
        }

        :global(html.js) .proof-strip p {
          transition-delay: 0ms;
          transition-duration: 620ms;
          transition-timing-function: cubic-bezier(0.2, 0.75, 0.24, 1);
        }

        :global(html.js) .proof-strip p:nth-child(2) {
          transition-delay: 90ms;
        }

        :global(html.js) .proof-strip p:nth-child(3) {
          transition-delay: 180ms;
        }
      }

      @keyframes heroVisualIn {
        from {
          opacity: 0;
          transform: translateY(18px) scale(0.985);
        }

        to {
          opacity: 1;
          transform: translateY(0) scale(1);
        }
      }

      @keyframes heroImageSettle {
        from {
          transform: scale(1.035);
        }

        to {
          transform: scale(1);
        }
      }

      @media (max-width: 980px) {
        .site-header {
          top: 12px;
        }

        .desktop-nav {
          display: none;
        }

        .menu-panel {
          top: 88px;
          right: 16px;
          width: calc(100% - 32px);
          max-height: calc(100dvh - 108px);
          grid-template-columns: 1fr;
          gap: 18px;
          padding: 20px;
        }

        .menu-nav a {
          grid-template-columns: 36px minmax(0, 1fr);
          border-radius: 14px;
          padding: 12px 10px;
          font-size: clamp(28px, 8.2vw, 54px);
        }

        .menu-aside {
          grid-template-columns: minmax(0, 1fr) minmax(220px, 0.72fr);
          align-items: stretch;
        }

        .header-phone {
          min-height: 38px;
          padding: 0 12px;
          font-size: 14px;
        }

        .hero,
        .backing,
        .network-proof,
        .split,
        .track-record,
        .positioning-panel,
        .trust-standards,
        .principles,
        .sale-time,
        .consultation-cta {
          grid-template-columns: 1fr;
        }

        .hero {
          gap: 26px;
          padding-top: 102px;
        }

        .hero-copy,
        .hero-visual {
          grid-column: 1;
          grid-row: auto;
        }

        .hero-copy {
          max-width: none;
          padding: 18px 0 0;
        }

        h1 {
          font-size: 62px;
        }

        h2 {
          font-size: 42px;
        }

        .promise {
          font-size: 31px;
        }

        .hero-visual {
          height: clamp(430px, 62svh, 560px);
        }

        .hero-beats {
          grid-template-columns: 1fr;
        }

        .proof-strip,
        .process-grid {
          grid-template-columns: 1fr;
        }

        .proof-strip {
          padding: 0 18px;
        }

        .proof-strip p {
          min-height: 74px;
          padding: 0;
          border-right: 0;
          border-bottom: 1px solid rgba(255, 250, 242, 0.14);
        }

        .city-panorama {
          min-height: 138px;
          background-position: center 66%;
        }

        .service {
          grid-template-columns: 1fr;
          gap: 10px;
        }

        .process-cta {
          align-items: start;
          flex-direction: column;
        }

        .trust-copy {
          position: static;
        }

        .trust-list article {
          grid-template-columns: 1fr;
          gap: 10px;
        }

        .backing {
          gap: 38px;
        }

        .network-copy {
          position: static;
        }

        .network-list article {
          grid-template-columns: 1fr;
          gap: 10px;
        }

        .track-record,
        .positioning-panel,
        .sale-time {
          gap: 34px;
        }

        .listing-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .listing-carousel .listing {
          flex-basis: min(420px, 58vw);
        }

        .positioning-panel p {
          max-width: none;
          align-self: start;
        }

        .mobile-cta.is-visible {
          opacity: 1;
          pointer-events: auto;
          transform: translateY(0);
        }
      }

      @media (max-width: 620px) {
        html {
          scroll-padding-top: 86px;
        }

        section[id] {
          scroll-margin-top: 86px;
        }

        .site-header {
          width: calc(100% - 20px);
          min-height: 58px;
          gap: 10px;
          padding: 7px 7px 7px 12px;
        }

        .brand-label span {
          font-size: 21px;
        }

        .brand-label {
          display: none;
        }

        .brand-cluster {
          gap: 8px;
        }

        .brand-divider {
          display: none;
        }

        .header-bosen-logo {
          display: none;
        }

        .menu-toggle {
          min-height: 42px;
          min-width: 44px;
          padding: 0 11px;
        }

        .menu-toggle span {
          display: none;
        }

        .menu-panel {
          top: 76px;
          right: 10px;
          width: calc(100% - 20px);
          max-height: calc(100dvh - 88px);
          border-radius: 22px;
          padding: 16px;
        }

        .menu-panel-head {
          padding-bottom: 14px;
        }

        .menu-close {
          padding: 8px 11px;
          font-size: 12px;
        }

        .menu-nav {
          gap: 2px;
        }

        .menu-nav a {
          grid-template-columns: 32px minmax(0, 1fr);
          gap: 10px;
          padding: 10px 6px;
          font-size: clamp(25px, 10.5vw, 44px);
        }

        .menu-aside {
          grid-template-columns: 1fr;
        }

        .menu-aside article {
          padding: 15px;
        }

        .menu-aside strong {
          font-size: 23px;
        }

        .menu-cta {
          min-height: 52px;
          padding-left: 16px;
        }

        .hero,
        .section {
          padding-left: 18px;
          padding-right: 18px;
        }

        .hero {
          min-height: auto;
          padding-top: 96px;
          padding-bottom: 40px;
        }

        h1 {
          font-size: 48px;
        }

        h2 {
          font-size: 34px;
          line-height: 1;
        }

        .promise {
          font-size: 28px;
        }

        .intro {
          font-size: 16px;
        }

        .stat-item {
          grid-template-columns: 1fr;
          gap: 10px;
        }

        .stat-item strong {
          font-size: 46px;
        }

        .positioning-panel h3 {
          font-size: 34px;
        }

        .hero-actions,
        footer {
          grid-template-columns: 1fr;
