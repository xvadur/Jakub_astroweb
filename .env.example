# Astro reads this at build/dev time.
# Use "staging" only on the staging deployment. It adds noindex + a visual staging ribbon.
PUBLIC_SITE_ENV=production

# Public launch: paste Jakub's real Google Calendar appointment schedule URL.
PUBLIC_BOOKING_URL=

# Optional standalone lead webhook for lightweight Telegram/CRM experiments.
# Current booking wizard uses /api/book; leave this empty unless a separate lead worker is used.
PUBLIC_LEAD_ENDPOINT=

# Browser key for Google Places autocomplete on /rezervacia/.
# This must be a Google Maps Platform API key restricted to allowed HTTP referrers.
PUBLIC_GOOGLE_MAPS_API_KEY=

# Server-side Google OAuth credentials for future Google Calendar integration.
# Keep real values only in local .env, .dev.vars, or Cloudflare secrets, never in Git.
GOOGLE_PROJECT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
GOOGLE_OAUTH_CLIENT_JSON=private/secrets/google_oauth_client.json

# Worker booking defaults. Wrangler vars live in wrangler.toml; override locally only when needed.
BOOKING_TIME_ZONE=Europe/Bratislava
BOOKING_SLOT_MINUTES=30
BOOKING_WORK_START=09:00
BOOKING_WORK_END=19:00
BOOKING_WORKING_DAYS=0,1,2,3,4,5,6
BOOKING_MIN_LEAD_MINUTES=0

# Telegram notification secrets for /api/book. Store as Cloudflare secrets in staging/production.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional OpenClaw handoff after /api/book succeeds.
# Store hook URL/token and delivery target as Cloudflare secrets first on staging.
OPENCLAW_HOOK_URL=
OPENCLAW_HOOK_TOKEN=
OPENCLAW_AGENT_ID=jakub-olsa
OPENCLAW_HOOK_NAME=Jakub-web-booking
OPENCLAW_HOOK_TIMEOUT_MS=8000
OPENCLAW_TIMEOUT_SECONDS=120
OPENCLAW_DELIVER=
OPENCLAW_DELIVERY_CHANNEL=
OPENCLAW_DELIVERY_TO=
OPENCLAW_CF_ACCESS_CLIENT_ID=
OPENCLAW_CF_ACCESS_CLIENT_SECRET=

# Server-side Supabase CRM.
# SUPABASE_SERVICE_ROLE_KEY must be stored as a secret only, never in frontend code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_TENANT_SLUG=jakub-olsa
SUPABASE_TENANT_NAME=Jakub Olša

# Internal dashboard safety.
# Keep public staging on demo data until /dashboard/* and /api/dashboard/* are protected.
DASHBOARD_PUBLIC_MODE=staging-demo
DASHBOARD_DATA_MODE=demo
